<script>
// @ts-nocheck
(function () {
  // ===== Module-level cleanup state =====
  var _timer = null;
  var _destroyed = false;
  var _pageHandler = null;

  function cleanup() {
    if (_timer) { clearTimeout(_timer); _timer = null; }
    if (_pageHandler) {
      document.removeEventListener('astro:page-load', _pageHandler);
      _pageHandler = null;
    }
    _destroyed = true;
  }

  function init() {
    // ===== Query persistent DOM elements =====
    var container = document.getElementById('hero-slideshow');
    var settingsBtn = document.getElementById('hero-settings-btn');
    var settingsPanel = document.getElementById('hero-settings-panel');
    var closeBtn = document.getElementById('settings-close');
    var toggleEnabled = document.getElementById('toggle-enabled');
    var toggleAutoplay = document.getElementById('toggle-autoplay');
    var intervalRange = document.getElementById('interval-range');
    var intervalVal = document.getElementById('interval-val');
    var opacityRange = document.getElementById('opacity-range');
    var opacityVal = document.getElementById('opacity-val');
    var qualitySelect = document.getElementById('quality-select');
    var uploadZone = document.getElementById('upload-zone');
    var fileInput = document.getElementById('file-input');
    var urlInput = document.getElementById('url-input');
    var urlAddBtn = document.getElementById('url-add-btn');
    var mediaManageBtn = document.getElementById('media-manage-btn');
    var mediaCount = document.getElementById('media-count');
    var mediaPanel = document.getElementById('media-panel');
    var mediaPanelBack = document.getElementById('media-panel-back');
    var mediaPanelAdd = document.getElementById('media-panel-add');
    var mediaPanelBody = document.getElementById('media-panel-body');
    var mediaPreview = document.getElementById('media-preview');
    var mediaPreviewClose = document.getElementById('media-preview-close');
    var mediaPreviewImg = document.getElementById('media-preview-img');
    var mediaPreviewVideo = document.getElementById('media-preview-video');

    if (!container || !settingsBtn) return;

    // ===== Element-level guard (same pattern as theme toggle fix) =====
    // Prevents double-initialization when astro:page-load fires on first load
    if (container.__initialized) {
      // Lightweight reinit: just restart slideshow on page navigation return
      _destroyed = false;
      var savedState = null;
      try {
        var s = localStorage.getItem('hero_settings');
        if (s) savedState = JSON.parse(s);
      } catch (e) {}
      if (savedState && savedState.enabled !== false) {
        var overlayVal = savedState.opacity != null ? savedState.opacity : 0.22;
        document.documentElement.style.setProperty('--slideshow-overlay', String(overlayVal));
      }
      return;
    }
    container.__initialized = true;

    // ===== Full initialization =====
    cleanup();
    _destroyed = false;

    var defaults = JSON.parse(container.dataset.defaults || '[]');
    var defInterval = parseInt(container.dataset.defaultInterval || '6000', 10);
    var defOpacity = parseFloat(container.dataset.defaultOpacity || '0.22');

    var layer = container.querySelector('.slideshow-layer');
    var videoEl = container.querySelector('.slideshow-video');
    var idx = 0;
    var currentSrc = '';
    var MAX_INLINE_VIDEO_BYTES = 50 * 1024 * 1024;

    /* ===== State ===== */
    var state = {
      enabled: true,
      autoplay: true,
      interval: defInterval,
      opacity: defOpacity,
      quality: 'high',
      selectedIndex: 0,
      images: []
    };

    /* ===== Load saved ===== */
    try {
      var saved = localStorage.getItem('hero_settings');
      if (saved) {
        var s = JSON.parse(saved);
        if (s.enabled === false) state.enabled = false;
        if (s.autoplay === false) state.autoplay = false;
        if (s.interval) state.interval = s.interval;
        if (s.opacity != null) state.opacity = s.opacity;
        if (s.quality) state.quality = s.quality;
        if (typeof s.selectedIndex === 'number') state.selectedIndex = s.selectedIndex;
        if (Array.isArray(s.images)) state.images = s.images;
      }
    } catch (e) {}

    /* ===== Helpers ===== */
    function allImages() {
      var custom = state.images.filter(function(src) {
        return defaults.indexOf(src) === -1;
      });
      return defaults.concat(custom);
    }

    function save() {
      try {
        localStorage.setItem('hero_settings', JSON.stringify({
          enabled: state.enabled,
          autoplay: state.autoplay,
          interval: state.interval,
          opacity: state.opacity,
          quality: state.quality,
          selectedIndex: state.selectedIndex,
          images: state.images.filter(function(src) {
            return defaults.indexOf(src) === -1;
          })
        }));
        return true;
      } catch (e) {
        if (e.name === 'QuotaExceededError') {
          alert('存储空间不足，请减少图片/视频数量。视频文件较大，建议使用 URL 方式添加。');
        }
        return false;
      }
    }

    function addCustomSource(src) {
      state.images.push(src);
      if (!save()) {
        state.images.pop();
        syncUI();
        return false;
      }
      syncUI();
      restartSlideshow();
      return true;
    }

    function applyOverlay() {
      document.documentElement.style.setProperty('--slideshow-overlay', String(state.opacity));
    }

    /* ===== Video detection ===== */
    function isVideo(src) {
      if (!src) return false;
      // Check data URL MIME type
      if (src.indexOf('data:video/') === 0) return true;
      if (src.indexOf('data:image/') === 0) return false;
      // Check blob type hint
      if (src.indexOf('blob:') === 0) return false;
      // Check URL extension (strip query/fragment)
      var clean = src.split('?')[0].split('#')[0];
      return /\.(mp4|webm|ogg|ogv|mov|m4v)$/i.test(clean);
    }

    /* ===== Image compression (images only) ===== */
    function compressImage(file, quality) {
      if (quality === 'original') {
        return new Promise(function(resolve, reject) {
          var reader = new FileReader();
          reader.onload = function() { resolve(reader.result); };
          reader.onerror = reject;
          reader.readAsDataURL(file);
        });
      }

      var q = quality === 'high' ? 0.95 : 0.75;
      var maxDim = quality === 'high' ? 2560 : 1920;

      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function() {
          var img = new Image();
          img.onload = function() {
            var canvas = document.createElement('canvas');
            var w = img.width, h = img.height;
            if (w > maxDim || h > maxDim) {
              if (w > h) { h = Math.round(h * maxDim / w); w = maxDim; }
              else { w = Math.round(w * maxDim / h); h = maxDim; }
            }
            canvas.width = w;
            canvas.height = h;
            var ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, w, h);
            resolve(canvas.toDataURL('image/jpeg', q));
          };
          img.onerror = reject;
          img.src = reader.result;
        };
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    /* ===== Video as base64 data URL ===== */
    function readVideoAsDataUrl(file) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload = function() { resolve(reader.result); };
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    /* ===== UI sync ===== */
    function syncUI() {
      toggleEnabled.checked = state.enabled;
      toggleAutoplay.checked = state.autoplay;
      intervalRange.value = Math.round(state.interval / 1000);
      intervalVal.textContent = Math.round(state.interval / 1000) + 's';
      opacityRange.value = Math.round(state.opacity * 100);
      opacityVal.textContent = Math.round(state.opacity * 100) + '%';
      qualitySelect.value = state.quality;
      renderList();
      applyOverlay();
    }

    function openPreview(src) {
      if (!mediaPreview) return;
      var video = isVideo(src);
      if (video) {
        if (mediaPreviewImg) mediaPreviewImg.style.display = 'none';
        if (mediaPreviewVideo) { mediaPreviewVideo.src = src; mediaPreviewVideo.style.display = 'block'; }
      } else {
        if (mediaPreviewVideo) mediaPreviewVideo.style.display = 'none';
        if (mediaPreviewImg) { mediaPreviewImg.src = src; mediaPreviewImg.style.display = 'block'; }
      }
      mediaPreview.classList.add('open');
      mediaPreview.setAttribute('aria-hidden', 'false');
    }

    function closePreview() {
      if (!mediaPreview) return;
      mediaPreview.classList.remove('open');
      mediaPreview.setAttribute('aria-hidden', 'true');
      if (mediaPreviewImg) { mediaPreviewImg.src = ''; mediaPreviewImg.style.display = 'none'; }
      if (mediaPreviewVideo) { mediaPreviewVideo.src = ''; mediaPreviewVideo.style.display = 'none'; mediaPreviewVideo.pause(); }
    }

    if (mediaPreviewClose) {
      mediaPreviewClose.addEventListener('click', function(e) { e.stopPropagation(); closePreview(); });
    }
    if (mediaPreview) {
      mediaPreview.addEventListener('click', function(e) { if (e.target === mediaPreview) closePreview(); });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && mediaPreview && mediaPreview.classList.contains('open')) {
        closePreview();
      }
    });

    function renderList() {
      var imgs = allImages();
      var total = imgs.length;
      var customCount = total - defaults.length;
      if (mediaCount) mediaCount.textContent = String(total);

      if (!mediaPanelBody) return;
      if (!total) {
        mediaPanelBody.innerHTML = '<div class="media-panel-empty">暂无媒体，点击右上角 + 添加</div>';
        return;
      }
      mediaPanelBody.innerHTML = '';
      var grid = document.createElement('div');
      grid.className = 'media-grid';

      imgs.forEach(function(src, i) {
        var isDefault = i < defaults.length;
        var video = isVideo(src);
        var card = document.createElement('div');
        card.className = 'media-card';
        if (!state.autoplay && i === state.selectedIndex % imgs.length) {
          card.classList.add('active');
        }

        if (video) {
          var vid = document.createElement('video');
          vid.src = src;
          vid.muted = true;
          vid.loop = true;
          vid.playsInline = true;
          card.appendChild(vid);
        } else {
          var img = document.createElement('img');
          img.src = src;
          img.alt = '';
          img.loading = 'lazy';
          img.onerror = function() { img.style.opacity = '0.3'; };
          card.appendChild(img);
        }

        if (isDefault) {
          var badge = document.createElement('span');
          badge.className = 'media-card-default';
          badge.textContent = '默认';
          card.appendChild(badge);
        }

        if (!isDefault) {
          var del = document.createElement('button');
          del.className = 'media-card-del';
          del.type = 'button';
          del.textContent = '\u00d7';
          del.title = '删除';
          del.onclick = function(e) {
            e.stopPropagation();
            var customIdx = i - defaults.length;
            state.images.splice(customIdx, 1);
            if (state.selectedIndex >= imgs.length - 1) {
              state.selectedIndex = Math.max(0, state.selectedIndex - 1);
            }
            save();
            syncUI();
            restartSlideshow();
          };
          card.appendChild(del);
        }

        var previewBtn = document.createElement('button');
        previewBtn.className = 'media-card-preview';
        previewBtn.type = 'button';
        previewBtn.title = '预览';
        previewBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
        previewBtn.onclick = function(e) {
          e.stopPropagation();
          openPreview(src);
        };
        card.appendChild(previewBtn);

        card.onclick = function() {
          state.selectedIndex = i;
          save();
          renderList();
          restartSlideshow();
        };

        grid.appendChild(card);
      });

      mediaPanelBody.appendChild(grid);
    }

    /* ===== Slideshow logic: handles both images and videos ===== */
    function hideAll() {
      layer.classList.remove('visible');
      videoEl.classList.remove('visible');
      videoEl.pause();
    }

    function showSlide(src) {
      if (src === currentSrc) return;
      var video = isVideo(src);

      if (!currentSrc) {
        // First item: just fade in
        if (video) {
          layer.classList.remove('visible');
          layer.style.backgroundImage = '';
          videoEl.src = src;
          videoEl.loop = true;
          videoEl.muted = true;
          videoEl.playsInline = true;
          requestAnimationFrame(function() { videoEl.classList.add('visible'); });
          videoEl.play().catch(function() {});
        } else {
          videoEl.classList.remove('visible');
          videoEl.pause();
          layer.style.backgroundImage = 'url("' + src + '")';
          requestAnimationFrame(function() { layer.classList.add('visible'); });
        }
        currentSrc = src;
        return;
      }

      // Fade out current first
      hideAll();

      // After fade-out (800ms), swap and fade in
      setTimeout(function() {
        if (_destroyed) return;

        if (video) {
          layer.style.backgroundImage = '';
          videoEl.src = src;
          videoEl.loop = true;
          videoEl.muted = true;
          videoEl.playsInline = true;
          requestAnimationFrame(function() {
            if (_destroyed) return;
            videoEl.classList.add('visible');
            videoEl.play().catch(function() {});
          });
        } else {
          videoEl.src = '';
          layer.style.backgroundImage = 'url("' + src + '")';
          requestAnimationFrame(function() {
            if (_destroyed) return;
            layer.classList.add('visible');
          });
        }
        currentSrc = src;
      }, 800);
    }

    function loadAt(index) {
      if (_destroyed) return;
      var imgs = allImages();
      if (!imgs.length) {
        hideAll();
        layer.style.backgroundImage = '';
        videoEl.src = '';
        currentSrc = '';
        return;
      }

      var src = imgs[index % imgs.length];

      if (isVideo(src)) {
        // For video, just show it directly (no preload check needed)
        showSlide(src);
      } else {
        // Preload image before showing
        var img = new Image();
        img.onload = function() {
          if (!_destroyed) showSlide(img.src);
        };
        img.onerror = function() {
          if (!_destroyed && imgs.length > 1) {
            idx = (idx + 1) % imgs.length;
            loadAt(idx);
          }
        };
        img.src = src;
      }
    }

    function advance() {
      if (_destroyed) return;
      var imgs = allImages();
      if (!imgs.length) return;
      idx = (idx + 1) % imgs.length;
      loadAt(idx);
      if (state.autoplay && imgs.length > 1) {
        // Wait for fade-out(800ms) + fade-in(1500ms) before scheduling next
        _timer = setTimeout(advance, state.interval + 2300);
      }
    }

    function start() {
      stop();
      if (!state.enabled) return;
      var imgs = allImages();
      if (!imgs.length) return;
      if (!state.autoplay) {
        var si = state.selectedIndex % imgs.length;
        loadAt(si);
        return;
      }
      idx = idx % imgs.length;
      loadAt(idx);
      if (imgs.length > 1) {
        _timer = setTimeout(advance, state.interval);
      }
    }

    function stop() {
      if (_timer) { clearTimeout(_timer); _timer = null; }
    }

    function restartSlideshow() {
      stop();
      currentSrc = '';
      if (state.enabled) start();
      else {
        hideAll();
        layer.style.backgroundImage = '';
        videoEl.src = '';
      }
    }

    /* ===== Apply initial state ===== */
    if (!state.enabled) {
      document.documentElement.classList.add('no-hero-bg');
    }
    applyOverlay();
    syncUI();
    if (state.enabled) start();

    /* ===== Event handlers ===== */
    settingsBtn.addEventListener('click', function() {
      settingsPanel.classList.toggle('open');
    });

    closeBtn.addEventListener('click', function() {
      settingsPanel.classList.remove('open');
    });

    toggleEnabled.addEventListener('change', function() {
      state.enabled = this.checked;
      save();
      if (state.enabled) {
        document.documentElement.classList.remove('no-hero-bg');
        start();
      } else {
        document.documentElement.classList.add('no-hero-bg');
        stop();
        hideAll();
      }
    });

    toggleAutoplay.addEventListener('change', function() {
      state.autoplay = this.checked;
      save();
      syncUI();
      restartSlideshow();
    });

    intervalRange.addEventListener('input', function() {
      state.interval = parseInt(this.value, 10) * 1000;
      intervalVal.textContent = this.value + 's';
      save();
      restartSlideshow();
    });

    opacityRange.addEventListener('input', function() {
      state.opacity = parseInt(this.value, 10) / 100;
      opacityVal.textContent = this.value + '%';
      applyOverlay();
      save();
    });

    qualitySelect.addEventListener('change', function() {
      state.quality = this.value;
      save();
    });

    fileInput.addEventListener('change', function() {
      handleFiles(this.files);
      this.value = '';
    });

    function handleFiles(files) {
      var quality = state.quality;
      Array.from(files).forEach(function(file) {
        if (file.type.startsWith('video/')) {
          if (file.size > MAX_INLINE_VIDEO_BYTES) {
            alert('视频文件超过 50MB，直接导入会导致页面卡顿并占满浏览器存储。请将视频放到图床、对象存储或 public 目录后，用 URL 添加。');
            return;
          }
          // Video: read as data URL (no compression — videos are too large)
          readVideoAsDataUrl(file).then(function(dataUrl) {
            addCustomSource(dataUrl);
          }).catch(function(err) {
            console.warn('Video processing failed:', err);
          });
        } else if (file.type.startsWith('image/')) {
          // Image: compress based on quality setting
          compressImage(file, quality).then(function(dataUrl) {
            addCustomSource(dataUrl);
          }).catch(function(err) {
            console.warn('Image processing failed:', err);
          });
        }
      });
    }

    uploadZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      this.classList.add('dragover');
    });

    uploadZone.addEventListener('dragleave', function() {
      this.classList.remove('dragover');
    });

    uploadZone.addEventListener('drop', function(e) {
      e.preventDefault();
      this.classList.remove('dragover');
      if (e.dataTransfer && e.dataTransfer.files.length) {
        handleFiles(e.dataTransfer.files);
      }
    });

    urlAddBtn.addEventListener('click', addUrl);
    urlInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') addUrl();
    });

    function addUrl() {
      var url = urlInput.value.trim();
      if (!url) return;
      if (!addCustomSource(url)) return;
      urlInput.value = '';
    }

    if (mediaManageBtn) {
      mediaManageBtn.addEventListener('click', function() {
        settingsPanel.classList.remove('open');
        mediaPanel.classList.add('open');
      });
    }

    if (mediaPanelBack) {
      mediaPanelBack.addEventListener('click', function() {
        mediaPanel.classList.remove('open');
        settingsPanel.classList.add('open');
      });
    }

    if (mediaPanel) {
      mediaPanel.addEventListener('click', function(e) {
        if (e.target === mediaPanel) {
          mediaPanel.classList.remove('open');
        }
      });
    }

    if (mediaPanelAdd) {
      mediaPanelAdd.addEventListener('click', function() {
        fileInput.click();
      });
    }

    container.addEventListener('mouseenter', stop);
    container.addEventListener('mouseleave', function() {
      if (state.enabled && !_destroyed) start();
    });

    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stop();
      else if (state.enabled && !_destroyed) start();
    });

    /* ===== Register page-load handler for navigation ===== */
    _pageHandler = function() {
      var el = document.getElementById('hero-slideshow');
      if (!el) {
        // Navigated away from homepage — stop slideshow
        stop();
        _destroyed = true;
        return;
      }
      // Re-init on return to homepage (element-level guard handles dedup)
      init();
    };
    document.addEventListener('astro:page-load', _pageHandler);
  }

  /* ===== Bootstrap ===== */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
