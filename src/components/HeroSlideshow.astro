---
/**
 * HeroSlideshow — Homepage background slideshow with settings panel
 *
 * HOW TO ADD DEFAULT IMAGES (always available):
 *   Add paths or URLs to the defaultImages array below.
 *
 * Examples:
 *   '/hero1.jpg'                        → public/hero1.jpg
 *   '/images/bg.png'                    → public/images/bg.png
 *   'https://example.com/wallpaper.jpg' → online URL
 *   '/hero.mp4'                         → public/hero.mp4 (video)
 */
const defaultImages: string[] = [
  // 填入 R2 图床 URL，例如：
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/miku_star1.mp4',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/953c5e02532e4eeb9ec758e7fd7e8ad3.jpg',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/1b87e2c5880511ebb6edd017c2d2eca2.png',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/wallhaven-1p9z61.jpg',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/miku_ying1.mp4',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/snow.mp4',
  'https://pub-6108779417b647c592c51538e44c8bd0.r2.dev/%E8%83%8C%E6%99%AF%E5%9B%BE/output.mp4'
];

const DEFAULT_INTERVAL = 6000;
const DEFAULT_OPACITY = 0.22;
---

<div
  class="hero-slideshow"
  id="hero-slideshow"
  transition:persist
  data-defaults={JSON.stringify(defaultImages)}
  data-default-interval={String(DEFAULT_INTERVAL)}
  data-default-opacity={String(DEFAULT_OPACITY)}
>
  <div class="slideshow-layer" aria-hidden="true"></div>
  <video class="slideshow-video" aria-hidden="true" muted loop playsinline preload="auto"></video>
  <div class="slideshow-overlay" aria-hidden="true"></div>
</div>

<button
  class="hero-settings-btn"
  id="hero-settings-btn"
  transition:persist
  type="button"
  aria-label="背景设置"
  title="背景设置"
>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="3"/>
    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
  </svg>
</button>

<div class="hero-settings-panel" id="hero-settings-panel" transition:persist>
  <div class="settings-header">
    <span class="settings-title">背景设置</span>
    <button class="settings-close" id="settings-close" type="button" aria-label="关闭">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="settings-body">
    <div class="setting-row">
      <span class="setting-label">启用背景</span>
      <label class="toggle-switch">
        <input type="checkbox" id="toggle-enabled" checked />
        <span class="toggle-track"></span>
      </label>
    </div>

    <div class="setting-row">
      <span class="setting-label">自动轮播</span>
      <label class="toggle-switch">
        <input type="checkbox" id="toggle-autoplay" checked />
        <span class="toggle-track"></span>
      </label>
    </div>

    <div class="setting-group">
      <span class="setting-label">切换间隔</span>
      <div class="range-row">
        <input type="range" id="interval-range" min="2" max="20" step="1" value="6" />
        <span class="range-value" id="interval-val">6s</span>
      </div>
    </div>

    <div class="setting-group">
      <span class="setting-label">遮罩透明度</span>
      <div class="range-row">
        <input type="range" id="opacity-range" min="0" max="80" step="5" value="22" />
        <span class="range-value" id="opacity-val">22%</span>
      </div>
    </div>

    <div class="setting-group">
      <span class="setting-label">上传画质</span>
      <select class="quality-select" id="quality-select">
        <option value="high">高质量 (JPEG 95%)</option>
        <option value="medium">中等 (JPEG 75%)</option>
        <option value="original">原始画质 (不压缩)</option>
      </select>
    </div>

    <div class="setting-group">
      <span class="setting-label">添加图片/视频</span>
      <label class="upload-zone" id="upload-zone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span>点击上传或拖入图片/视频</span>
        <input type="file" accept="image/*,video/mp4" multiple id="file-input" hidden />
      </label>
      <div class="url-row">
        <input type="url" id="url-input" placeholder="粘贴图片/视频 URL 后回车" />
        <button class="url-add-btn" id="url-add-btn" type="button">添加</button>
      </div>
    </div>

    <div class="setting-group">
      <button class="media-manage-btn" id="media-manage-btn" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <span>背景管理</span>
        <span class="media-count" id="media-count">0</span>
      </button>
    </div>
  </div>
</div>

<div class="media-panel" id="media-panel" transition:persist>
  <div class="media-panel-inner">
    <div class="media-panel-header">
      <button class="media-panel-back" id="media-panel-back" type="button" aria-label="返回">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <span class="media-panel-title">背景库</span>
      <button class="media-panel-add" id="media-panel-add" type="button" aria-label="添加">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
    </div>
    <div class="media-panel-body" id="media-panel-body">
      <div class="media-panel-empty">暂无媒体，点击右上角 + 添加</div>
    </div>
  </div>
</div>

<div class="media-preview" id="media-preview" transition:persist aria-hidden="true">
  <button class="media-preview-close" id="media-preview-close" type="button" aria-label="关闭">&times;</button>
  <div class="media-preview-stage" id="media-preview-stage">
    <img class="media-preview-img" id="media-preview-img" src="" alt="" />
    <video class="media-preview-video" id="media-preview-video" src="" muted loop playsinline controls></video>
  </div>
</div>

<style>
  /* ===== Slideshow Container ===== */
  .hero-slideshow {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .slideshow-layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .slideshow-layer.visible {
    opacity: 1;
  }

  .slideshow-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    z-index: 1;
  }

  .slideshow-video.visible {
    opacity: 1;
  }

  .slideshow-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, var(--slideshow-overlay, 0.22)) 0%,
      rgba(0, 0, 0, calc(var(--slideshow-overlay, 0.22) + 0.12)) 50%,
      rgba(0, 0, 0, calc(var(--slideshow-overlay, 0.22) + 0.22)) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* ===== Settings Button ===== */
  .hero-settings-btn {
    position: fixed;
    left: 28px;
    top: 90px;
    z-index: 9999;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: linear-gradient(135deg, rgba(255,255,255,0.30), rgba(255,255,255,0.12));
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-soft);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease, color 220ms ease;
  }

  [data-theme="light"] .hero-settings-btn {
    background: linear-gradient(135deg, rgba(255,255,255,0.50), rgba(255,240,245,0.30));
    border-color: rgba(255, 180, 210, 0.40);
    box-shadow: 0 4px 16px rgba(200, 80, 150, 0.08);
  }

  .hero-settings-btn:hover {
    transform: scale(1.1) rotate(30deg);
    border-color: var(--hover-border);
    box-shadow: 0 4px 20px rgba(var(--accent-rgb), 0.22);
    color: var(--accent);
  }

  .hero-settings-btn:active {
    transform: scale(0.95);
  }

  .hero-settings-btn svg {
    width: 18px;
    height: 18px;
  }

  /* ===== Settings Panel ===== */
  .hero-settings-panel {
    position: fixed;
    left: 28px;
    top: 142px;
    z-index: 9998;
    width: 320px;
    max-height: calc(100vh - 170px);
    background: linear-gradient(135deg, rgba(255,255,255,0.38), rgba(255,255,255,0.18));
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(28px) saturate(1.5);
    -webkit-backdrop-filter: blur(28px) saturate(1.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    display: none;
    flex-direction: column;
    overflow: hidden;
    animation: panel-in 0.28s ease;
  }

  [data-theme="light"] .hero-settings-panel {
    background: linear-gradient(135deg, rgba(255,255,255,0.55), rgba(255,230,245,0.35));
    border-color: rgba(255, 180, 210, 0.40);
    box-shadow: 0 8px 32px rgba(200, 80, 150, 0.10);
  }

  .hero-settings-panel.open {
    display: flex;
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(-10px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .settings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.20);
  }

  [data-theme="light"] .settings-header {
    border-bottom-color: rgba(255, 255, 255, 0.20);
  }

  .settings-title {
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--text);
  }

  .settings-close {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: background 200ms, color 200ms;
  }

  .settings-close:hover {
    background: var(--tag-bg);
    color: var(--accent);
  }

  .settings-close svg {
    width: 16px;
    height: 16px;
  }

  .settings-body {
    padding: 14px 18px 18px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* --- Setting rows --- */
  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .setting-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .setting-label {
    color: var(--text-soft);
    font-size: 0.86rem;
    font-weight: 600;
  }

  /* --- Toggle switch --- */
  .toggle-switch {
    position: relative;
    display: inline-block;
    cursor: pointer;
  }

  .toggle-switch input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-track {
    display: block;
    width: 40px;
    height: 22px;
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.20);
    border: 1px solid rgba(255, 255, 255, 0.30);
    transition: background 200ms, border-color 200ms;
    position: relative;
  }

  [data-theme="light"] .toggle-track {
    background: rgba(255, 255, 255, 0.50);
    border-color: rgba(255, 180, 210, 0.35);
  }

  .toggle-track::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--muted);
    transition: transform 200ms ease, background 200ms ease;
  }

  .toggle-switch input:checked + .toggle-track {
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    border-color: transparent;
  }

  .toggle-switch input:checked + .toggle-track::after {
    transform: translateX(18px);
    background: #fff;
  }

  /* --- Range sliders --- */
  .range-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .range-row input[type="range"] {
    flex: 1;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.25);
    outline: none;
  }

  [data-theme="light"] .range-row input[type="range"] {
    background: rgba(200, 80, 150, 0.20);
  }

  .range-row input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    cursor: pointer;
    border: none;
    box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.30);
  }

  .range-row input[type="range"]::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    cursor: pointer;
    border: none;
  }

  .range-value {
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
    min-width: 32px;
    text-align: right;
  }

  /* --- Quality select --- */
  .quality-select {
    width: 100%;
    padding: 8px 12px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.15);
    color: var(--text);
    font-size: 0.84rem;
    font-family: inherit;
    font-weight: 500;
    outline: none;
    cursor: pointer;
    transition: border-color 200ms, box-shadow 200ms;
  }

  [data-theme="light"] .quality-select {
    background: rgba(255, 240, 248, 0.50);
    border-color: rgba(255, 180, 210, 0.40);
  }

  .quality-select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--focus-shadow);
  }

  /* --- Upload zone --- */
  .upload-zone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px;
    border: 2px dashed rgba(255, 255, 255, 0.40);
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.08);
    transition: border-color 200ms, color 200ms, background 200ms;
  }

  [data-theme="light"] .upload-zone {
    border-color: rgba(255, 180, 210, 0.40);
    background: rgba(255, 240, 248, 0.30);
  }

  .upload-zone:hover,
  .upload-zone.dragover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }

  .upload-zone svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* --- URL input --- */
  .url-row {
    display: flex;
    gap: 6px;
  }

  .url-row input {
    flex: 1;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.15);
    color: var(--text);
    font-size: 0.82rem;
    font-family: inherit;
    outline: none;
    transition: border-color 200ms, box-shadow 200ms;
  }

  [data-theme="light"] .url-row input {
    background: rgba(255, 240, 248, 0.50);
    border-color: rgba(255, 180, 210, 0.40);
  }

  .url-row input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--focus-shadow);
  }

  .url-add-btn {
    padding: 8px 14px;
    border-radius: 999px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 200ms, box-shadow 200ms;
  }

  .url-add-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(var(--accent-rgb), 0.30);
  }

  /* --- Media manage button --- */
  .media-manage-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.12);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 200ms, background 200ms, transform 200ms;
  }

  [data-theme="light"] .media-manage-btn {
    background: rgba(255, 240, 248, 0.40);
    border-color: rgba(255, 180, 210, 0.35);
  }

  .media-manage-btn:hover {
    border-color: var(--accent);
    background: rgba(var(--accent-rgb), 0.08);
  }

  .media-manage-btn:active {
    transform: scale(0.98);
  }

  .media-manage-btn svg {
    width: 18px;
    height: 18px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .media-count {
    margin-left: auto;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    min-width: 20px;
    text-align: center;
  }

  /* --- Media Panel (centered dialog) --- */
  .media-panel {
    position: fixed;
    inset: 0;
    z-index: 10001;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    animation: media-panel-in 0.25s ease;
  }

  .media-panel.open {
    display: flex;
  }

  .media-panel-inner {
    width: 90vw;
    max-width: 800px;
    height: 75vh;
    max-height: 600px;
    background: rgba(14, 12, 26, 0.45);
    backdrop-filter: blur(30px) saturate(1.4);
    -webkit-backdrop-filter: blur(30px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }

  [data-theme="light"] .media-panel-inner {
    background: rgba(255, 240, 248, 0.45);
    border-color: rgba(200, 80, 150, 0.2);
  }

  .media-panel.open {
    display: flex;
  }

  @keyframes media-panel-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .media-panel-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    flex-shrink: 0;
  }

  [data-theme="light"] .media-panel-header {
    border-bottom-color: rgba(200, 80, 150, 0.12);
    background: rgba(255, 255, 255, 0.15);
  }

  .media-panel-back {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.1);
