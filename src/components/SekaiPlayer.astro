  function drawCdVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var cx = width / 2;
    var cy = height / 2;
    var size = Math.min(width, height);
    var rawBass = getBandAverage(0, 0.13);
    var transient = Math.max(0, rawBass - (visualizerLevels.cdRawBass || 0) * 0.92);
    visualizerLevels.cdRawBass = rawBass;
    var bass = smoothLevel('cdBass', rawBass, 0.72);
    var high = smoothLevel('cdHigh', getBandAverage(0.55, 1), 0.85);
    var beat = smoothLevel('cdBeat', Math.min(1, bass * 0.6 + transient * 2.2), 0.62);

    cdEl.style.setProperty('--sekai-cd-scale', (1 + beat * 0.008).toFixed(3));
    cdEl.style.setProperty('--sekai-cd-glow', (0.1 + beat * 0.1 + high * 0.03).toFixed(3));

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';

    // Re-extract colors when cover changes
    if (!visualizerLevels.dominantColors || visualizerLevels.lastCoverSrc !== (coverImg && coverImg.src)) {
      visualizerLevels.dominantColors = extractCoverColors();
      visualizerLevels.lastCoverSrc = coverImg ? coverImg.src : '';
    }

    var colors = visualizerLevels.dominantColors;
    var useExtracted = colors.length > 0;

    var barCount = frequencyData ? frequencyData.length : 128;
    var coverRadius = size * 0.4;
    var minBarH = 5;
    var maxBarH = 80;
    var overlap = Math.max(2, Math.floor(barCount * 0.06));
    var overlapThreshold = barCount - overlap;
    var startValues = new Float32Array(overlap);

    for (var i = 0; i < barCount; i++) {
      var ratio = i / barCount;

      // Frequency transform with power curve (matches 25ji exactly)
      var rawVal = frequencyData ? frequencyData[i] / 255 : 0;
      var transformed = rawVal * (0.5 + Math.pow(ratio, 1.5));

      if (transformed < 0.25) {
        transformed = 0;
      } else if (transformed < 0.65) {
        transformed = (transformed - 0.25) * 2.0;
      } else {
        transformed = 0.8 + (transformed - 0.65) * 0.6;
      }

      // Store start values for overlap blend
      if (i < overlap) {
        startValues[i] = transformed;
      }

      // Seamless circle blend at the seam
      if (i >= overlapThreshold) {
        var pos = i - overlapThreshold;
        var dvStart = startValues[pos];
        var tRaw = overlap > 1 ? pos / (overlap - 1) : 1;
        var t = tRaw * tRaw * (3 - 2 * tRaw); // smoothstep
        transformed = transformed * (1 - t) + dvStart * t * (0.7 + 0.3 * Math.random());
      }

      var barH = minBarH + transformed * (maxBarH - minBarH);
      var angle = ratio * Math.PI * 2 - Math.PI / 2;

      var x1 = cx + Math.cos(angle) * coverRadius;
      var y1 = cy + Math.sin(angle) * coverRadius;
      var x2 = cx + Math.cos(angle) * (coverRadius + barH);
      var y2 = cy + Math.sin(angle) * (coverRadius + barH);

      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.lineWidth = 4;

      var gradient = ctx.createLinearGradient(x1, y1, x2, y2);

      if (useExtracted) {
        var rotOffset = (Date.now() * 0.0005) % colors.length;
        var basePos = ratio * colors.length;
        var colorPos = (basePos + rotOffset) % colors.length;
        var ci = Math.floor(colorPos);
        var ni = (ci + 1) % colors.length;
        var blend = colorPos - ci;

        var c1 = colors[ci];
        var c2 = colors[ni];
        var h = c1.h + (c2.h - c1.h) * blend;
        var s = c1.s + (c2.s - c1.s) * blend;
        var l = c1.l + (c2.l - c1.l) * blend;

        var intensity = frequencyData ? frequencyData[i] / 255 : 0;
        var lightness1 = Math.max(25, l - 15);
        var lightness2 = Math.min(75, l + 15 + 15 * intensity);

        gradient.addColorStop(0, 'hsla(' + h + ',' + s + '%,' + lightness1 + '%,0.6)');
        gradient.addColorStop(1, 'hsla(' + h + ',' + s + '%,' + lightness2 + '%,0.95)');
      } else {
        var hue = (i * 360 / barCount + Date.now() * 0.05) % 360;
        gradient.addColorStop(0, 'hsla(' + hue + ',70%,50%,0.4)');
        gradient.addColorStop(1, 'hsla(' + hue + ',80%,60%,0.8)');
      }

      ctx.strokeStyle = gradient;
      ctx.lineCap = 'round';
      ctx.stroke();
    }

    ctx.restore();
  }

  function extractCoverColors() {
    try {
      var img = coverImg;
      if (!img || !img.complete || !img.naturalWidth || !img.src) return [];

      var tempCanvas = document.createElement('canvas');
      var tempCtx = tempCanvas.getContext('2d');
      var sz = 50;
      tempCanvas.width = sz;
      tempCanvas.height = sz;
      tempCtx.drawImage(img, 0, 0, sz, sz);
      var imageData = tempCtx.getImageData(0, 0, sz, sz);
      var pixels = imageData.data;

      var colorMap = {};
      var totalSaturation = 0;
      var sampleCount = 0;

      for (var p = 0; p < pixels.length; p += 40) {
        var r = pixels[p];
        var g = pixels[p + 1];
        var b = pixels[p + 2];
        var a = pixels[p + 3];

        // Skip transparent, very dark, very bright pixels
        if (a < 128) continue;
        if ((r < 15 && g < 15 && b < 15) || (r > 240 && g > 240 && b > 240)) continue;

        var max = Math.max(r, g, b);
        var min = Math.min(r, g, b);
        var s = max === 0 ? 0 : ((max - min) / max) * 100;
        var l = (max + min) / 2 / 255 * 100;

        totalSaturation += s;
        sampleCount++;

        if (s < 20) continue;

        var h = 0;
        if (max === r) h = ((g - b) / (max - min)) * 60;
        else if (max === g) h = 120 + ((b - r) / (max - min)) * 60;
        else h = 240 + ((r - g) / (max - min)) * 60;
        if (h < 0) h += 360;

        var hueKey = Math.round(h / 30) * 30;
        if (!colorMap[hueKey]) colorMap[hueKey] = { h: h, s: s, l: l, count: 0 };
        colorMap[hueKey].count++;
        colorMap[hueKey].h = (colorMap[hueKey].h * (colorMap[hueKey].count - 1) + h) / colorMap[hueKey].count;
        colorMap[hueKey].s = (colorMap[hueKey].s * (colorMap[hueKey].count - 1) + s) / colorMap[hueKey].count;
        colorMap[hueKey].l = (colorMap[hueKey].l * (colorMap[hueKey].count - 1) + l) / colorMap[hueKey].count;
      }

      // Monochrome check
      var avgSat = sampleCount > 0 ? totalSaturation / sampleCount : 0;
      if (avgSat < 15) {
        return [
          { h: 0, s: 0, l: 30 }, { h: 0, s: 0, l: 45 },
          { h: 0, s: 0, l: 60 }, { h: 0, s: 0, l: 75 }
        ];
      }

      var colorList = Object.values(colorMap).sort(function(a, b) { return b.count - a.count; });
      if (colorList.length === 0) return [];

      var dominant = colorList[0];
      var totalCount = colorList.reduce(function(a, c) { return a + c.count; }, 0);

      // Hue variance
      var hueVariance = 0;
      for (var c = 0; c < colorList.length; c++) {
        var diff = Math.abs(colorList[c].h - dominant.h);
        hueVariance += Math.min(diff, 360 - diff) * colorList[c].count;
      }
      hueVariance = totalCount > 0 ? hueVariance / totalCount : 0;

      if (hueVariance < 30) {
        return [
          { h: dominant.h, s: Math.max(dominant.s, 60), l: 35 },
          { h: dominant.h, s: Math.max(dominant.s, 60), l: 50 },
          { h: dominant.h, s: Math.max(dominant.s, 60), l: 65 },
          { h: dominant.h, s: Math.max(dominant.s, 60), l: 75 }
        ];
      }

      // Sort by hue for smooth gradient
      var top = colorList.slice(0, 8).map(function(c) {
        return { h: c.h, s: Math.max(c.s, 50), l: Math.min(Math.max(c.l, 40), 70) };
      });
      return sortColorsForGradient(top);
    } catch (e) {
      return [];
    }
  }

  function sortColorsForGradient(colors) {
    if (colors.length <= 1) return colors;
    var sorted = colors.slice().sort(function(a, b) { return a.h - b.h; });

    var maxGap = 0;
    var maxGapIdx = 0;
    for (var i = 0; i < sorted.length; i++) {
      var cur = sorted[i].h;
      var nxt = sorted[(i + 1) % sorted.length].h;
      var gap = i === sorted.length - 1 ? (360 - cur + nxt) : (nxt - cur);
      if (gap > maxGap) { maxGap = gap; maxGapIdx = i; }
    }

    if (maxGap > 60) {
      return sorted.slice(maxGapIdx + 1).concat(sorted.slice(0, maxGapIdx + 1));
    }
    return sorted;
  }

  function drawDockVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var cx = width / 2;
    var cy = height / 2;
    var size = Math.min(width, height);
    var time = Date.now() * 0.0005;
    var bass = smoothLevel('dockBass', getBandAverage(0, 0.15), 0.78);

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';

    var colors = visualizerLevels.dominantColors || [];
    var useExtracted = colors.length > 0;

    var barCount = 48;
    var innerR = size * 0.42;
    var minBarH = 2;
    var maxBarH = size * 0.2;

    for (var i = 0; i < barCount; i++) {
      var ratio = i / barCount;
      var angle = ratio * Math.PI * 2 - Math.PI / 2;

      var rawFreq = sampleFrequency(ratio, 1.32);
      var transformed;
      if (rawFreq < 0.25) transformed = 0;
      else if (rawFreq < 0.65) transformed = (rawFreq - 0.25) * 2.0;
      else transformed = 0.8 + (rawFreq - 0.65) * 0.6;
      var freq = smoothLevel('dockBar' + i, transformed, transformed > (visualizerLevels['dockBar' + i] || 0) ? 0.24 : 0.66);

      var barH = minBarH + freq * (maxBarH - minBarH);

      var x1 = cx + Math.cos(angle) * innerR;
      var y1 = cy + Math.sin(angle) * innerR;
      var x2 = cx + Math.cos(angle) * (innerR + barH);
      var y2 = cy + Math.sin(angle) * (innerR + barH);

      ctx.beginPath();
      ctx.moveTo(x1, y1);
      ctx.lineTo(x2, y2);
      ctx.lineWidth = 3;

      if (useExtracted) {
        var rotOffset = time % colors.length;
        var colorPos = (ratio * colors.length + rotOffset) % colors.length;
        var ci = Math.floor(colorPos);
        var ni = (ci + 1) % colors.length;
        var blend = colorPos - ci;
        var c1 = colors[ci];
        var c2 = colors[ni];
        var h = c1.h + (c2.h - c1.h) * blend;
        var s = c1.s + (c2.s - c1.s) * blend;
        var baseL = c1.l + (c2.l - c1.l) * blend;
        var l2 = Math.min(75, baseL + 15 + 15 * freq);

        var gradient = ctx.createLinearGradient(x1, y1, x2, y2);
        gradient.addColorStop(0, 'hsla(' + h + ',' + s + '%,' + Math.max(25, baseL - 15) + '%,0.6)');
