    ctx.shadowColor = 'hsla(270, 60%, 78%, ' + (0.15 + bass * 0.15) + ')';
    ctx.stroke();

    ctx.restore();
  }

  function drawPageVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var time = performance.now() * 0.001;
    var bass = smoothLevel('pageBass', getBandAverage(0, 0.12), 0.86);
    var mid = smoothLevel('pageMid', getBandAverage(0.12, 0.52), 0.88);
    var high = smoothLevel('pageHigh', getBandAverage(0.52, 1), 0.9);
    var samples = 128;

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';

    // 1. Bottom rising bubbles
    var bubbleCount = 18;
    for (var i = 0; i < bubbleCount; i++) {
      var seed = i * 137.508;
      var bx = (Math.sin(seed) * 0.5 + 0.5) * width;
      var speed = 0.3 + (i % 5) * 0.12;
      var by = height - ((time * speed * 40 + i * 60) % (height * 0.85));
      var bSize = (2 + (i % 4) * 1.5 + bass * 3) * prepared.dpr;
      var bAlpha = (0.08 + mid * 0.12) * (1 - by / height);
      var bHue = (dreamHues[i % dreamHues.length] + time * 6) % 360;
      ctx.beginPath();
      ctx.arc(bx, by, bSize, 0, Math.PI * 2);
      ctx.fillStyle = 'hsla(' + bHue + ', 60%, 78%, ' + bAlpha + ')';
      ctx.fill();
    }

    // 2. Bottom frequency wave
    var waveGrad = ctx.createLinearGradient(0, height * 0.82, width, height);
    waveGrad.addColorStop(0, 'hsla(328, 55%, 72%, ' + (0.05 + bass * 0.08) + ')');
    waveGrad.addColorStop(0.5, 'hsla(270, 52%, 75%, ' + (0.04 + mid * 0.06) + ')');
    waveGrad.addColorStop(1, 'hsla(195, 55%, 72%, ' + (0.03 + high * 0.05) + ')');
    ctx.beginPath();
    ctx.moveTo(0, height);
    for (var s = 0; s <= samples; s++) {
      var p = s / samples;
      var f = sampleFrequency(p, 1.18);
      var waveY = Math.sin(p * Math.PI * 3 + time * 0.5) * height * 0.01;
      var y = height * (0.94 - bass * 0.02) - f * height * 0.1 + waveY;
      ctx.lineTo(p * width, y);
    }
    ctx.lineTo(width, height);
    ctx.closePath();
    ctx.fillStyle = waveGrad;
    ctx.globalAlpha = 0.4;
    ctx.fill();
    ctx.globalAlpha = 1;

    ctx.restore();
  }

  function readState() {
    try {
      var raw = sessionStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch (error) {
      return null;
    }
  }

  function saveState() {
    if (isRestoring) return;
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        musicId: currentSong ? currentSong.id : null,
        vocalId: currentVocal ? currentVocal.id : null,
        mode: playbackMode,
        order: playbackOrder,
        visualizer: getVisualizerStateName(),
        visualizerTargets: {
          cd: visualizerTargets.cd,
          dock: visualizerTargets.dock,
          page: visualizerTargets.page
        },
        time: audio.currentTime || 0,
        playing: isPlaying ? 1 : 0,
        volume: audio.volume,
        query: query,
        tag: tagFilter
      }));
    } catch (error) {}
  }

  function restoreSelection(state) {
    restoredOnce = true;
    if (!state) return;
    if (state.tag) {
      tagFilter = state.tag;
      if (TAG_ORDER.indexOf(tagFilter) < 0) tagFilter = 'all';
      updateTagDropdownLabel();
      populateTagFilter();
    }
    if (state.query) {
      query = state.query;
      searchInput.value = query;
    }
    applyFilters();
    if (!state.musicId) return;
    var song = songs.find(function(item) { return String(item.id) === String(state.musicId); });
    if (!song) return;
    selectSong(song, false, state.vocalId, state.time || 0);
  }

  btn.addEventListener('click', function(event) {
    event.stopPropagation();
    panel.classList.toggle('hidden');
    if (!panel.classList.contains('hidden')) ensureCatalog().catch(function() {});
  });
  closeBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    panel.classList.add('hidden');
    panel.classList.remove('sekai-mobile-library-open');
    if (playlistToggle) playlistToggle.classList.remove('active');
  });
  playPauseBtn.addEventListener('click', togglePlay);
  prevBtn.addEventListener('click', prevTrack);
  nextBtn.addEventListener('click', nextTrack);

  // Mobile: playlist toggle (show/hide library overlay)
  if (playlistToggle) {
    playlistToggle.addEventListener('click', function(event) {
      event.stopPropagation();
      panel.classList.toggle('sekai-mobile-library-open');
      playlistToggle.classList.toggle('active');
    });
  }
  // Mobile: library close button (injected dynamically)
  panel.addEventListener('click', function(event) {
    if (event.target.closest('.sekai-lib-close')) {
      panel.classList.remove('sekai-mobile-library-open');
      if (playlistToggle) playlistToggle.classList.remove('active');
    }
  });
  vocalButton.addEventListener('click', function(event) {
    event.stopPropagation();
    toggleDropdown(vocalDropdown);
  });
  tagButton.addEventListener('click', function(event) {
    event.stopPropagation();
    toggleDropdown(tagDropdown);
  });
  volBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    volPopover.classList.toggle('open');
  });
  shortBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setMode('short');
  });
  longBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setMode('long');
  });
  sequenceBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('sequence');
  });
  shuffleBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('shuffle');
  });
  if (sequenceBtnM) sequenceBtnM.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('sequence');
  });
  if (shuffleBtnM) shuffleBtnM.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('shuffle');
  });
  vizOffBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    clearVisualizerTargets();
  });
  vizCdBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('cd');
  });
  vizDockBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('dock');
  });
  vizPageBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('page');
  });

  searchInput.addEventListener('input', function(event) {
    query = event.target.value || '';
    applyFilters();
  });
  audio.addEventListener('timeupdate', function() {
    if (audio.duration) {
      progressBar.value = (audio.currentTime / audio.duration) * 100;
      currentTimeEl.textContent = fmt(audio.currentTime);
    }
  });
  audio.addEventListener('loadedmetadata', function() {
    totalTimeEl.textContent = fmt(audio.duration);
    updateCatalogStatus();
  });
  audio.addEventListener('canplay', function() {
    updateCatalogStatus();
    if (window.__immersiveVizActive || hasVisualizerTarget()) {
      ensureVisualizer();
      resumeVisualizerAudio();
    }
  });
  audio.addEventListener('play', function() {
    if (window.__immersiveVizActive || hasVisualizerTarget()) {
      ensureVisualizer();
      resumeVisualizerAudio();
    }
  });
  audio.addEventListener('waiting', function() {
    if (audio.src) setStatus((playbackMode === 'long' ? 'FULL' : 'PREVIEW') + ' / 缓冲中', '');
  });
  audio.addEventListener('ended', function() {
    stopVisualizer();
    nextTrack();
  });
  audio.addEventListener('error', function() {
    if (!audio.src) return;
    isPlaying = false;
    playPauseBtn.textContent = '▶';
    cdEl.classList.add('paused');
    btn.classList.remove('playing');
    resetCdRotation();
    stopVisualizer();
    setStatus('音频不可用', 'error');
  });
  progressBar.addEventListener('input', function(event) {
    event.stopPropagation();
    if (audio.duration) audio.currentTime = (progressBar.value / 100) * audio.duration;
  });
  volumeSlider.addEventListener('input', function(event) {
    event.stopPropagation();
    audio.volume = clampVolume(volumeSlider.value);
    updateVolumeUI();
    saveState();
  });
  audio.addEventListener('volumechange', updateVolumeUI);

  document.addEventListener('click', function(event) {
    closeDropdowns();
    volPopover.classList.remove('open');
    if (!panel.classList.contains('hidden') && !panel.contains(event.target) && !btn.contains(event.target)) {
      panel.classList.add('hidden');
    }
  });
  panel.addEventListener('click', function(event) {
    if (!event.target.closest('.sekai-dropdown')) closeDropdowns();
    if (!event.target.closest('.sekai-vol-wrap')) volPopover.classList.remove('open');
    event.stopPropagation();
  });

  /* ===== Local & Online Import ===== */
  var localImportBtn = document.getElementById('sekaiLocalImport');
  var localFileInput = document.getElementById('sekaiLocalFileInput');
  var onlineImportBtn = document.getElementById('sekaiOnlineImport');
  var onlinePanel = document.getElementById('sekaiOnlinePanel');
  var onlineClose = document.getElementById('sekaiOnlineClose');
  var playlistUrlInput = document.getElementById('sekaiPlaylistUrl');
  var playlistFetchBtn = document.getElementById('sekaiPlaylistFetch');
  var onlineStatus = document.getElementById('sekaiOnlineStatus');
  var onlineTabs = document.querySelectorAll('.sekai-online-tab');
  var selectedPlatform = 'netease';

  // Local file import
  if (localImportBtn && localFileInput) {
    localImportBtn.addEventListener('click', function() { localFileInput.click(); });
    localFileInput.addEventListener('change', function() {
      if (!this.files || !this.files.length) return;
      var files = Array.from(this.files);
      files.forEach(function(file) {
        var url = URL.createObjectURL(file);
        var name = file.name.replace(/\.[^.]+$/, '');
        songs.push({
          id: 'local_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8),
          title: name,
          composer: '本地音乐',
          jacketBundle: null,
          source: 'local',
          tags: ['imported'],
          localUrl: url,
          vocals: [{ id: 'local', name: '原始音频', sourceUrl: url }]
        });
      });
      filteredSongs = songs.slice();
      renderPlaylist();
      statusEl.textContent = '已添加 ' + files.length + ' 首本地歌曲';
      this.value = '';
    });
  }

  // Online import panel toggle
  if (onlineImportBtn && onlinePanel) {
    onlineImportBtn.addEventListener('click', function() {
      onlinePanel.style.display = onlinePanel.style.display === 'none' ? 'block' : 'none';
    });
  }
  if (onlineClose && onlinePanel) {
    onlineClose.addEventListener('click', function() {
      onlinePanel.style.display = 'none';
    });
  }

  // Platform tab switch
  onlineTabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      onlineTabs.forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      selectedPlatform = tab.dataset.platform;
      playlistUrlInput.placeholder = selectedPlatform === 'netease'
        ? '粘贴网易云歌单链接或输入歌单ID'
        : '粘贴QQ音乐歌单链接或输入歌单ID';
    });
  });

  // Online playlist fetch
  if (playlistFetchBtn && playlistUrlInput) {
    playlistFetchBtn.addEventListener('click', function() {
      var raw = playlistUrlInput.value.trim();
      if (!raw) { onlineStatus.textContent = '请输入歌单链接或ID'; onlineStatus.className = 'sekai-online-status error'; return; }

      var playlistId = extractPlaylistId(raw, selectedPlatform);
      if (!playlistId) { onlineStatus.textContent = '无法识别歌单ID，请检查输入'; onlineStatus.className = 'sekai-online-status error'; return; }

      playlistFetchBtn.disabled = true;
      onlineStatus.textContent = '正在获取歌单...';
      onlineStatus.className = 'sekai-online-status';

      if (selectedPlatform === 'netease') {
        fetchNeteasePlaylist(playlistId, function(tracks, error) {
          playlistFetchBtn.disabled = false;
          if (error) { onlineStatus.textContent = error; onlineStatus.className = 'sekai-online-status error'; return; }
          addOnlineTracks(tracks, 'netease');
          onlineStatus.textContent = '已导入 ' + tracks.length + ' 首歌曲';
        });
      } else {
        fetchQQPlaylist(playlistId, function(tracks, error) {
          playlistFetchBtn.disabled = false;
          if (error) { onlineStatus.textContent = error; onlineStatus.className = 'sekai-online-status error'; return; }
          addOnlineTracks(tracks, 'qq');
          onlineStatus.textContent = '已导入 ' + tracks.length + ' 首歌曲';
        });
      }
    });
  }

  function extractPlaylistId(input, platform) {
    // Try to extract ID from URL
    var idMatch = input.match(/(?:id=|\/playlist\/|detail\?id=)(\d+)/);
    if (idMatch) return idMatch[1];
    // Pure number
    if (/^\d{5,}$/.test(input)) return input;
    return null;
  }

  function addOnlineTracks(tracks, platform) {
    tracks.forEach(function(track) {
      songs.push({
        id: platform + '_' + track.id,
        title: track.title,
        composer: track.artist || (platform === 'netease' ? '网易云音乐' : 'QQ音乐'),
        jacketBundle: track.cover ? { single: track.cover } : null,
        source: platform,
        tags: ['imported'],
        onlineId: track.id,
        sourceUrl: track.url || '',
        vocals: [{ id: platform + '_vocal', name: track.artist || '未知', sourceUrl: track.url || '' }]
      });
    });
    applyFilters();
  }

  function deleteSong(songId) {
    var idx = songs.findIndex(function(s) { return s.id === songId; });
    if (idx < 0) return;
    songs.splice(idx, 1);
    if (currentSong && currentSong.id === songId) {
      audio.pause();
      currentSong = null;
      currentVocal = null;
      isPlaying = false;
      updateNowPlaying();
    }
    applyFilters();
  }

  function clearImported() {
    songs = songs.filter(function(s) { return !s.source || s.source === 'sekai'; });
    if (currentSong && currentSong.source && currentSong.source !== 'sekai') {
      audio.pause();
      currentSong = null;
      currentVocal = null;
      isPlaying = false;
      updateNowPlaying();
    }
    applyFilters();
  }

  var clearImportedBtn = document.getElementById('sekaiClearImported');
  if (clearImportedBtn) {
    clearImportedBtn.addEventListener('click', function() {
      var count = songs.filter(function(s) { return s.source && s.source !== 'sekai'; }).length;
      if (!count) return;
      if (confirm('确定清空所有 ' + count + ' 首导入歌曲？')) {
        clearImported();
      }
    });
  }

  function fetchNeteasePlaylist(playlistId, callback) {
    var PROXY = 'https://music-proxy-3e4.pages.dev/api/';
    fetch(PROXY + 'netease-playlist?id=' + playlistId).then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    }).then(function(data) {
      if (!data.tracks || !data.tracks.length) { callback(null, '歌单为空或无法访问'); return; }
      var ids = data.tracks.map(function(t) { return t.id; }).join(',');
      return fetch(PROXY + 'netease-url?ids=' + ids).then(function(r) { return r.json(); }).then(function(urlData) {
        (urlData.urls || []).forEach(function(u) {
          var t = data.tracks.find(function(x) { return x.id === u.id; });
          if (t && u.url) t.url = u.url;
        });
        callback(data.tracks);
      }).catch(function() { callback(data.tracks); });
    }).catch(function(e) {
      callback(null, '请求失败: ' + e.message);
    });
  }

  function fetchQQPlaylist(playlistId, callback) {
    var PROXY = 'https://music-proxy-3e4.pages.dev/api/';
    fetch(PROXY + 'qq-playlist?id=' + playlistId).then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    }).then(function(data) {
      if (!data.tracks || !data.tracks.length) { callback(null, '歌单为空或无法访问'); return; }
      callback(data.tracks);
    }).catch(function(e) {
      callback(null, '请求失败: ' + e.message);
    });
  }

  renderPlaylist();
  updateMobileBg();
})();
</script>
