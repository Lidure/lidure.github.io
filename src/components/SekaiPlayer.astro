  justify-content: center;
  color: rgba(255,255,255,0.72);
  font-size: 1.7rem;
}
.sekai-cd.paused .sekai-cover,
.sekai-cd.paused .sekai-cover-fallback {
  border-radius: 22px;
  filter: saturate(.96);
}
