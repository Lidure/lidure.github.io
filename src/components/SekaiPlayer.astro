    8: '日野森雫',
    9: '小豆沢こはね',
    10: '白石杏',
    11: '東雲彰人',
    12: '青柳冬弥',
    13: '天馬司',
    14: '鳳えむ',
    15: '草薙寧々',
    16: '神代類',
    17: '宵崎奏',
    18: '朝比奈まふゆ',
    19: '東雲絵名',
    20: '暁山瑞希',
    21: '初音ミク',
    22: '鏡音リン',
    23: '鏡音レン',
    24: '巡音ルカ',
    25: 'MEIKO',
    26: 'KAITO'
  };
  var VOCAL_PRIORITY = {
    sekai: 0,
    original_song: 1,
    virtual_singer: 2,
    another_vocal: 3,
    instrumental: 4,
    streaming_live: 5,
    april_fool_2022: 6
  };

  var btn = document.getElementById('sekaiPlayerBtn');
  var panel = document.getElementById('sekaiPlayerPanel');
  var closeBtn = document.getElementById('sekaiPlayerCloseBtn');
  var audio = document.getElementById('sekaiAudio');
  audio.crossOrigin = 'anonymous';
  var playPauseBtn = document.getElementById('sekaiPlayPauseBtn');
  var prevBtn = document.getElementById('sekaiPrevBtn');
  var nextBtn = document.getElementById('sekaiNextBtn');
  var shortBtn = document.getElementById('sekaiShortBtn');
  var longBtn = document.getElementById('sekaiLongBtn');
  var sequenceBtn = document.getElementById('sekaiSequenceBtn');
  var shuffleBtn = document.getElementById('sekaiShuffleBtn');
  var vizOffBtn = document.getElementById('sekaiVizOffBtn');
  var vizCdBtn = document.getElementById('sekaiVizCdBtn');
  var vizDockBtn = document.getElementById('sekaiVizDockBtn');
  var vizPageBtn = document.getElementById('sekaiVizPageBtn');
  var progressBar = document.getElementById('sekaiProgressBar');
  var currentTimeEl = document.getElementById('sekaiCurrentTime');
  var totalTimeEl = document.getElementById('sekaiTotalTime');
  var volumeSlider = document.getElementById('sekaiVolumeSlider');
  var trackTitleEl = document.getElementById('sekaiTrackTitle');
  var trackArtistEl = document.getElementById('sekaiTrackArtist');
  var playlistEl = document.getElementById('sekaiPlaylist');
  var trackCountEl = document.getElementById('sekaiTrackCount');
  var cdEl = document.getElementById('sekaiCd');
  var coverImg = document.getElementById('sekaiCover');
  var coverFallback = document.getElementById('sekaiCoverFallback');
  var dockCover = document.getElementById('sekaiDockCover');
  var dockVisualizer = document.getElementById('sekaiDockVisualizer');
  var cdVisualizer = document.getElementById('sekaiCdVisualizer');
  var pageVisualizer = document.getElementById('sekaiPageVisualizer');
  var statusEl = document.getElementById('sekaiSourceStatus');
  var searchInput = document.getElementById('sekaiSearchInput');
  var tagDropdown = document.getElementById('sekaiTagDropdown');
  var tagButton = document.getElementById('sekaiTagButton');
  var tagLabel = document.getElementById('sekaiTagLabel');
  var tagMenu = document.getElementById('sekaiTagMenu');
  var vocalDropdown = document.getElementById('sekaiVocalDropdown');
  var vocalButton = document.getElementById('sekaiVocalButton');
  var vocalLabel = document.getElementById('sekaiVocalLabel');
  var vocalMenu = document.getElementById('sekaiVocalMenu');

  var catalogPromise = null;
  var songs = [];
  var filteredSongs = [];
  var currentSong = null;
  var currentVocal = null;
  var playbackMode = 'long';
  var playbackOrder = 'sequence';
  var visualizerTargets = { cd: false, dock: false, page: false };
  var isPlaying = false;
  var isRestoring = false;
  var restoredOnce = false;
  var audioContext = null;
  var analyser = null;
  var sourceNode = null;
  var frequencyData = null;
  var timeData = null;
  var visualizerFrame = 0;
  var visualizerLevels = {};
  var query = '';
  var tagFilter = 'all';
  var savedState = readState();

  if (savedState) {
    if (savedState.mode === 'long' || savedState.mode === 'short') playbackMode = savedState.mode;
    if (savedState.order === 'shuffle' || savedState.order === 'sequence') playbackOrder = savedState.order;
    if (savedState.visualizerTargets && typeof savedState.visualizerTargets === 'object') {
      visualizerTargets.cd = !!savedState.visualizerTargets.cd;
      visualizerTargets.dock = !!savedState.visualizerTargets.dock;
      visualizerTargets.page = !!savedState.visualizerTargets.page;
    } else if (savedState.visualizer === 'cd' || savedState.visualizer === 'dock' || savedState.visualizer === 'page') {
      visualizerTargets[savedState.visualizer] = true;
    }
    if (typeof savedState.volume === 'number') audio.volume = savedState.volume;
    else audio.volume = 0.5;
    query = savedState.query || '';
    tagFilter = savedState.tag || 'all';
  } else {
    audio.volume = 0.5;
  }
  volumeSlider.value = audio.volume;
  searchInput.value = query;
  updateModeButtons();
  updateOrderButtons();
  updateVisualizerButtons();
  applyVisualizerTargets();

  function fetchJson(name) {
    return fetch(MASTER_BASE + '/' + name, { cache: 'force-cache' }).then(function(response) {
      if (!response.ok) throw new Error(name + ' ' + response.status);
      return response.json();
    });
  }

  function ensureCatalog() {
    if (catalogPromise) return catalogPromise;
    setStatus('加载中', '');
    catalogPromise = Promise.all([
      fetchJson('musics.json'),
      fetchJson('musicVocals.json'),
      fetchJson('musicTags.json')
    ]).then(function(result) {
      songs = buildSongs(result[0], result[1], result[2]);
      populateTagFilter();
      applyFilters();
      updateCatalogStatus();
      if (!restoredOnce) restoreSelection(savedState);
      return songs;
    }).catch(function(error) {
      setStatus('加载失败', 'error');
      renderEmpty('无法加载歌曲数据');
      throw error;
    });
    return catalogPromise;
  }

  function buildSongs(musics, vocals, tags) {
    var now = Date.now();
    var vocalsByMusic = new Map();
    var tagsByMusic = new Map();

    vocals.forEach(function(vocal) {
      if (!vocal || !vocal.musicId || !vocal.assetbundleName) return;
      if (!vocalsByMusic.has(vocal.musicId)) vocalsByMusic.set(vocal.musicId, []);
      vocalsByMusic.get(vocal.musicId).push(vocal);
    });

    tags.forEach(function(tag) {
      if (!tag || !tag.musicId || !tag.musicTag) return;
      if (!tagsByMusic.has(tag.musicId)) tagsByMusic.set(tag.musicId, []);
      tagsByMusic.get(tag.musicId).push(tag.musicTag);
    });

    return musics
      .filter(function(music) {
        if (!music || !music.id || !music.title) return false;
        if (!vocalsByMusic.has(music.id)) return false;
        return !(typeof music.publishedAt === 'number' && music.publishedAt > now);
      })
      .map(function(music) {
        var songVocals = vocalsByMusic.get(music.id).slice().sort(sortVocals);
        var songTags = tagsByMusic.get(music.id) || ['all'];
        var haystack = [
          music.title,
          music.pronunciation,
          music.lyricist,
          music.composer,
          music.arranger,
          songVocals.map(function(vocal) { return getVocalLabel(vocal); }).join(' ')
        ].join(' ');

        return {
          id: music.id,
          seq: music.seq || music.id,
          title: music.title,
          pronunciation: music.pronunciation || '',
          lyricist: music.lyricist || '',
          composer: music.composer || '',
          arranger: music.arranger || '',
          jacketBundle: music.assetbundleName,
          tags: songTags,
          vocals: songVocals,
          searchText: normalize(haystack)
        };
      })
      .sort(function(a, b) {
        return a.seq - b.seq || a.id - b.id;
      });
  }

  function sortVocals(a, b) {
    var pa = VOCAL_PRIORITY[a.musicVocalType] == null ? 99 : VOCAL_PRIORITY[a.musicVocalType];
    var pb = VOCAL_PRIORITY[b.musicVocalType] == null ? 99 : VOCAL_PRIORITY[b.musicVocalType];
    return pa - pb || (a.seq || 0) - (b.seq || 0) || a.id - b.id;
  }

  function populateTagFilter() {
    tagMenu.innerHTML = '';
    TAG_ORDER.forEach(function(tag) {
      var item = document.createElement('button');
      item.type = 'button';
      item.className = 'sekai-dropdown-item' + (tag === tagFilter ? ' active' : '');
      item.setAttribute('role', 'option');
      item.setAttribute('aria-selected', tag === tagFilter ? 'true' : 'false');
      item.textContent = TAG_LABELS[tag] || tag;
      item.addEventListener('click', function(event) {
        event.stopPropagation();
        tagFilter = tag;
        updateTagDropdownLabel();
        closeDropdowns();
        applyFilters();
        populateTagFilter();
      });
      tagMenu.appendChild(item);
    });
    if (TAG_ORDER.indexOf(tagFilter) < 0) tagFilter = 'all';
    updateTagDropdownLabel();
  }

  function applyFilters() {
    var normalizedQuery = normalize(query);
    filteredSongs = songs.filter(function(song) {
      var matchesTag = tagFilter === 'all' || song.tags.indexOf(tagFilter) >= 0;
      var matchesQuery = !normalizedQuery || song.searchText.indexOf(normalizedQuery) >= 0;
      return matchesTag && matchesQuery;
    });
    renderPlaylist();
    saveState();
  }

  function renderPlaylist() {
    playlistEl.innerHTML = '';
    trackCountEl.textContent = String(filteredSongs.length);

    if (!songs.length && !catalogPromise) {
      renderEmpty('打开后加载歌曲');
      return;
    }
    if (!filteredSongs.length) {
      renderEmpty('没有匹配的歌曲');
      return;
    }

    filteredSongs.slice(0, MAX_RENDERED_TRACKS).forEach(function(song) {
      var isActive = currentSong && song.id === currentSong.id;
      var item = document.createElement('button');
      item.type = 'button';
      item.className = 'sekai-playlist-item' + (isActive ? ' active' : '');

      var icon = document.createElement('div');
      icon.className = 'sekai-pl-icon';

      if (song.jacketBundle) {
        var cover = document.createElement('img');
        cover.className = 'sekai-pl-cover-img';
        cover.src = getJacketUrl(song);
        cover.alt = '';
        cover.loading = 'lazy';
        cover.decoding = 'async';
        cover.onerror = function() {
          cover.classList.add('is-error');
        };
        icon.appendChild(cover);
      }

      var fallback = document.createElement('span');
      fallback.className = 'sekai-pl-fallback';
      fallback.textContent = '♪';
      icon.appendChild(fallback);

      if (isActive) {
        var playing = document.createElement('span');
        playing.className = 'sekai-pl-playing';
        playing.textContent = '▶';
        icon.appendChild(playing);
      }

      var info = document.createElement('div');
      info.className = 'sekai-pl-info';

      var title = document.createElement('div');
      title.className = 'sekai-pl-title';
      title.textContent = song.title;

      var sub = document.createElement('div');
      sub.className = 'sekai-pl-sub';
      sub.textContent = getSongSubtitle(song);

      info.appendChild(title);
      info.appendChild(sub);
      item.appendChild(icon);
      item.appendChild(info);
      item.addEventListener('click', function(event) {
        event.stopPropagation();
        selectSong(song, true);
      });
      playlistEl.appendChild(item);
    });

    if (filteredSongs.length > MAX_RENDERED_TRACKS) {
      var more = document.createElement('div');
      more.className = 'sekai-empty';
      more.textContent = '继续搜索可缩小结果';
      playlistEl.appendChild(more);
    }
  }

  function revealActiveTrack() {
    var activeItem = playlistEl.querySelector('.sekai-playlist-item.active');
    if (!activeItem) return;
    activeItem.scrollIntoView({ block: 'center', behavior: 'smooth' });
  }

  function renderEmpty(text) {
    playlistEl.innerHTML = '';
    var empty = document.createElement('div');
    empty.className = 'sekai-empty';
    empty.textContent = text;
    playlistEl.appendChild(empty);
  }

  function selectSong(song, autoPlay, preferredVocalId, startTime) {
    if (!song) return;
    currentSong = song;
    currentVocal = chooseVocal(song, preferredVocalId);
    renderVocalSelect();
    setAudioSource(!!autoPlay, startTime || 0);
    renderPlaylist();
    if (autoPlay) window.setTimeout(revealActiveTrack, 0);
  }

  function chooseVocal(song, preferredVocalId) {
    if (!song || !song.vocals.length) return null;
    if (preferredVocalId != null) {
      var preferred = song.vocals.find(function(vocal) { return String(vocal.id) === String(preferredVocalId); });
      if (preferred) return preferred;
    }
    return song.vocals[0];
  }

  function renderVocalSelect() {
    vocalMenu.innerHTML = '';
    if (!currentSong || !currentSong.vocals.length) {
      vocalLabel.textContent = 'Vocal';
      vocalButton.removeAttribute('title');
      vocalButton.disabled = true;
      closeDropdowns();
      return;
    }

    currentSong.vocals.forEach(function(vocal) {
      var item = document.createElement('button');
      item.type = 'button';
      item.className = 'sekai-dropdown-item' + (currentVocal && vocal.id === currentVocal.id ? ' active' : '');
      item.setAttribute('role', 'option');
      item.setAttribute('aria-selected', currentVocal && vocal.id === currentVocal.id ? 'true' : 'false');
      item.title = getVocalLabel(vocal);

      var labelWrap = document.createElement('span');
      labelWrap.className = 'sekai-vocal-option-text';

      var main = document.createElement('span');
      main.className = 'sekai-vocal-main';
      main.textContent = getVocalBaseLabel(vocal);

      var sub = document.createElement('span');
      sub.className = 'sekai-vocal-sub';
      sub.textContent = getVocalDetailLabel(vocal);

      labelWrap.appendChild(main);
      if (sub.textContent) labelWrap.appendChild(sub);
      item.appendChild(labelWrap);
      item.addEventListener('click', function(event) {
        event.stopPropagation();
        currentVocal = chooseVocal(currentSong, vocal.id);
        closeDropdowns();
        renderVocalSelect();
        setAudioSource(isPlaying, 0);
      });
      vocalMenu.appendChild(item);
    });
    var selectedVocalLabel = currentVocal ? getVocalLabel(currentVocal) : 'Vocal';
    vocalLabel.textContent = selectedVocalLabel;
    vocalButton.title = selectedVocalLabel;
    vocalButton.disabled = currentSong.vocals.length < 2;
    if (vocalButton.disabled) closeDropdowns();
  }

  function setAudioSource(autoPlay, startTime) {
    if (!currentSong || !currentVocal) return;
    isRestoring = true;
    audio.src = getAudioUrl(currentVocal);
    audio.load();
    resetProgress();
    updateNowPlaying();
    setStatus((playbackMode === 'long' ? 'FULL' : 'PREVIEW') + ' / 连接中', '');
    saveState();

    if (startTime) {
      audio.addEventListener('loadedmetadata', function onMeta() {
        audio.removeEventListener('loadedmetadata', onMeta);
        if (audio.duration && startTime < audio.duration) {
          audio.currentTime = startTime;
          currentTimeEl.textContent = fmt(startTime);
          progressBar.value = (startTime / audio.duration) * 100;
        }
        isRestoring = false;
      });
    } else {
      isRestoring = false;
    }

    if (autoPlay) play();
  }

  function updateNowPlaying() {
    trackTitleEl.textContent = currentSong ? currentSong.title : '选择一首歌曲';
    trackArtistEl.textContent = currentSong && currentVocal
      ? getVocalLabel(currentVocal) + ' / ' + (currentSong.composer || currentSong.lyricist || 'Project SEKAI')
      : 'Project SEKAI';

    if (currentSong && currentSong.jacketBundle) {
      coverImg.onload = function() {
        coverImg.style.display = 'block';
        coverFallback.style.display = 'none';
      };
      coverImg.onerror = function() {
        coverImg.style.display = 'none';
        coverFallback.style.display = 'flex';
      };
      coverImg.src = getJacketUrl(currentSong);
    } else {
      coverImg.style.display = 'none';
      coverFallback.style.display = 'flex';
    }
    updateDockCover(currentSong);
  }

  function updateDockCover(song) {
    if (!song || !song.jacketBundle) {
      btn.classList.remove('has-cover');
      dockCover.removeAttribute('src');
      return;
    }
    dockCover.onload = function() {
      btn.classList.add('has-cover');
    };
    dockCover.onerror = function() {
      btn.classList.remove('has-cover');
    };
    dockCover.src = getJacketUrl(song);
  }

  function getAudioUrl(vocal) {
    var bundle = vocal.assetbundleName;
    if (playbackMode === 'long') {
      return ASSET_BASE + '/music/long/' + bundle + '/' + bundle + '.mp3';
    }
    var shortFormat = audio.canPlayType('audio/flac') ? 'flac' : 'wav';
    return ASSET_BASE + '/music/short/' + bundle + '/' + bundle + '_short.' + shortFormat;
  }

  function getJacketUrl(song) {
    return ASSET_BASE + '/music/jacket/' + song.jacketBundle + '/' + song.jacketBundle + '.webp';
  }

  function getVocalBaseLabel(vocal) {
    return vocal.caption || VOCAL_LABELS[vocal.musicVocalType] || vocal.musicVocalType || 'Vocal';
  }

  function getCharacterName(character) {
    if (!character) return '';
    if (character.characterType === 'game_character') {
      return CHARACTER_NAMES[character.characterId] || ('角色#' + character.characterId);
    }
    return '外部角色#' + character.characterId;
  }

  function getVocalCharacterLabel(vocal) {
    if (!vocal || !Array.isArray(vocal.characters) || !vocal.characters.length) return '';
    return vocal.characters
      .slice()
      .sort(function(a, b) { return (a.seq || 0) - (b.seq || 0) || a.characterId - b.characterId; })
      .map(getCharacterName)
      .filter(Boolean)
      .join(' / ');
  }

  function getVocalDetailLabel(vocal) {
    var parts = [];
    var characters = getVocalCharacterLabel(vocal);
    if (characters) parts.push(characters);
    if (vocal && vocal.assetbundleName) parts.push(vocal.assetbundleName);
    return parts.join(' · ');
  }

  function getVocalLabel(vocal) {
    var base = getVocalBaseLabel(vocal);
    var detail = getVocalDetailLabel(vocal);
    return detail ? base + ' · ' + detail : base;
  }

  function getSongSubtitle(song) {
    var tag = song.tags
      .filter(function(name) { return name !== 'all'; })
      .map(function(name) { return TAG_LABELS[name] || name; })[0];
    var credit = song.composer || song.lyricist || 'Project SEKAI';
    return tag ? tag + ' / ' + credit : credit;
  }

  function play() {
    if (!songs.length) {
      ensureCatalog().then(function() {
        if (!currentSong) selectSong(filteredSongs[0] || songs[0], false);
        play();
      }).catch(function() {});
      return;
    }
    if (!currentSong) selectSong(filteredSongs[0] || songs[0], false);
    if (hasVisualizerTarget()) ensureVisualizer();
    resumeVisualizerAudio();
    audio.play().then(function() {
      isPlaying = true;
      playPauseBtn.textContent = '⏸';
      cdEl.classList.remove('paused');
      btn.classList.add('playing');
      startVisualizer();
      updateCatalogStatus();
      saveState();
    }).catch(function() {
      isPlaying = false;
      playPauseBtn.textContent = '▶';
      cdEl.classList.add('paused');
      btn.classList.remove('playing');
      setStatus('播放失败', 'error');
    });
  }

  function pause() {
    audio.pause();
    isPlaying = false;
    playPauseBtn.textContent = '▶';
    cdEl.classList.add('paused');
    btn.classList.remove('playing');
    stopVisualizer();
    saveState();
  }

  function togglePlay(event) {
    if (event) event.stopPropagation();
    isPlaying ? pause() : play();
  }

  function prevTrack(event) {
    if (event) event.stopPropagation();
    moveTrack(-1);
  }

  function nextTrack(event) {
    if (event) event.stopPropagation();
    moveTrack(1);
  }

  function moveTrack(step) {
    if (!songs.length) {
      ensureCatalog().then(function() { moveTrack(step); }).catch(function() {});
      return;
    }
    var list = filteredSongs.length ? filteredSongs : songs;
    if (!list.length) return;
    if (playbackOrder === 'shuffle') {
      selectSong(pickRandomSong(list), isPlaying);
      return;
    }
    var currentIndex = currentSong ? list.findIndex(function(song) { return song.id === currentSong.id; }) : -1;
    var nextIndex = currentIndex < 0 ? 0 : (currentIndex + step + list.length) % list.length;
    selectSong(list[nextIndex], isPlaying);
  }

  function pickRandomSong(list) {
    if (list.length < 2 || !currentSong) return list[0];
    var next = currentSong;
    var guard = 0;
    while (next && next.id === currentSong.id && guard < 12) {
      next = list[Math.floor(Math.random() * list.length)];
      guard++;
    }
    return next && next.id !== currentSong.id ? next : list[(list.findIndex(function(song) { return song.id === currentSong.id; }) + 1) % list.length];
  }

  function resetProgress() {
    currentTimeEl.textContent = '0:00';
    totalTimeEl.textContent = '0:00';
    progressBar.value = 0;
  }

  function fmt(seconds) {
    if (!seconds || isNaN(seconds)) return '0:00';
    var minutes = Math.floor(seconds / 60);
    var rest = Math.floor(seconds % 60);
    return minutes + ':' + (rest < 10 ? '0' + rest : rest);
  }

  function normalize(value) {
    return String(value || '').normalize('NFKC').toLowerCase();
  }

  function updateTagDropdownLabel() {
    tagLabel.textContent = TAG_LABELS[tagFilter] || '全部';
  }

  function setDropdownOpen(dropdown, open) {
    var button = dropdown === vocalDropdown ? vocalButton : tagButton;
    dropdown.classList.toggle('open', open);
    button.setAttribute('aria-expanded', open ? 'true' : 'false');
  }

  function closeDropdowns(except) {
    if (except !== vocalDropdown) setDropdownOpen(vocalDropdown, false);
    if (except !== tagDropdown) setDropdownOpen(tagDropdown, false);
  }

  function toggleDropdown(dropdown) {
    var button = dropdown === vocalDropdown ? vocalButton : tagButton;
    if (button.disabled) return;
    var willOpen = !dropdown.classList.contains('open');
    closeDropdowns(dropdown);
    setDropdownOpen(dropdown, willOpen);
  }

  function setStatus(text, state) {
    statusEl.textContent = text;
    if (state) statusEl.dataset.state = state;
    else statusEl.removeAttribute('data-state');
  }

  function updateCatalogStatus() {
    if (!songs.length) return;
    setStatus(
      (playbackMode === 'long' ? 'FULL' : 'PREVIEW') +
      ' / ' +
      (playbackOrder === 'shuffle' ? '随机' : '顺序') +
      ' / ' +
      songs.length +
      ' 首',
      ''
    );
  }

  function updateModeButtons() {
    shortBtn.classList.toggle('active', playbackMode === 'short');
    longBtn.classList.toggle('active', playbackMode === 'long');
  }

  function updateOrderButtons() {
    sequenceBtn.classList.toggle('active', playbackOrder === 'sequence');
    shuffleBtn.classList.toggle('active', playbackOrder === 'shuffle');
  }

  function hasVisualizerTarget() {
    return !!(visualizerTargets.cd || visualizerTargets.dock || visualizerTargets.page);
  }

  function getVisualizerStateName() {
    if (!hasVisualizerTarget()) return 'off';
    var selected = [];
    if (visualizerTargets.cd) selected.push('cd');
    if (visualizerTargets.dock) selected.push('dock');
    if (visualizerTargets.page) selected.push('page');
    return selected.length === 1 ? selected[0] : 'multi';
  }

  function updateVisualizerButtons() {
    var hasTarget = hasVisualizerTarget();
    vizOffBtn.classList.toggle('active', !hasTarget);
    vizCdBtn.classList.toggle('active', visualizerTargets.cd);
    vizDockBtn.classList.toggle('active', visualizerTargets.dock);
    vizPageBtn.classList.toggle('active', visualizerTargets.page);
    vizOffBtn.setAttribute('aria-pressed', !hasTarget ? 'true' : 'false');
    vizCdBtn.setAttribute('aria-pressed', visualizerTargets.cd ? 'true' : 'false');
    vizDockBtn.setAttribute('aria-pressed', visualizerTargets.dock ? 'true' : 'false');
    vizPageBtn.setAttribute('aria-pressed', visualizerTargets.page ? 'true' : 'false');
  }

  function setMode(mode) {
    if (mode !== 'short' && mode !== 'long') return;
    if (playbackMode === mode) return;
    playbackMode = mode;
    updateModeButtons();
    if (currentSong) setAudioSource(isPlaying, 0);
    updateCatalogStatus();
    saveState();
  }

  function setOrder(order) {
    if (order !== 'sequence' && order !== 'shuffle') return;
    playbackOrder = order;
    updateOrderButtons();
    updateCatalogStatus();
    saveState();
  }

  function setVisualizerTarget(target, enabled) {
    if (target !== 'cd' && target !== 'dock' && target !== 'page') return;
    visualizerTargets[target] = typeof enabled === 'boolean' ? enabled : !visualizerTargets[target];
    updateVisualizerButtons();
    applyVisualizerTargets();
    if (hasVisualizerTarget() && isPlaying) {
      if (!ensureVisualizer()) {
        saveState();
        return;
      }
      startVisualizer();
    }
    saveState();
  }

  function clearVisualizerTargets() {
    visualizerTargets.cd = false;
    visualizerTargets.dock = false;
    visualizerTargets.page = false;
    updateVisualizerButtons();
    applyVisualizerTargets();
    saveState();
  }

  function applyVisualizerTargets() {
    cdEl.classList.toggle('viz-cd', visualizerTargets.cd);
    btn.classList.toggle('viz-dock', visualizerTargets.dock);
    pageVisualizer.classList.toggle('active', visualizerTargets.page);
    if (!visualizerTargets.cd) clearCanvas(cdVisualizer);
    if (!visualizerTargets.dock) clearCanvas(dockVisualizer);
    if (!visualizerTargets.page) clearCanvas(pageVisualizer);
    if (!hasVisualizerTarget()) stopVisualizer();
  }

  function ensureVisualizer() {
    if (analyser) return true;
    try {
      var AudioContextCtor = window.AudioContext || window['webkitAudioContext'];
      if (!AudioContextCtor) return false;
      audioContext = new AudioContextCtor();
      analyser = audioContext.createAnalyser();
      analyser.fftSize = 256;
      analyser.smoothingTimeConstant = 0.86;
      sourceNode = audioContext.createMediaElementSource(audio);
      sourceNode.connect(analyser);
      analyser.connect(audioContext.destination);
      frequencyData = new Uint8Array(analyser.frequencyBinCount);
      timeData = new Uint8Array(analyser.fftSize);
      return true;
    } catch (error) {
      analyser = null;
      timeData = null;
      visualizerTargets.cd = false;
      visualizerTargets.dock = false;
      visualizerTargets.page = false;
      updateVisualizerButtons();
      applyVisualizerTargets();
      setStatus('可视化不可用', 'error');
      return false;
    }
  }

  function resumeVisualizerAudio() {
    if (audioContext && audioContext.state === 'suspended') {
      audioContext.resume().catch(function() {});
    }
  }

  function startVisualizer() {
    if (!hasVisualizerTarget() || !analyser || visualizerFrame) return;
    drawVisualizer();
  }

  function stopVisualizer() {
    if (visualizerFrame) {
      cancelAnimationFrame(visualizerFrame);
      visualizerFrame = 0;
    }
    clearCanvas(cdVisualizer);
    clearCanvas(dockVisualizer);
    clearCanvas(pageVisualizer);
  }

  function drawVisualizer() {
    if (!hasVisualizerTarget() || !analyser || !frequencyData) {
      stopVisualizer();
      return;
    }
    visualizerFrame = requestAnimationFrame(drawVisualizer);
    analyser.getByteFrequencyData(frequencyData);
    if (timeData) analyser.getByteTimeDomainData(timeData);
    if (visualizerTargets.cd) drawCdVisualizer(cdVisualizer);
    else clearCanvas(cdVisualizer);
    if (visualizerTargets.dock) drawDockVisualizer(dockVisualizer);
    else clearCanvas(dockVisualizer);
    if (visualizerTargets.page) drawPageVisualizer(pageVisualizer);
    else clearCanvas(pageVisualizer);
  }

  function prepareCanvas(canvas) {
    if (!canvas) return null;
    var rect = canvas.getBoundingClientRect();
    var dpr = window.devicePixelRatio || 1;
    var width = Math.max(1, Math.floor(rect.width * dpr));
    var height = Math.max(1, Math.floor(rect.height * dpr));
    if (canvas.width !== width || canvas.height !== height) {
      canvas.width = width;
      canvas.height = height;
    }
    var ctx = canvas.getContext('2d');
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.clearRect(0, 0, width, height);
    return { ctx: ctx, width: width, height: height, dpr: dpr };
  }

  function clearCanvas(canvas) {
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (ctx) ctx.clearRect(0, 0, canvas.width || 0, canvas.height || 0);
  }

  function getBandAverage(startRatio, endRatio) {
    if (!frequencyData || !frequencyData.length) return 0;
    var start = Math.max(0, Math.floor(startRatio * frequencyData.length));
    var end = Math.min(frequencyData.length - 1, Math.ceil(endRatio * frequencyData.length));
    var total = 0;
    var count = 0;
    for (var i = start; i <= end; i++) {
      total += frequencyData[i];
      count++;
    }
    return count ? total / count / 255 : 0;
  }

  function sampleFrequency(position, curve) {
    if (!frequencyData || !frequencyData.length) return 0;
    var normalized = Math.max(0, Math.min(1, position));
    var shaped = Math.pow(normalized, curve || 1.32);
    var index = Math.min(frequencyData.length - 1, Math.floor(shaped * (frequencyData.length - 1)));
    return frequencyData[index] / 255;
  }

  function sampleWave(position) {
    if (!timeData || !timeData.length) return 0;
    var normalized = Math.max(0, Math.min(1, position));
    var index = Math.min(timeData.length - 1, Math.floor(normalized * (timeData.length - 1)));
    return (timeData[index] - 128) / 128;
  }

  function smoothLevel(name, value, hold) {
    var previous = visualizerLevels[name] || 0;
    var next = previous * hold + value * (1 - hold);
    visualizerLevels[name] = next;
    return next;
  }

  function drawCdVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var cx = width / 2;
    var cy = height / 2;
    var size = Math.min(width, height);
    var time = performance.now() * 0.001;
    var bass = smoothLevel('cdBass', getBandAverage(0, 0.12), 0.78);
    var mid = smoothLevel('cdMid', getBandAverage(0.12, 0.48), 0.82);
    var high = smoothLevel('cdHigh', getBandAverage(0.48, 1), 0.86);
    var halo = ctx.createRadialGradient(cx, cy, size * 0.18, cx, cy, size * 0.52);
    halo.addColorStop(0, 'rgba(255,255,255,0)');
    halo.addColorStop(0.45, 'rgba(30,216,255,' + (0.06 + bass * 0.16) + ')');
    halo.addColorStop(0.76, 'rgba(255,93,168,' + (0.08 + mid * 0.16) + ')');
    halo.addColorStop(1, 'rgba(255,228,94,0)');

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';
    ctx.fillStyle = halo;
    ctx.beginPath();
    ctx.arc(cx, cy, size * 0.52, 0, Math.PI * 2);
    ctx.fill();

    ctx.lineCap = 'round';
    var bars = 72;
    var base = size * (0.415 + bass * 0.01);
    for (var i = 0; i < bars; i++) {
      var position = i / bars;
      var value = sampleFrequency(position, 1.18);
      var blended = Math.min(1, value * 0.72 + bass * 0.18 + high * 0.1);
      var angle = Math.PI * 2 * position - Math.PI / 2;
      var wobble = Math.sin(time * 2.4 + i * 0.38) * size * 0.006;
      var inner = base + wobble;
      var outer = inner + size * (0.018 + blended * 0.075);
      var hue = (185 + i * 4.2 + time * 26 + blended * 70) % 360;
      ctx.beginPath();
      ctx.moveTo(cx + Math.cos(angle) * inner, cy + Math.sin(angle) * inner);
      ctx.lineTo(cx + Math.cos(angle) * outer, cy + Math.sin(angle) * outer);
      ctx.strokeStyle = 'hsla(' + hue + ', 96%, 68%, ' + (0.28 + blended * 0.68) + ')';
      ctx.lineWidth = Math.max(2, size * (0.007 + blended * 0.009));
      ctx.shadowBlur = size * (0.035 + blended * 0.05);
      ctx.shadowColor = 'hsla(' + hue + ', 96%, 68%, 0.72)';
      ctx.stroke();
    }

    for (var layer = 0; layer < 3; layer++) {
      var radius = size * (0.405 + layer * 0.036 + bass * 0.012);
      var pieces = 10 + layer * 3;
      ctx.lineWidth = Math.max(1.5, size * (0.007 + layer * 0.002));
      ctx.shadowBlur = size * 0.035;
      for (var piece = 0; piece < pieces; piece++) {
        var arcValue = sampleFrequency((piece + layer * 0.37) / pieces, 1.08);
        var start = time * (0.42 + layer * 0.18) + piece * Math.PI * 2 / pieces + layer * 0.36;
        var sweep = Math.PI * (0.07 + arcValue * 0.13 + high * 0.05);
        var colorHue = (195 + layer * 42 + piece * 17 + time * 18) % 360;
        ctx.beginPath();
        ctx.arc(cx, cy, radius, start, start + sweep);
        ctx.strokeStyle = 'hsla(' + colorHue + ', 94%, 70%, ' + (0.18 + arcValue * 0.32 + mid * 0.18) + ')';
        ctx.shadowColor = 'hsla(' + colorHue + ', 94%, 70%, 0.58)';
        ctx.stroke();
      }
    }
    ctx.restore();
  }

  function drawDockVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var cx = width / 2;
    var cy = height / 2;
    var size = Math.min(width, height);
    var time = performance.now() * 0.001;
    var bass = smoothLevel('dockBass', getBandAverage(0, 0.18), 0.74);
    var mid = smoothLevel('dockMid', getBandAverage(0.18, 0.62), 0.82);
    var bars = 32;

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';
    ctx.lineCap = 'round';
    ctx.shadowBlur = size * (0.06 + bass * 0.1);
    for (var i = 0; i < bars; i++) {
      var position = i / bars;
      var value = sampleFrequency(position, 1.14);
      var angle = Math.PI * 2 * position - Math.PI / 2 + time * 0.16;
      var blended = Math.min(1, value * 0.76 + bass * 0.18 + mid * 0.08);
      var inner = size * (0.37 + bass * 0.008);
      var outer = size * (0.435 + blended * 0.075);
      var hue = (190 + i * 6.6 + time * 32 + blended * 45) % 360;
      ctx.beginPath();
      ctx.moveTo(cx + Math.cos(angle) * inner, cy + Math.sin(angle) * inner);
      ctx.lineTo(cx + Math.cos(angle) * outer, cy + Math.sin(angle) * outer);
      ctx.strokeStyle = 'hsla(' + hue + ', 96%, 70%, ' + (0.32 + blended * 0.62) + ')';
      ctx.lineWidth = Math.max(1.4, size * (0.013 + blended * 0.009));
      ctx.shadowColor = 'hsla(' + hue + ', 96%, 70%, 0.72)';
      ctx.stroke();
    }

    ctx.shadowBlur = size * 0.1;
    ctx.lineWidth = Math.max(1.2, size * 0.022);
    for (var arc = 0; arc < 3; arc++) {
      var start = time * (0.8 + arc * 0.24) + arc * Math.PI * 0.72;
      ctx.beginPath();
      ctx.arc(cx, cy, size * (0.405 + arc * 0.035), start, start + Math.PI * (0.28 + bass * 0.2));
      ctx.strokeStyle = arc === 0
        ? 'rgba(30,216,255,' + (0.24 + bass * 0.38) + ')'
        : arc === 1
          ? 'rgba(255,93,168,' + (0.22 + mid * 0.34) + ')'
          : 'rgba(255,228,94,' + (0.18 + bass * 0.28) + ')';
      ctx.stroke();
    }
    ctx.restore();
  }

  function drawPageVisualizer(canvas) {
    var prepared = prepareCanvas(canvas);
    if (!prepared) return;
    var ctx = prepared.ctx;
    var width = prepared.width;
    var height = prepared.height;
    var time = performance.now() * 0.001;
    var bass = smoothLevel('pageBass', getBandAverage(0, 0.12), 0.84);
    var mid = smoothLevel('pageMid', getBandAverage(0.12, 0.52), 0.88);
    var high = smoothLevel('pageHigh', getBandAverage(0.52, 1), 0.9);
    var samples = 128;

    ctx.save();
    ctx.globalCompositeOperation = 'lighter';

    var curtain = ctx.createLinearGradient(0, height * 0.34, 0, height);
    curtain.addColorStop(0, 'rgba(30,216,255,0)');
    curtain.addColorStop(0.55, 'rgba(255,93,168,' + (0.035 + mid * 0.08) + ')');
    curtain.addColorStop(1, 'rgba(30,216,255,' + (0.06 + bass * 0.13) + ')');
    ctx.fillStyle = curtain;
    ctx.fillRect(0, height * 0.34, width, height * 0.66);

    var floorGradient = ctx.createLinearGradient(0, height * 0.62, width, height);
    floorGradient.addColorStop(0, 'rgba(30,216,255,' + (0.12 + bass * 0.18) + ')');
    floorGradient.addColorStop(0.48, 'rgba(255,93,168,' + (0.1 + mid * 0.15) + ')');
    floorGradient.addColorStop(1, 'rgba(255,228,94,' + (0.08 + high * 0.12) + ')');
    ctx.beginPath();
    ctx.moveTo(0, height);
    for (var i = 0; i <= samples; i++) {
      var p = i / samples;
      var value = sampleFrequency(p, 1.22);
      var y = height * (0.9 - bass * 0.05) - value * height * 0.2 - Math.sin(p * Math.PI * 2 + time * 1.5) * height * 0.012;
      ctx.lineTo(p * width, y);
    }
    ctx.lineTo(width, height);
    ctx.closePath();
    ctx.fillStyle = floorGradient;
    ctx.globalAlpha = 0.44;
    ctx.fill();
    ctx.globalAlpha = 1;

    var ribbons = [
      { base: 0.28, speed: 0.75, width: 2.4, hue: 188, amp: 0.08 },
      { base: 0.47, speed: -0.58, width: 3.3, hue: 326, amp: 0.1 },
      { base: 0.66, speed: 0.42, width: 2.8, hue: 52, amp: 0.075 },
      { base: 0.78, speed: -0.36, width: 1.8, hue: 162, amp: 0.055 }
    ];

    ribbons.forEach(function(ribbon, ribbonIndex) {
      var gradient = ctx.createLinearGradient(0, 0, width, 0);
      gradient.addColorStop(0, 'hsla(' + ribbon.hue + ', 96%, 70%, 0)');
      gradient.addColorStop(0.18, 'hsla(' + ribbon.hue + ', 96%, 70%, 0.32)');
      gradient.addColorStop(0.52, 'hsla(' + ((ribbon.hue + 72) % 360) + ', 96%, 72%, 0.44)');
      gradient.addColorStop(0.84, 'hsla(' + ((ribbon.hue + 136) % 360) + ', 96%, 68%, 0.26)');
      gradient.addColorStop(1, 'hsla(' + ribbon.hue + ', 96%, 70%, 0)');

      ctx.beginPath();
      for (var point = 0; point <= samples; point++) {
        var xRatio = point / samples;
        var freq = sampleFrequency((xRatio + ribbonIndex * 0.08) % 1, 1.1);
        var wave = sampleWave((xRatio + time * 0.02 + ribbonIndex * 0.11) % 1);
        var yOffset =
          Math.sin(xRatio * Math.PI * (2.8 + ribbonIndex * 0.7) + time * ribbon.speed) * height * 0.026 +
          wave * height * (0.016 + ribbonIndex * 0.003) -
          freq * height * ribbon.amp +
          bass * height * 0.022 * Math.sin(xRatio * Math.PI * 2 + ribbonIndex);
        var x = xRatio * width;
        var y = height * ribbon.base + yOffset;
        if (point === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.strokeStyle = gradient;
      ctx.lineWidth = Math.max(1, prepared.dpr * (ribbon.width + bass * 2.8));
      ctx.shadowColor = 'hsla(' + ribbon.hue + ', 96%, 70%, 0.58)';
      ctx.shadowBlur = prepared.dpr * (8 + mid * 18);
      ctx.stroke();
    });
    ctx.restore();
  }

  function readState() {
    try {
      var raw = sessionStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch (error) {
      return null;
    }
  }

  function saveState() {
    if (isRestoring) return;
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        musicId: currentSong ? currentSong.id : null,
        vocalId: currentVocal ? currentVocal.id : null,
        mode: playbackMode,
        order: playbackOrder,
        visualizer: getVisualizerStateName(),
        visualizerTargets: {
          cd: visualizerTargets.cd,
          dock: visualizerTargets.dock,
          page: visualizerTargets.page
        },
        time: audio.currentTime || 0,
        playing: isPlaying ? 1 : 0,
        volume: audio.volume,
        query: query,
        tag: tagFilter
      }));
    } catch (error) {}
  }

  function restoreSelection(state) {
    restoredOnce = true;
    if (!state) return;
    if (state.tag) {
      tagFilter = state.tag;
      if (TAG_ORDER.indexOf(tagFilter) < 0) tagFilter = 'all';
      updateTagDropdownLabel();
      populateTagFilter();
    }
    if (state.query) {
      query = state.query;
      searchInput.value = query;
    }
    applyFilters();
    if (!state.musicId) return;
    var song = songs.find(function(item) { return String(item.id) === String(state.musicId); });
    if (!song) return;
    selectSong(song, false, state.vocalId, state.time || 0);
  }

  btn.addEventListener('click', function(event) {
    event.stopPropagation();
    panel.classList.toggle('hidden');
    if (!panel.classList.contains('hidden')) ensureCatalog().catch(function() {});
  });
  closeBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    panel.classList.add('hidden');
  });
  playPauseBtn.addEventListener('click', togglePlay);
  prevBtn.addEventListener('click', prevTrack);
  nextBtn.addEventListener('click', nextTrack);
  vocalButton.addEventListener('click', function(event) {
    event.stopPropagation();
    toggleDropdown(vocalDropdown);
  });
  tagButton.addEventListener('click', function(event) {
    event.stopPropagation();
    toggleDropdown(tagDropdown);
  });
  shortBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setMode('short');
  });
  longBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setMode('long');
  });
  sequenceBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('sequence');
  });
  shuffleBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setOrder('shuffle');
  });
  vizOffBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    clearVisualizerTargets();
  });
  vizCdBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('cd');
  });
  vizDockBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('dock');
  });
  vizPageBtn.addEventListener('click', function(event) {
    event.stopPropagation();
    setVisualizerTarget('page');
  });

  searchInput.addEventListener('input', function(event) {
    query = event.target.value || '';
    applyFilters();
  });
  audio.addEventListener('timeupdate', function() {
    if (audio.duration) {
      progressBar.value = (audio.currentTime / audio.duration) * 100;
      currentTimeEl.textContent = fmt(audio.currentTime);
    }
  });
  audio.addEventListener('loadedmetadata', function() {
    totalTimeEl.textContent = fmt(audio.duration);
    updateCatalogStatus();
  });
  audio.addEventListener('canplay', function() {
    updateCatalogStatus();
  });
  audio.addEventListener('waiting', function() {
    if (audio.src) setStatus((playbackMode === 'long' ? 'FULL' : 'PREVIEW') + ' / 缓冲中', '');
  });
  audio.addEventListener('ended', function() {
    stopVisualizer();
    nextTrack();
  });
  audio.addEventListener('error', function() {
    if (!audio.src) return;
    isPlaying = false;
    playPauseBtn.textContent = '▶';
    cdEl.classList.add('paused');
    btn.classList.remove('playing');
    stopVisualizer();
    setStatus('音频不可用', 'error');
  });
  progressBar.addEventListener('input', function(event) {
    event.stopPropagation();
    if (audio.duration) audio.currentTime = (progressBar.value / 100) * audio.duration;
  });
  volumeSlider.addEventListener('input', function(event) {
    event.stopPropagation();
    audio.volume = Number(volumeSlider.value);
    saveState();
  });

  document.addEventListener('click', function(event) {
    closeDropdowns();
    if (!panel.classList.contains('hidden') && !panel.contains(event.target) && !btn.contains(event.target)) {
      panel.classList.add('hidden');
    }
  });
  panel.addEventListener('click', function(event) {
    if (!event.target.closest('.sekai-dropdown')) closeDropdowns();
    event.stopPropagation();
  });

  renderPlaylist();
})();
</script>
