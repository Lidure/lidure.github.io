---
/** SEKAI player */
---

<button id="sekaiPlayerBtn" class="sekai-player-btn" title="SEKAI 播放器" aria-label="打开 SEKAI 播放器">
  <img id="sekaiDockCover" class="sekai-dock-cover" src="" alt="" aria-hidden="true" />
  <canvas id="sekaiDockVisualizer" class="sekai-dock-visualizer" aria-hidden="true"></canvas>
  <span id="sekaiDockIcon" class="sekai-dock-icon">♪</span>
</button>

<div id="sekaiPlayerPanel" class="sekai-player-panel hidden" role="dialog" aria-label="SEKAI 播放器">
  <div class="sekai-player-header">
    <div class="sekai-heading">
      <span class="sekai-player-title">PJSK CD</span>
      <span id="sekaiSourceStatus" class="sekai-status">未加载</span>
    </div>
    <button id="sekaiPlayerCloseBtn" class="sekai-player-close" title="关闭" aria-label="关闭">×</button>
  </div>

  <div class="sekai-player-body">
    <div class="sekai-top-section">
      <div class="sekai-cover-wrap">
        <div class="sekai-cd paused" id="sekaiCd">
          <canvas id="sekaiCdVisualizer" class="sekai-cd-visualizer" aria-hidden="true"></canvas>
          <img class="sekai-cover" id="sekaiCover" src="" alt="封面" style="display:none;" />
          <div class="sekai-cover-fallback" id="sekaiCoverFallback">♪</div>
        </div>
      </div>

      <div class="sekai-now-playing">
        <div class="sekai-track-title" id="sekaiTrackTitle">选择一首歌曲</div>
        <div class="sekai-track-artist" id="sekaiTrackArtist">Project SEKAI</div>
        <div class="sekai-progress">
          <span id="sekaiCurrentTime">0:00</span>
          <input type="range" id="sekaiProgressBar" min="0" max="100" value="0" step="0.1" aria-label="播放进度" />
          <span id="sekaiTotalTime">0:00</span>
        </div>
        <div class="sekai-controls">
          <button id="sekaiPrevBtn" class="sekai-ctrl-btn" title="上一首" aria-label="上一首">‹</button>
          <button id="sekaiPlayPauseBtn" class="sekai-ctrl-btn sekai-play-btn" title="播放/暂停" aria-label="播放/暂停">▶</button>
          <button id="sekaiNextBtn" class="sekai-ctrl-btn" title="下一首" aria-label="下一首">›</button>
        </div>
      </div>
    </div>

    <div class="sekai-options">
      <div class="sekai-dropdown" id="sekaiVocalDropdown">
        <button id="sekaiVocalButton" class="sekai-dropdown-btn" type="button" aria-haspopup="listbox" aria-expanded="false" disabled>
          <span class="sekai-dropdown-kicker">VOCAL</span>
          <span id="sekaiVocalLabel" class="sekai-dropdown-value">Vocal</span>
        </button>
        <div id="sekaiVocalMenu" class="sekai-dropdown-menu" role="listbox"></div>
      </div>
    </div>

    <div class="sekai-playback-options">
      <div class="sekai-mode-toggle" aria-label="音频版本">
        <button id="sekaiLongBtn" class="sekai-mode-btn active" type="button">完整</button>
        <button id="sekaiShortBtn" class="sekai-mode-btn" type="button">片段</button>
      </div>
      <div class="sekai-order-toggle" aria-label="播放顺序">
        <button id="sekaiSequenceBtn" class="sekai-order-btn active" type="button">顺序</button>
        <button id="sekaiShuffleBtn" class="sekai-order-btn" type="button">随机</button>
      </div>
    </div>

    <div class="sekai-visualizer-options">
      <span class="sekai-control-label">可视化</span>
      <div class="sekai-visualizer-toggle" aria-label="音频可视化">
        <button id="sekaiVizOffBtn" class="sekai-viz-btn active" type="button" aria-pressed="true">关闭</button>
        <button id="sekaiVizCdBtn" class="sekai-viz-btn" type="button" aria-pressed="false">CD环</button>
        <button id="sekaiVizDockBtn" class="sekai-viz-btn" type="button" aria-pressed="false">悬浮</button>
        <button id="sekaiVizPageBtn" class="sekai-viz-btn" type="button" aria-pressed="false">背景</button>
      </div>
    </div>

    <div class="sekai-volume">
      <span aria-hidden="true">VOL</span>
      <input type="range" id="sekaiVolumeSlider" min="0" max="1" step="0.01" value="0.5" aria-label="音量" />
    </div>

    <div class="sekai-library-controls">
      <input id="sekaiSearchInput" class="sekai-search" type="search" placeholder="搜索曲名 / 作曲 / 版本" autocomplete="off" />
      <div class="sekai-dropdown sekai-tag-dropdown" id="sekaiTagDropdown">
        <button id="sekaiTagButton" class="sekai-dropdown-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
          <span class="sekai-dropdown-kicker">UNIT</span>
          <span id="sekaiTagLabel" class="sekai-dropdown-value">全部</span>
        </button>
        <div id="sekaiTagMenu" class="sekai-dropdown-menu" role="listbox"></div>
      </div>
    </div>

    <div class="sekai-playlist-label">
      <span>播放列表</span>
      <span id="sekaiTrackCount">0</span>
    </div>
    <div class="sekai-playlist" id="sekaiPlaylist"></div>
  </div>
</div>

<audio id="sekaiAudio" preload="metadata"></audio>
<canvas id="sekaiPageVisualizer" class="sekai-page-visualizer" aria-hidden="true"></canvas>

<style>
.sekai-player-btn {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78px;
  height: 78px;
  overflow: visible;
  border: 1px solid rgba(255,255,255,0.54);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, rgba(255,255,255,0.95) 0 18%, transparent 19%),
    conic-gradient(from 210deg,#1ed8ff,#7c5cff,#ff5da8,#ffe45e,#46e6ad,#1ed8ff);
  color: #fff;
  box-shadow: 0 12px 32px rgba(30,216,255,0.28), 0 4px 16px rgba(255,93,168,0.22);
  cursor: pointer;
  font-size: 1.75rem;
  text-shadow: 0 1px 8px rgba(0,0,0,0.45);
  transition: transform .2s, box-shadow .2s;
  user-select: none;
}
.sekai-player-btn::after {
  content: none;
}
.sekai-player-btn.has-cover::after {
  opacity: 0;
}
.sekai-dock-cover {
  position: absolute;
  inset: 0;
  z-index: 1;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  opacity: 0;
  transform: rotate(0deg);
  transition: opacity .2s;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.42), 0 14px 34px rgba(0,0,0,0.34);
}
.sekai-player-btn.has-cover .sekai-dock-cover {
  opacity: 1;
}
.sekai-player-btn.playing .sekai-dock-cover {
  animation: sekaiCdSpin 7.5s linear infinite;
}
.sekai-dock-visualizer {
  position: absolute;
  inset: -15px;
  z-index: 0;
  width: calc(100% + 30px);
  height: calc(100% + 30px);
  border-radius: 50%;
  opacity: 0;
  mix-blend-mode: screen;
  pointer-events: none;
  transition: opacity .2s;
}
.sekai-player-btn.viz-dock .sekai-dock-visualizer {
  opacity: .95;
}
.sekai-dock-icon {
  position: relative;
  z-index: 2;
}
.sekai-player-btn.has-cover .sekai-dock-icon {
  opacity: 0;
}
.sekai-player-btn:hover {
  transform: translateY(-2px) scale(1.04);
  box-shadow: 0 16px 38px rgba(30,216,255,0.34), 0 8px 24px rgba(255,93,168,0.28);
}
.sekai-player-btn.playing {
  animation: sekaiPulse 1.6s ease-in-out infinite;
}
@keyframes sekaiPulse {
  0%,100% { box-shadow: 0 12px 32px rgba(30,216,255,0.28), 0 4px 16px rgba(255,93,168,0.22); }
  50% { box-shadow: 0 14px 44px rgba(30,216,255,0.46), 0 8px 30px rgba(255,93,168,0.38); }
}

.sekai-player-panel {
  position: fixed;
  right: 24px;
  bottom: 120px;
  z-index: 10000;
  display: flex;
  flex-direction: column;
  width: 420px;
  max-width: calc(100vw - 32px);
  max-height: min(840px, calc(100vh - 112px));
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 10px;
  background:
    linear-gradient(135deg,rgba(30,216,255,0.13),transparent 30%),
    linear-gradient(315deg,rgba(255,93,168,0.13),transparent 32%),
    linear-gradient(180deg,rgba(22,28,42,0.98),rgba(8,11,18,0.98));
  box-shadow: 0 20px 72px rgba(0,0,0,0.46), inset 0 1px 0 rgba(255,255,255,0.1);
  backdrop-filter: blur(20px) saturate(150%);
  transition: opacity .2s, transform .2s, visibility .2s;
}
.sekai-player-panel::before {
  content: "";
  position: absolute;
  inset: 0 0 auto;
  z-index: 0;
  height: 148px;
  background:
    radial-gradient(circle at 12% 0%, rgba(30,216,255,0.22), transparent 36%),
    radial-gradient(circle at 78% 8%, rgba(255,93,168,0.2), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.09), transparent);
  pointer-events: none;
}
.sekai-player-panel::after {
  content: "";
  position: absolute;
  inset: auto 18px 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.16), transparent);
  pointer-events: none;
}
.sekai-player-panel.hidden {
  opacity: 0;
  pointer-events: none;
  transform: translateY(10px) scale(0.98);
  visibility: hidden;
}
.sekai-player-panel:not(.hidden) {
  opacity: 1;
  transform: translateY(0) scale(1);
  visibility: visible;
}

.sekai-player-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px 18px 13px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.045);
}
.sekai-heading {
  display: flex;
  align-items: center;
  gap: 9px;
  min-width: 0;
  border-radius: 999px;
  padding: 4px 5px 4px 10px;
  background: rgba(255,255,255,0.08);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
}
.sekai-player-title {
  font-size: .96rem;
  font-weight: 900;
  letter-spacing: .1em;
  color: #fff;
  text-shadow: 0 0 16px rgba(30,216,255,0.28);
}
.sekai-player-title::before {
  content: "";
  display: inline-block;
  width: 7px;
  height: 7px;
  margin-right: 8px;
  border-radius: 50%;
  background: linear-gradient(135deg,#1ed8ff,#ff5da8);
  box-shadow: 0 0 10px rgba(30,216,255,0.55);
  vertical-align: 1px;
}
.sekai-status {
  max-width: 180px;
  overflow: hidden;
  border: 1px solid rgba(30,216,255,0.24);
  border-radius: 999px;
  padding: 4px 9px;
  color: rgba(211,250,255,0.9);
  background: rgba(30,216,255,0.08);
  font-size: .68rem;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sekai-status[data-state="error"] {
  border-color: rgba(255,99,132,0.32);
  color: rgba(255,165,180,0.92);
}
.sekai-player-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border: 0;
  border-radius: 8px;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.64);
  cursor: pointer;
  font-size: 1.2rem;
  line-height: 1;
  transition: background .2s, color .2s;
}
.sekai-player-close:hover {
  background: rgba(255,93,168,0.16);
  color: #fff;
}

.sekai-player-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: 13px;
  min-height: 0;
  max-height: calc(min(840px, 100vh - 112px) - 54px);
  overflow-x: hidden;
  overflow-y: auto;
  padding: 16px 18px 18px;
  scrollbar-color: rgba(30,216,255,0.42) rgba(255,255,255,0.06);
  scrollbar-width: thin;
}
.sekai-player-body::-webkit-scrollbar {
  width: 8px;
}
.sekai-player-body::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.06);
}
.sekai-player-body::-webkit-scrollbar-thumb {
  border: 2px solid rgba(12,16,26,0.9);
  border-radius: 999px;
  background: linear-gradient(180deg,#1ed8ff,#ff5da8);
}
.sekai-top-section {
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  padding: 12px;
  background:
    linear-gradient(90deg,rgba(30,216,255,0.1),rgba(255,255,255,0.025) 44%,rgba(255,93,168,0.1)),
    rgba(255,255,255,0.035);
}
.sekai-cover-wrap {
  flex: 0 0 auto;
}
.sekai-cd {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 98px;
  height: 98px;
  overflow: visible;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.24);
  background:
    linear-gradient(135deg,rgba(30,216,255,0.2),rgba(255,93,168,0.14)),
    rgba(255,255,255,0.05);
  box-shadow: 0 0 0 5px rgba(255,255,255,0.035), 0 14px 30px rgba(0,0,0,0.34), 0 0 26px rgba(30,216,255,0.13);
}
.sekai-cd-visualizer {
  position: absolute;
  inset: -10px;
  z-index: 3;
  width: calc(100% + 20px);
  height: calc(100% + 20px);
  border-radius: 50%;
  opacity: 0;
  mix-blend-mode: screen;
  pointer-events: none;
  transition: opacity .2s;
}
.sekai-cd.viz-cd .sekai-cd-visualizer {
  opacity: .95;
}
.sekai-cd::before {
  content: none;
}
.sekai-cover,
.sekai-cover-fallback {
  position: relative;
  z-index: 1;
  width: 98px;
  height: 98px;
  border-radius: 50%;
  animation: sekaiCdSpin 8s linear infinite;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.32), 0 10px 24px rgba(0,0,0,0.24);
}
.sekai-cover {
  object-fit: cover;
}
.sekai-cover-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.72);
  font-size: 1.7rem;
}
.sekai-cd.paused .sekai-cover,
.sekai-cd.paused .sekai-cover-fallback {
  animation-play-state: paused;
}
@keyframes sekaiCdSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.sekai-now-playing {
  flex: 1;
  min-width: 0;
}
.sekai-track-title {
  margin-bottom: 5px;
  overflow: hidden;
  color: #fff;
  font-size: 1.02rem;
  font-weight: 900;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sekai-track-artist {
  margin-bottom: 10px;
  overflow: hidden;
  color: rgba(211,250,255,0.72);
  font-size: .73rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sekai-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.58);
  font-size: .7rem;
  font-variant-numeric: tabular-nums;
}
.sekai-progress input[type=range],
.sekai-volume input[type=range] {
  flex: 1;
  height: 5px;
  border-radius: 999px;
  background: linear-gradient(90deg,rgba(30,216,255,0.42),rgba(255,93,168,0.36));
  cursor: pointer;
  -webkit-appearance: none;
}
.sekai-progress input[type=range]::-webkit-slider-thumb,
.sekai-volume input[type=range]::-webkit-slider-thumb {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 0 0 4px rgba(30,216,255,0.18), 0 0 14px rgba(255,93,168,0.24);
  -webkit-appearance: none;
}
.sekai-controls {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 8px;
}
.sekai-ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  background: rgba(255,255,255,0.075);
  color: #fff;
  cursor: pointer;
  font-size: 1.1rem;
  line-height: 1;
  transition: background .2s, transform .2s;
}
.sekai-ctrl-btn:hover {
  background: rgba(30,216,255,0.16);
  border-color: rgba(30,216,255,0.28);
  transform: translateY(-1px);
}
.sekai-play-btn {
  width: 46px;
  height: 38px;
  background: linear-gradient(135deg,#ff5da8,#1ed8ff);
  box-shadow: 0 10px 22px rgba(30,216,255,0.2), 0 4px 14px rgba(255,93,168,0.2);
  font-size: .95rem;
}
.sekai-options,
.sekai-playback-options,
.sekai-library-controls,
.sekai-visualizer-options,
.sekai-volume {
  display: flex;
  align-items: center;
  gap: 8px;
}
.sekai-options {
  position: relative;
  z-index: 12;
}
.sekai-playback-options {
  align-items: stretch;
}
.sekai-search {
  min-width: 0;
  height: 38px;
  border: 1px solid rgba(120,220,255,0.2);
  border-radius: 8px;
  background:
    linear-gradient(135deg,rgba(30,216,255,0.12),rgba(255,93,168,0.08)),
    rgba(7,13,24,0.62);
  color: rgba(255,255,255,0.92);
  font-size: .78rem;
  font-weight: 700;
  outline: none;
  color-scheme: dark;
  transition: border-color .18s, box-shadow .18s, background .18s;
}
.sekai-search:focus {
  border-color: rgba(30,216,255,0.52);
  background:
    linear-gradient(135deg,rgba(30,216,255,0.17),rgba(255,93,168,0.11)),
    rgba(10,18,32,0.82);
  box-shadow: 0 0 0 3px rgba(30,216,255,0.12), 0 12px 28px rgba(0,0,0,0.2);
}
.sekai-search {
  flex: 1.2;
  padding: 0 10px;
}
.sekai-search::placeholder {
  color: rgba(211,250,255,0.44);
}
.sekai-dropdown {
  position: relative;
  flex: 1;
  min-width: 0;
}
.sekai-tag-dropdown {
  flex: .85;
}
.sekai-dropdown-btn {
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  align-items: center;
  width: 100%;
  min-width: 0;
  height: 42px;
  border: 1px solid rgba(120,220,255,0.2);
  border-radius: 10px;
  padding: 6px 34px 6px 12px;
  background:
    linear-gradient(135deg,rgba(30,216,255,0.13),rgba(255,93,168,0.09)),
    rgba(7,13,24,0.64);
  color: rgba(255,255,255,0.92);
  box-shadow: 0 10px 22px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
  cursor: pointer;
  font: inherit;
  outline: none;
  position: relative;
  transition: transform .18s, border-color .18s, box-shadow .18s;
}
.sekai-dropdown-btn::after {
  content: "";
  position: absolute;
  right: 12px;
  top: 50%;
  width: 8px;
  height: 8px;
  border-right: 2px solid rgba(211,250,255,0.68);
  border-bottom: 2px solid rgba(211,250,255,0.68);
  transform: translateY(-65%) rotate(45deg);
  transition: transform .18s;
}
.sekai-dropdown.open .sekai-dropdown-btn::after {
  transform: translateY(-30%) rotate(225deg);
}
.sekai-dropdown-btn:hover:not(:disabled),
.sekai-dropdown-btn:focus-visible {
  border-color: rgba(30,216,255,0.58);
  background:
    linear-gradient(135deg,rgba(30,216,255,0.18),rgba(255,93,168,0.13)),
    rgba(10,18,32,0.82);
  box-shadow: 0 14px 26px rgba(30,216,255,0.16), inset 0 1px 0 rgba(255,255,255,0.13);
  transform: translateY(-1px);
}
.sekai-dropdown-btn:disabled {
  cursor: default;
  opacity: .66;
}
.sekai-dropdown-kicker,
.sekai-dropdown-value {
  min-width: 0;
  overflow: hidden;
  text-align: left;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sekai-dropdown-kicker {
  grid-column: 1 / -1;
  color: rgba(30,216,255,0.72);
  font-size: .58rem;
  font-weight: 900;
  letter-spacing: .12em;
  line-height: 1;
}
.sekai-dropdown-value {
  color: rgba(255,255,255,0.94);
  font-size: .8rem;
  font-weight: 900;
  line-height: 1.2;
}
.sekai-dropdown-menu {
  position: absolute;
  z-index: 60;
  right: 0;
  left: 0;
  top: calc(100% + 8px);
  display: none;
  max-height: 230px;
  overflow-x: hidden;
  overflow-y: auto;
  border: 1px solid rgba(120,220,255,0.22);
  border-radius: 10px;
  padding: 6px;
  background:
    linear-gradient(135deg,rgba(30,216,255,0.12),rgba(255,93,168,0.08)),
    rgba(7,13,24,0.96);
  box-shadow: 0 18px 42px rgba(0,0,0,0.42), 0 0 0 1px rgba(30,216,255,0.11);
  color: rgba(255,255,255,0.9);
  backdrop-filter: blur(18px) saturate(150%);
  scrollbar-color: rgba(30,216,255,0.44) transparent;
  scrollbar-width: thin;
}
.sekai-dropdown.open .sekai-dropdown-menu {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
#sekaiVocalMenu {
  max-height: 320px;
}
:global(.sekai-dropdown-item) {
  display: flex;
  align-items: flex-start;
