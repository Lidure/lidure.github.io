<script is:inline>
(function() {
  var MASTER_BASE = 'https://sekai-world.github.io/sekai-master-db-diff';
  var ASSET_BASE = 'https://storage.sekai.best/sekai-jp-assets';
  var STORAGE_KEY = 'sekai_player_v3';
  var MAX_RENDERED_TRACKS = 140;

  var TAG_ORDER = [
    'all',
    'vocaloid',
    'light_music_club',
    'idol',
    'street',
    'theme_park',
    'school_refusal',
    'other'
  ];
