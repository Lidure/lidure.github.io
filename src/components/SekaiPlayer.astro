---
/** SEKAI player */
---

<button id="sekaiPlayerBtn" class="sekai-player-btn" title="SEKAI 播放器" aria-label="打开 SEKAI 播放器" transition:persist transition:name="sekai-btn">
  <img id="sekaiDockCover" class="sekai-dock-cover" src="" alt="" aria-hidden="true" />
  <canvas id="sekaiDockVisualizer" class="sekai-dock-visualizer" aria-hidden="true"></canvas>
  <span id="sekaiDockIcon" class="sekai-dock-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
  </span>
</button>

<div id="sekaiPlayerPanel" class="sekai-player-panel hidden" role="dialog" aria-label="SEKAI 播放器" transition:persist transition:name="sekai-panel">
  <div class="sekai-mobile-bg" id="sekaiMobileBg" aria-hidden="true"></div>
  <div class="sekai-player-header">
    <div class="sekai-heading">
      <span class="sekai-player-title">PJSK CD</span>
      <span id="sekaiSourceStatus" class="sekai-status">未加载</span>
    </div>
    <div class="sekai-header-tools">
      <div class="sekai-header-toggle sekai-header-mode" aria-label="音频版本">
        <button id="sekaiLongBtn" class="sekai-header-btn active" type="button" title="完整版">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        </button>
        <button id="sekaiShortBtn" class="sekai-header-btn" type="button" title="片段版">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="4" height="12" rx="1"/><rect x="8" y="4" width="4" height="16" rx="1"/><rect x="14" y="8" width="4" height="8" rx="1"/></svg>
        </button>
      </div>
      <div class="sekai-header-toggle sekai-header-order" aria-label="播放顺序">
        <button id="sekaiSequenceBtn" class="sekai-header-btn active" type="button" title="顺序播放">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/></svg>
        </button>
        <button id="sekaiShuffleBtn" class="sekai-header-btn" type="button" title="随机播放">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        </button>
      </div>
      <div class="sekai-header-toggle sekai-header-visual" aria-label="可视化">
        <button id="sekaiVizOffBtn" class="sekai-header-btn active" type="button" title="关闭可视化" aria-pressed="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
        </button>
        <button id="sekaiVizCdBtn" class="sekai-header-btn" type="button" title="环形可视化" aria-pressed="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
        <button id="sekaiVizDockBtn" class="sekai-header-btn" type="button" title="悬浮可视化" aria-pressed="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="3" width="6" height="6" rx="1"/><rect x="3" y="15" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/></svg>
        </button>
        <button id="sekaiVizPageBtn" class="sekai-header-btn" type="button" title="背景可视化" aria-pressed="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
        </button>
      </div>
    </div>
    <button id="sekaiPlayerCloseBtn" class="sekai-player-close" title="关闭" aria-label="关闭">×</button>
  </div>

  <div class="sekai-player-body">
    <aside class="sekai-library-pane">
      <button class="sekai-lib-close" title="关闭歌单" aria-label="关闭歌单">&times;</button>
      <div class="sekai-library-controls">
        <input id="sekaiSearchInput" class="sekai-search" type="search" placeholder="搜索曲名 / 作曲 / 版本" autocomplete="off" />
        <div class="sekai-dropdown sekai-tag-dropdown" id="sekaiTagDropdown">
          <button id="sekaiTagButton" class="sekai-dropdown-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
            <span class="sekai-dropdown-kicker">UNIT</span>
            <span id="sekaiTagLabel" class="sekai-dropdown-value">全部</span>
          </button>
          <div id="sekaiTagMenu" class="sekai-dropdown-menu" role="listbox"></div>
        </div>
      </div>

      <div class="sekai-import-bar">
        <button id="sekaiLocalImport" class="sekai-import-btn" type="button" title="添加本地音乐">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span>本地音乐</span>
        </button>
        <input type="file" id="sekaiLocalFileInput" accept="audio/*" multiple hidden />
        <button id="sekaiOnlineImport" class="sekai-import-btn" type="button" title="导入在线歌单">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <span>在线歌单</span>
        </button>
        <button id="sekaiClearImported" class="sekai-import-btn sekai-import-clear" type="button" title="清空所有导入歌曲">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          <span>清空</span>
        </button>
      </div>

      <div id="sekaiOnlinePanel" class="sekai-online-panel" style="display:none">
        <div class="sekai-online-tabs">
          <button class="sekai-online-tab active" data-platform="netease">网易云</button>
          <button class="sekai-online-tab" data-platform="qq">QQ音乐</button>
        </div>
        <div class="sekai-online-input-row">
          <input id="sekaiPlaylistUrl" class="sekai-online-input" type="text" placeholder="粘贴歌单链接或ID" autocomplete="off" />
          <button id="sekaiPlaylistFetch" class="sekai-online-fetch" type="button">导入</button>
        </div>
        <div id="sekaiOnlineStatus" class="sekai-online-status"></div>
        <button id="sekaiOnlineClose" class="sekai-online-close" type="button">收起</button>
      </div>

      <div class="sekai-playlist-label">
        <span>播放列表</span>
        <span id="sekaiTrackCount">0</span>
      </div>
      <div class="sekai-playlist" id="sekaiPlaylist"></div>
    </aside>

    <section class="sekai-main-pane">
      <div class="sekai-top-section">
        <div class="sekai-cover-wrap">
          <div class="sekai-cd paused" id="sekaiCd">
            <canvas id="sekaiCdVisualizer" class="sekai-cd-visualizer" aria-hidden="true"></canvas>
            <img class="sekai-cover" id="sekaiCover" src="" alt="封面" style="display:none;" />
            <div class="sekai-cover-fallback" id="sekaiCoverFallback">♪</div>
          </div>
        </div>
      </div>

        <div class="sekai-now-playing">
          <div class="sekai-track-title" id="sekaiTrackTitle">选择一首歌曲</div>
          <div class="sekai-track-artist" id="sekaiTrackArtist">Project SEKAI</div>
          <div class="sekai-progress">
            <span id="sekaiCurrentTime">0:00</span>
            <input type="range" id="sekaiProgressBar" min="0" max="100" value="0" step="0.1" aria-label="播放进度" />
            <span id="sekaiTotalTime">0:00</span>
          </div>
          <div class="sekai-controls">
            <button id="sekaiPrevBtn" class="sekai-ctrl-btn" title="上一首" aria-label="上一首">‹</button>
            <button id="sekaiPlayPauseBtn" class="sekai-ctrl-btn sekai-play-btn" title="播放/暂停" aria-label="播放/暂停">▶</button>
            <button id="sekaiNextBtn" class="sekai-ctrl-btn" title="下一首" aria-label="下一首">›</button>
            <div class="sekai-vol-wrap" id="sekaiVolWrap">
              <button id="sekaiVolBtn" class="sekai-vol-btn" type="button" title="音量" aria-label="音量">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                  <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                  <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                </svg>
              </button>
              <div class="sekai-vol-popover" id="sekaiVolPopover" role="group" aria-label="音量调节">
                <input type="range" id="sekaiVolumeSlider" class="sekai-vol-slider" min="0" max="1" step="0.01" value="0.5" aria-label="音量" />
                <span id="sekaiVolumeValue" class="sekai-vol-value">50%</span>
              </div>
            </div>
            <div class="sekai-order-toggle" aria-label="播放顺序">
              <button id="sekaiSequenceBtnM" class="sekai-order-btn active" type="button" title="顺序播放">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/></svg>
              </button>
              <button id="sekaiShuffleBtnM" class="sekai-order-btn" type="button" title="随机播放">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
              </button>
            </div>
            <button id="sekaiPlaylistToggle" class="sekai-playlist-toggle" title="播放列表" aria-label="播放列表">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1.5" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1.5" fill="currentColor" stroke="none"/></svg>
            </button>
          </div>
        </div>

      <div class="sekai-control-panel">
        <div class="sekai-dropdown sekai-vocal-dropdown" id="sekaiVocalDropdown">
          <button id="sekaiVocalButton" class="sekai-dropdown-btn" type="button" aria-haspopup="listbox" aria-expanded="false" disabled>
            <span class="sekai-dropdown-kicker">VOCAL</span>
            <span id="sekaiVocalLabel" class="sekai-dropdown-value">Vocal</span>
          </button>
          <div id="sekaiVocalMenu" class="sekai-dropdown-menu" role="listbox"></div>
        </div>
      </div>
    </section>
  </div>
</div>

<audio id="sekaiAudio" preload="metadata" transition:persist transition:name="sekai-audio"></audio>
<canvas id="sekaiPageVisualizer" class="sekai-page-visualizer" aria-hidden="true" transition:persist transition:name="sekai-page-viz"></canvas>

<style>
.sekai-player-btn {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50px;
  height: 50px;
  overflow: visible;
  border: none;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(26, 20, 48, 0.7), rgba(40, 28, 72, 0.5));
  backdrop-filter: blur(20px) saturate(1.6);
  -webkit-backdrop-filter: blur(20px) saturate(1.6);
  color: var(--accent);
  box-shadow:
    0 4px 20px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.12),
    0 0 0 1px rgba(255, 255, 255, 0.08);
  cursor: pointer;
  font-size: 1.35rem;
  transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s, background .3s;
  user-select: none;
}

[data-theme="light"] .sekai-player-btn {
  background: linear-gradient(135deg, rgba(255, 240, 248, 0.75), rgba(255, 220, 240, 0.55));
  box-shadow:
    0 4px 20px rgba(200, 80, 150, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.5),
    0 0 0 1px rgba(200, 80, 150, 0.15);
}
.sekai-player-btn::after {
  content: none;
}
.sekai-player-btn.has-cover::after {
  opacity: 0;
}
.sekai-dock-cover {
  position: absolute;
  inset: 2px;
  z-index: 1;
  width: calc(100% - 4px);
  height: calc(100% - 4px);
  border-radius: 50%;
  object-fit: cover;
  opacity: 0;
  transform: rotate(0deg);
  transition: opacity .3s;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
}
.sekai-player-btn.has-cover .sekai-dock-cover {
  opacity: 1;
}
.sekai-player-btn.playing .sekai-dock-cover {
  animation: sekaiCdSpin 7.5s linear infinite;
}
.sekai-dock-visualizer {
  position: absolute;
  inset: -11px;
  z-index: 0;
  width: calc(100% + 22px);
  height: calc(100% + 22px);
  border-radius: 50%;
  opacity: 0;
  mix-blend-mode: normal;
  pointer-events: none;
  transition: opacity .3s;
}
.sekai-player-btn.viz-dock .sekai-dock-visualizer {
  opacity: .95;
}
.sekai-dock-icon {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sekai-dock-icon svg {
  width: 22px;
  height: 22px;
}
.sekai-player-btn.has-cover .sekai-dock-icon {
  opacity: 0;
}
.sekai-player-btn:hover {
  transform: translateY(-3px) scale(1.1);
  box-shadow:
    0 8px 28px rgba(0, 0, 0, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.18),
    0 0 0 1px rgba(255, 255, 255, 0.15);
}
.sekai-player-btn:active {
  transform: translateY(-1px) scale(1.02);
}
.sekai-player-btn.playing {
  animation: sekaiPulse 2.5s ease-in-out infinite;
}
@keyframes sekaiPulse {
  0%,100% {
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  50% {
    box-shadow:
      0 4px 28px rgba(var(--accent-rgb), 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 0 0 1px rgba(var(--accent-rgb), 0.2);
  }
}

.sekai-player-panel {
  position: fixed;
  right: 24px;
  bottom: 90px;
  z-index: 10000;
  display: flex;
  flex-direction: column;
  width: 920px;
  max-width: calc(100vw - 32px);
  max-height: min(720px, calc(100vh - 112px));
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 8px;
  background:
    linear-gradient(180deg,rgba(20,26,38,0.98),rgba(8,11,18,0.98));
  box-shadow: 0 18px 56px rgba(0,0,0,0.48), inset 0 1px 0 rgba(255,255,255,0.08);
  backdrop-filter: blur(18px) saturate(140%);
  isolation: isolate;
  transition: opacity .2s, transform .2s, visibility .2s;
}
.sekai-player-panel::before {
  content: none;
}
.sekai-player-panel::after {
  content: none;
}
.sekai-player-panel.hidden {
  opacity: 0;
  pointer-events: none;
  transform: translateY(10px) scale(0.98);
  visibility: hidden;
}
.sekai-player-panel:not(.hidden) {
  opacity: 1;
  transform: translateY(0) scale(1);
  visibility: visible;
}

.sekai-player-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 10px 12px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.035);
}
.sekai-header-tools {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-right: auto;
  margin-left: 4px;
}
.sekai-header-toggle {
  display: flex;
  gap: 2px;
  padding: 3px;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 7px;
  background: rgba(7,13,24,0.5);
}
.sekai-header-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: 0;
  border-radius: 5px;
  background: transparent;
  color: rgba(255,255,255,0.45);
  cursor: pointer;
  transition: background .18s, color .18s, box-shadow .18s, transform .18s;
}
.sekai-header-btn svg {
  width: 15px;
  height: 15px;
}
.sekai-header-btn:hover {
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.08);
}
.sekai-header-btn.active {
  background: linear-gradient(135deg,rgba(30,216,255,0.28),rgba(255,93,168,0.22));
  color: #fff;
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.15);
}
.sekai-header-btn:active {
  transform: scale(0.92);
}
.sekai-heading {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}
.sekai-player-title {
  font-size: .96rem;
  font-weight: 700;
  letter-spacing: 0;
  color: #fff;
}
.sekai-player-title::before {
  content: "";
  display: inline-block;
  width: 7px;
  height: 7px;
  margin-right: 8px;
  border-radius: 50%;
  background: linear-gradient(135deg,#1ed8ff,#ff5da8);
  box-shadow: 0 0 10px rgba(30,216,255,0.55);
  vertical-align: 1px;
}
.sekai-status {
  max-width: 160px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 7px;
  padding: 4px 8px;
  color: rgba(211,250,255,0.78);
  background: rgba(255,255,255,0.05);
  font-size: .68rem;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sekai-status[data-state="error"] {
  border-color: rgba(255,99,132,0.32);
  color: rgba(255,165,180,0.92);
}
.sekai-player-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  border: 0;
  border-radius: 8px;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.64);
  cursor: pointer;
  font-size: 1.2rem;
  line-height: 1;
  transition: background .2s, color .2s;
}
.sekai-player-close:hover {
  background: rgba(255,93,168,0.16);
  color: #fff;
}

.sekai-player-body {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
  flex: 1 1 auto;
  gap: 0;
  min-height: 0;
  max-height: calc(min(720px, 100vh - 112px) - 54px);
  overflow-x: hidden;
  overflow-y: hidden;
  padding: 0;
  scrollbar-color: rgba(30,216,255,0.42) rgba(255,255,255,0.06);
  scrollbar-width: thin;
}
.sekai-player-body::-webkit-scrollbar {
  width: 8px;
}
.sekai-player-body::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.06);
}
.sekai-player-body::-webkit-scrollbar-thumb {
