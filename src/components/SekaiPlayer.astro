.sekai-cd {
  --sekai-cd-scale: 1;
  --sekai-cd-glow: 0.13;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 218px;
  height: 218px;
  overflow: visible;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.24);
  background:
    linear-gradient(135deg,rgba(30,216,255,0.2),rgba(255,93,168,0.14)),
    rgba(255,255,255,0.05);
  box-shadow: 0 10px 24px rgba(0,0,0,0.3), 0 0 24px rgba(30,216,255,var(--sekai-cd-glow));
  transform: scale(var(--sekai-cd-scale));
  transform-origin: center;
  transition: border-radius .55s cubic-bezier(.2,.8,.2,1), box-shadow .35s, background .35s;
}
.sekai-cd.paused {
  border-radius: 24px;
  background: rgba(255,255,255,0.045);
}
.sekai-cd-visualizer {
  position: absolute;
  inset: -26px;
  z-index: 3;
  width: calc(100% + 52px);
  height: calc(100% + 52px);
  border-radius: 50%;
  opacity: 0;
  mix-blend-mode: normal;
  pointer-events: none;
  transition: opacity .2s;
}
.sekai-cd.viz-cd .sekai-cd-visualizer {
  opacity: 1;
}
.sekai-cd::before {
  content: "";
  position: absolute;
  inset: 18px;
  z-index: 2;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, transparent 0 31%, rgba(255,255,255,0.24) 32%, transparent 34%),
    repeating-radial-gradient(circle at center, rgba(255,255,255,0.16) 0 1px, transparent 1px 13px);
  opacity: 0;
  pointer-events: none;
  transition: opacity .45s;
}
.sekai-cd::after {
  content: "";
  position: absolute;
  z-index: 4;
  width: 42px;
  height: 42px;
  border: 1px solid rgba(255,255,255,0.5);
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(7,13,24,0.95) 0 28%, rgba(255,255,255,0.9) 29% 36%, rgba(7,13,24,0.82) 38% 100%);
  box-shadow: 0 0 18px rgba(30,216,255,0.22);
  opacity: 0;
  pointer-events: none;
  transition: opacity .45s, transform .45s;
  transform: scale(.8);
}
.sekai-cd:not(.paused)::before {
  opacity: .42;
}
.sekai-cd:not(.paused)::after {
  opacity: 1;
  transform: scale(1);
}
.sekai-cover,
.sekai-cover-fallback {
  position: relative;
  z-index: 1;
  width: 218px;
  height: 218px;
  border-radius: 50%;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.28), 0 8px 18px rgba(0,0,0,0.22);
  transform: rotate(0deg);
  transition: transform .7s cubic-bezier(.22,1,.36,1), border-radius .55s cubic-bezier(.2,.8,.2,1), filter .35s, box-shadow .35s;
}
.sekai-cover {
