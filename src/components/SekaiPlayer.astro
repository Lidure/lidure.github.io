  }

  function tickParticles(pool, ctx) {
    for (var i = pool.length - 1; i >= 0; i--) {
      var p = pool[i];
      p.x += p.vx;
      p.y += p.vy;
      p.vx *= 0.992;
      p.vy *= 0.992;
      p.life--;
      if (p.life <= 0) { pool.splice(i, 1); continue; }
      var t = p.life / p.max;
