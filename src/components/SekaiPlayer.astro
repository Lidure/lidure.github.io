    virtual_singer: 'Virtual Singer',
    another_vocal: 'Another Vocal',
    instrumental: 'Instrumental',
    streaming_live: 'Streaming Live',
    april_fool_2022: 'April Fool'
  };
  var CHARACTER_NAMES = {
    1: '星乃一歌',
    2: '天馬咲希',
    3: '望月穂波',
    4: '日野森志歩',
    5: '花里みのり',
