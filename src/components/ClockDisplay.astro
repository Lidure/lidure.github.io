---
const now = new Date();
const serverTime = now.toLocaleString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long',
  hour: '2-digit',
  minute: '2-digit',
  second: '2-digit',
});
---
<section class="clock-kawaii" aria-label="当前时间">
  <span class="clock-icon" aria-hidden="true">⏰</span>
  <span id="clock-display" class="clock-text-kawaii">{serverTime}</span>
</section>

<style>
.clock-kawaii {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 10px 24px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(var(--accent-rgb), 0.08), rgba(124, 140, 248, 0.06));
  border: 1px solid var(--panel-border);
  backdrop-filter: blur(4px);
  box-shadow: var(--shadow-soft);
}

.clock-icon {
  font-size: 1.15rem;
  line-height: 1;
  animation: clock-bounce 2s ease-in-out infinite;
}

.clock-text-kawaii {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 1.12rem;
  color: var(--accent);
  letter-spacing: 0.05em;
  font-weight: 500;
  line-height: 1.2;
}

@keyframes clock-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}

@media (max-width: 720px) {
  .clock-kawaii {
    padding: 8px 18px;
    gap: 8px;
  }
  .clock-text-kawaii {
    font-size: 0.95rem;
  }
}
</style>

<script>
function pad(n: number): string {
  return n < 10 ? '0' + n : String(n);
}

const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];

function tick() {
  const el = document.getElementById('clock-display');
  if (!el) return;
  const d = new Date();
  el.textContent = `${d.getFullYear()} 年 ${d.getMonth() + 1} 月 ${d.getDate()} 日 ${weekdays[d.getDay()]} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
}

tick();
const timer = setInterval(tick, 1000);

document.addEventListener('astro:before-swap', () => clearInterval(timer));
</script>