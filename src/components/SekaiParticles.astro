---
/** Project SEKAI 风格世界碎片 —— 在最顶层缓慢飘浮，极低透明度。 */
---
<div class="sekai-particles" aria-hidden="true">
  {Array.from({ length: 20 }).map((_, i) => (
    <span
      class={`particle particle--${(i % 6) + 1}`}
      style={{
        left: `${5 + Math.random() * 90}%`,
        width: `${8 + Math.random() * 14}px`,
        height: `${8 + Math.random() * 14}px`,
        animationDelay: `${Math.random() * 18}s`,
        animationDuration: `${16 + Math.random() * 18}s`,
        opacity: 0.12 + Math.random() * 0.18,
      }}
      aria-hidden="true"
    />
  ))}
</div>

<style>
.sekai-particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}

.particle {
  position: absolute;
  bottom: -40px;
  border-radius: 3px;
  transform: rotate(45deg);
  animation: sekai-float linear infinite;
}

.particle--1 { background: #ff8bb5; }
.particle--2 { background: #6090dd; }
.particle--3 { background: #50c0a8; }
.particle--4 { background: #f08050; }
.particle--5 { background: #ecc030; }
.particle--6 { background: #b070cc; }

@keyframes sekai-float {
  0%   { transform: translateY(0) rotate(45deg); opacity: 0; }
  8%   { opacity: 1; }
  82%  { opacity: 1; }
  100% { transform: translateY(-110vh) rotate(135deg); opacity: 0; }
}

@media (prefers-reduced-motion: reduce) {
  .sekai-particles { display: none; }
}
</style>