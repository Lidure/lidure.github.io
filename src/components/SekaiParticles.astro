---
/** Project SEKAI 世界碎片 — Canvas 粒子系统，不受系统动效设置影响。 */
---
<canvas id="sekai-canvas" aria-hidden="true"></canvas>

<style>
#sekai-canvas {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9999;
  display: block;
}
</style>

<script is:inline>
(function() {
  var canvas = document.getElementById('sekai-canvas');
  if (!canvas || !canvas.getContext) return;

  const ctx = canvas.getContext('2d');

  const colors = [
    'rgba(255,139,181,',
    'rgba(96,144,221,',
    'rgba(80,192,168,',
    'rgba(240,128,80,',
    'rgba(236,192,48,',
    'rgba(176,112,204,',
  ];

  let W, H;
  const particles = [];

  function makeParticle(resetY) {
    W = canvas.width;
    H = canvas.height;
    return {
      x: Math.random() * W,
      y: resetY ? -20 - Math.random() * H * 0.5 : Math.random() * H,
      size: 3 + Math.random() * 10,
      color: colors[Math.floor(Math.random() * colors.length)],
      speedY: 0.2 + Math.random() * 0.5,
      speedX: (Math.random() - 0.5) * 0.3,
      opacity: 0.25 + Math.random() * 0.35,
      rotation: Math.random() * Math.PI,
      rotationSpeed: (Math.random() - 0.5) * 0.02,
    };
  }

  function update(p) {
    p.y += p.speedY;
    p.x += p.speedX;
    p.rotation += p.rotationSpeed;
    if (p.y > H + 20) {
      var n = makeParticle(true);
      p.x = n.x; p.y = -20; p.size = n.size;
      p.color = n.color; p.speedY = n.speedY; p.speedX = n.speedX;
      p.opacity = n.opacity; p.rotation = n.rotation; p.rotationSpeed = n.rotationSpeed;
    }
  }

  function draw(p) {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rotation);
    ctx.globalAlpha = p.opacity;
    ctx.fillStyle = p.color + p.opacity + ')';
    ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
    ctx.restore();
  }

  function resize() {
    var dpr = window.devicePixelRatio || 1;
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.scale(dpr, dpr);
  }

  function init(count) {
    resize();
    particles.length = 0;
    for (var i = 0; i < count; i++) {
      particles.push(makeParticle(false));
    }
  }

  function animate() {
    ctx.clearRect(0, 0, W, H);
    for (var i = 0; i < particles.length; i++) {
      update(particles[i]);
      draw(particles[i]);
    }
    requestAnimationFrame(animate);
  }

  window.addEventListener('resize', resize);
  init(40);
  animate();
})();
</script>