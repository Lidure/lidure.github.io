---
/** 樱花飘落特效。 */
---
<div id="sakura-container" aria-hidden="true"></div>

<style>
#sakura-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}
</style>

<script is:inline>
(function() {
  if (window.__sekaiParticlesInit) return;
  window.__sekaiParticlesInit = true;

  var container = document.getElementById('sakura-container');
  if (!container) return;

  var emojis = ['🌸', '💮', '✿', '❀'];
  var MAX_PETALS = 30;

  function createSakura() {
    if (container.children.length >= MAX_PETALS) return;

    var petal = document.createElement('div');
    petal.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];

    var pixelX = Math.random() * (window.innerWidth - 30);
    var size = Math.random() * 10 + 10;
    var duration = Math.random() * 5 + 8;
    var opacity = Math.random() * 0.5 + 0.3;
    var startY = -50;
    var endY = window.innerHeight + 50;

    petal.style.cssText = [
      'position:absolute',
      'left:' + pixelX + 'px',
      'font-size:' + size + 'px',
      'opacity:0',
      'pointer-events:none',
      'text-shadow:0 0 10px rgba(255,182,193,0.5)',
      'will-change:transform,opacity'
    ].join(';');

    container.appendChild(petal);

    var startTime = null;
    var lastTs = null;

    function animate(ts) {
      if (!startTime) startTime = ts;
      // 页面后台恢复后时间戳可能跳跃过大，直接移除花瓣避免堆积
      if (lastTs !== null && ts - lastTs > 1000) {
        petal.remove();
        return;
      }
      var progress = Math.min((ts - startTime) / 1000 / duration, 1);
      var y = startY + (endY - startY) * progress;
      var x = pixelX + 100 * progress + Math.sin(progress * Math.PI * 3) * 20;
      var rot = 720 * progress;
      var fadeIn = Math.min(progress * 10, 1);
      var fadeOut = progress > 0.9 ? (1 - (progress - 0.9) / 0.1) : 1;
      petal.style.transform = 'translate(' + x + 'px,' + y + 'px) rotate(' + rot + 'deg)';
      petal.style.opacity = opacity * fadeIn * fadeOut;
      if (progress < 1) {
        lastTs = ts;
        requestAnimationFrame(animate);
      } else {
        petal.remove();
      }
    }

    requestAnimationFrame(animate);
  }

  createSakura();
  setInterval(createSakura, 800);

  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'hidden') {
      container._hiddenTime = Date.now();
    } else if (container._hiddenTime && Date.now() - container._hiddenTime > 10000) {
      container.innerHTML = '';
    }
  });
})();
</script>