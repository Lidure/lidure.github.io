---
/** 樱花飘落特效。 */
---
<div id="sakura-container" aria-hidden="true"></div>

<style>
#sakura-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9999;
  overflow: hidden;
}

.sakura-petal {
  position: absolute;
  top: 0;
  text-shadow: 0 0 10px rgba(255, 182, 193, 0.5);
  will-change: transform, opacity;
}
</style>

<script is:inline>
(function() {
  var container = document.getElementById('sakura-container');
  if (!container) return;

  var emojis = ['🌸', '💮', '✿', '❀'];

  function createSakura() {
    var petal = document.createElement('div');
    petal.className = 'sakura-petal';
    petal.innerHTML = emojis[Math.floor(Math.random() * emojis.length)];

    var pixelX = Math.random() * window.innerWidth;
    var size = Math.random() * 14 + 10;
    var duration = Math.random() * 5 + 6;
    var drift = (Math.random() - 0.5) * 120;
    var swayAmp = (Math.random() - 0.5) * 40;
    var rotateEnd = (Math.random() * 4 - 2) * 360;
    var opacity = Math.random() * 0.4 + 0.3;
    var startY = -50 - Math.random() * 200;
    var endY = window.innerHeight + 60;

    petal.style.cssText = [
      'position:absolute',
      'font-size:' + size + 'px',
      'opacity:0',
      'pointer-events:none',
      'text-shadow:0 0 10px rgba(255,182,193,0.5)',
      'will-change:transform'
    ].join(';');

    container.appendChild(petal);

    var startTime = null;

    function animate(ts) {
      if (!startTime) startTime = ts;
      var elapsed = (ts - startTime) / 1000;
      var progress = Math.min(elapsed / duration, 1);

      var swayX = Math.sin(progress * Math.PI * 3) * swayAmp;
      var driftX = drift * progress;
      var y = startY + progress * (endY - startY);
      var scale = 1 - progress * 0.1;
      var rot = rotateEnd * progress;
      var fadeIn = Math.min(progress * 10, 1);
      var fadeOut = progress > 0.9 ? (1 - (progress - 0.9) / 0.1) : 1;
      var op = opacity * fadeIn * fadeOut;

      petal.style.transform = 'translate(' + (pixelX + swayX + driftX) + 'px, ' + y + 'px) rotate(' + rot + 'deg) scale(' + scale + ')';
      petal.style.opacity = op;

      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        petal.remove();
      }
    }

    requestAnimationFrame(animate);
  }

  createSakura();
  setInterval(createSakura, 600);
})();
</script>