---
/** Project SEKAI 风格世界碎片 —— 客户端 JS 实时创建，不受构建时区影响。 */
---
<div id="sekai-container" class="sekai-container" aria-hidden="true"></div>

<script>
(function() {
  const container = document.getElementById('sekai-container');
  if (!container) return;

  const colors = [
    '#ff8bb5', '#6090dd', '#50c0a8',
    '#f08050', '#ecc030', '#b070cc',
  ];

  for (let i = 0; i < 30; i++) {
    const el = document.createElement('span');
    const size = 6 + Math.random() * 16;
    el.style.cssText = [
      'position: fixed',
      'pointer-events: none',
      'z-index: 9999',
      'bottom: -30px',
      `left: ${Math.random() * 96 + 2}%`,
      `width: ${size}px`,
      `height: ${size}px`,
      'border-radius: 3px',
      'transform: rotate(45deg)',
      `background: ${colors[i % colors.length]}`,
      `opacity: ${0.35 + Math.random() * 0.35}`,
      `animation: sekai-drift ${14 + Math.random() * 20}s linear infinite`,
      `animation-delay: ${Math.random() * 20}s`,
    ].join(';');
    container.appendChild(el);
  }
})();
</script>

<style>
.sekai-container { display: none; }

@keyframes sekai-drift {
  0%   { transform: translateY(0) rotate(45deg); opacity: 0; }
  5%   { opacity: 1; }
  85%  { opacity: 1; }
  100% { transform: translateY(-120vh) rotate(135deg); opacity: 0; }
}
</style>