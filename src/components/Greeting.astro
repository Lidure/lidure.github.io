---
/** 根据访客本地时段显示可爱问候语（客户端动态计算） */
---
<span id="greeting-text" class="greeting-text"></span>

<script is:inline>
(function() {
  function setGreeting() {
    var greetings = {
      dawn:    { emoji: '🌅', text: '清晨好呀，今天也一起加油吧 ～' },
      morning: { emoji: '☀️', text: '早上好～ 愿你今天也有好心情！' },
      noon:    { emoji: '🌞', text: '中午啦，记得好好吃饭哦 ～' },
      afternoon: { emoji: '🌤️', text: '下午好～ 要不要停下来喝杯茶呢' },
      dusk:    { emoji: '🌆', text: '傍晚了呢，今天辛苦啦 ✨' },
      night:   { emoji: '🌙', text: '夜深了，早点休息哦，晚安 ～' },
      late:    { emoji: '💫', text: '还没睡吗？注意身体呀～' }
    };

    var hour = new Date().getHours();
    var key;
    if (hour >= 5 && hour < 8) key = 'dawn';
    else if (hour >= 8 && hour < 11) key = 'morning';
    else if (hour >= 11 && hour < 13) key = 'noon';
    else if (hour >= 13 && hour < 17) key = 'afternoon';
    else if (hour >= 17 && hour < 19) key = 'dusk';
    else if (hour >= 19 && hour < 23) key = 'night';
    else key = 'late';

    var g = greetings[key];
    var el = document.getElementById('greeting-text');
    if (el && g) el.textContent = g.emoji + ' ' + g.text;
  }

  // 首次加载
  setGreeting();

  // ClientRouter 每次页面切换完成后重新设置问候语
  document.addEventListener('astro:page-load', setGreeting);
})();
</script>

<style>
.greeting-text {
  font-size: 1.05rem;
  color: var(--text-soft);
  font-weight: 500;
  letter-spacing: 0.04em;
}

[data-theme="light"] .greeting-text {
  color: var(--text);
}

@media (max-width: 720px) {
  .greeting-text {
    font-size: 0.95rem;
  }
}
</style>