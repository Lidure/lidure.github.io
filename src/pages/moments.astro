---
import BaseLayout from '../layouts/BaseLayout.astro';
import { moments, categoryMeta, categoryOrder } from '../data/moments';
import type { MomentCategory } from '../data/moments';

const sortedMoments = [...moments].sort(
  (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);

const stats = categoryOrder.map((cat) => ({
  cat,
  count: sortedMoments.filter((m) => m.category === cat).length,
}));
const total = sortedMoments.length;
---
<BaseLayout title="碎碎念 | 搁浅 的小窝" description="游戏，音乐、生活，随时碎碎念。" showTime={true}>
  <section class="moments-shell">

    <!-- Hero -->
    <div class="moments-hero">
      <div class="hero-bubbles">
        <span class="bubble b1"></span>
        <span class="bubble b2"></span>
        <span class="bubble b3"></span>
      </div>
      <span class="kicker">✨ Moments</span>
      <h1>碎碎念</h1>
      <p>随手记下的碎片，游戏 · 音乐 · 生活。随时更新，想到什么说什么。</p>
      <div class="hero-stats">
        <span class="stat-badge">
          <strong>{total}</strong> 条动态
        </span>
        {stats.map((s) => (
          <span class="stat-badge">
            {categoryMeta[s.cat].icon} <strong>{s.count}</strong>
          </span>
        ))}
      </div>
    </div>

    <!-- 控制栏：筛选 + 发布 -->
    <div class="controls-bar">
      <div class="cat-pills">
        <button class="pill active" data-category="all">全部</button>
        {categoryOrder.map((cat) => (
          <button class="pill" data-category={cat}>
            {categoryMeta[cat].icon}
          </button>
        ))}
      </div>
      <button class="fab" id="publish-toggle" aria-label="发布新动态">
        <span id="toggle-icon">✏️</span>
      </button>
    </div>

    <!-- 发布面板 -->
    <div class="publish-panel hidden" id="publish-box">
      <div class="panel-topbar">
        <span class="panel-title">📝 发布新动态</span>
        <button type="button" class="icon-btn" id="close-btn" aria-label="关闭">✕</button>
      </div>
      <form id="publish-form" class="publish-form">
        <div class="form-row">
          <label class="field">
            <span class="field-label">📅 日期</span>
            <input type="date" name="date" required />
          </label>
          <label class="field">
            <span class="field-label">🏷️ 分类</span>
            <select name="category" required>
              <option value="">选择分类</option>
              {categoryOrder.map((cat) => (
                <option value={cat}>{categoryMeta[cat].icon} {cat}</option>
              ))}
            </select>
          </label>
        </div>
        <label class="field full">
          <span class="field-label">✏️ 内容</span>
          <textarea name="text" rows="3" placeholder="想说点什么..." required></textarea>
        </label>
        <label class="field full">
          <span class="field-label">🔗 链接（可选）</span>
          <input type="url" name="link" placeholder="https://..." />
        </label>

        <div class="image-upload-area" id="image-upload-area">
          <input type="file" id="image-input" accept="image/*" multiple hidden />
          <div class="upload-dropzone" id="upload-placeholder">
            <span>📷 点击上传 / 拖入图片（最多 9 张）</span>
          </div>
          <div class="image-previews" id="image-previews"></div>
        </div>

        <label class="field full token-field">
          <span class="field-label">🔑 GitHub Token</span>
          <div class="token-input-wrap">
            <input type="password" name="githubToken" placeholder="ghp_xxxxxxxxxx" required />
            <a href="https://github.com/settings/tokens/new?scopes=repo&description=Moments%20Blog" target="_blank" rel="noreferrer" class="token-link">
              如何获取？
            </a>
          </div>
        </label>

        <button type="submit" class="submit-btn" id="submit-btn">🚀 发布</button>
        <p class="form-note">Token 需要 repo 权限，发布后自动提交 GitHub 并触发构建。</p>
      </form>
      <div id="form-message"></div>
    </div>

    <!-- 时间线 -->
    <div class="moments-list">
      {sortedMoments.map((moment, idx) => (
        <article class="moment-card" data-category={moment.category} style={`--delay: ${idx * 60}ms`}>
          <div class={`card-glow glow-${moment.category}`}></div>
          <div class="card-content">
            <div class="card-meta">
              <span class={`cat-pill pill-${moment.category}`}>
                {categoryMeta[moment.category as MomentCategory].icon}
                {categoryMeta[moment.category as MomentCategory].label}
              </span>
              <time class="card-date">{moment.date}</time>
            </div>
            <p class="card-text">{moment.text}</p>
            {moment.images && moment.images.length > 0 && (
              <div class="card-images">
                {moment.images.map((img: string) => (
                  <img src={img} alt="" loading="lazy" />
                ))}
              </div>
            )}
            {moment.link && (
              <a class="card-link" href={moment.link} target="_blank" rel="noreferrer">
                🔗 {moment.link.replace(/^https?:\/\//, '').split('/')[0]}
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== 页面框架 ===== */
  .moments-shell {
    max-width: 760px;
    margin: 0 auto;
  }

  /* ===== Hero 区域 ===== */
  .moments-hero {
    position: relative;
    padding: 40px 36px 32px;
    margin-bottom: 28px;
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    overflow: hidden;
    text-align: center;
  }

  .hero-bubbles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bubble {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(30px);
  }

  .b1 {
    width: 200px; height: 200px;
    background: var(--accent);
    top: -60px; left: -40px;
    animation: bubble-float 8s ease-in-out infinite;
  }

  .b2 {
    width: 160px; height: 160px;
    background: var(--accent-2);
    bottom: -40px; right: 10%;
    animation: bubble-float 10s ease-in-out infinite reverse;
  }

  .b3 {
    width: 120px; height: 120px;
    background: var(--accent-3);
    top: 20px; right: -30px;
    animation: bubble-float 7s ease-in-out infinite 2s;
  }

  @keyframes bubble-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.05); }
  }

  .moments-hero .kicker {
    position: relative;
    z-index: 1;
  }

  .moments-hero h1 {
    position: relative;
    z-index: 1;
    margin: 10px 0 10px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: clamp(2.8rem, 7vw, 5rem);
    letter-spacing: -0.02em;
  }

  .moments-hero p {
    position: relative;
    z-index: 1;
    color: var(--muted);
    margin: 0 0 20px;
    font-size: 1.02rem;
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .stat-badge {
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--tag-bg);
    border: 1px solid var(--panel-border);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .stat-badge strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* ===== 控制栏 ===== */
  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 24px;
  }

  .cat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    padding: 7px 16px;
    border-radius: 999px;
    border: 1px solid var(--panel-border);
    background: var(--panel);
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 180ms ease;
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pill.active {
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.3);
  }

  .fab {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.35);
    transition: transform 200ms ease, box-shadow 200ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(var(--accent-rgb), 0.45);
  }

  .fab:active {
    transform: scale(0.95);
  }

  /* ===== 发布面板 ===== */
  .publish-panel {
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    padding: 24px 26px;
    margin-bottom: 28px;
    backdrop-filter: blur(14px);
  }

  .panel-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--muted);
    padding: 4px 10px;
    border-radius: 8px;
    transition: all 180ms ease;
  }

  .icon-btn:hover {
    color: var(--text);
    background: var(--tag-bg);
  }

  .publish-form {
    display: grid;
    gap: 14px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field.full {
    grid-column: 1 / -1;
  }

  .field-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .field input,
  .field select,
  .field textarea {
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.93rem;
    font-family: inherit;
    transition: border-color 180ms ease;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .field textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* 图片上传 */
  .image-upload-area {
    grid-column: 1 / -1;
  }

  .upload-dropzone {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    border: 2px dashed var(--panel-border);
    border-radius: 14px;
    cursor: pointer;
    font-size: 0.88rem;
    color: var(--muted);
    transition: all 180ms ease;
  }

  .upload-dropzone:hover,
  .upload-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--tag-bg);
    color: var(--accent);
  }

  .image-previews {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .preview-item {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-item .remove-img {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.65);
    color: white;
    border: none;
    cursor: pointer;
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-item .upload-progress {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.75rem;
    border-radius: 10px;
  }

  /* Token */
  .token-field {
    grid-column: 1 / -1;
  }

  .token-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .token-input-wrap input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.93rem;
    font-family: inherit;
    transition: border-color 180ms ease;
  }

  .token-input-wrap input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .token-link {
    font-size: 0.8rem;
    color: var(--accent);
    white-space: nowrap;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .token-link:hover {
    color: var(--accent-hover);
  }

  .submit-btn {
    grid-column: 1 / -1;
    padding: 13px;
    border-radius: 14px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    font-size: 0.97rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.3);
    transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(var(--accent-rgb), 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-note {
    grid-column: 1 / -1;
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
    text-align: center;
  }

  #form-message {
    grid-column: 1 / -1;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.88rem;
    text-align: center;
    margin-top: -4px;
  }

  #form-message.success {
    background: rgba(80, 200, 120, 0.15);
    color: #3aaa5a;
  }

  #form-message.error {
    background: rgba(255, 80, 80, 0.12);
    color: #d94040;
  }

  /* 隐藏/展开动画 */
  .publish-panel.hidden {
    display: none;
  }

  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .publish-panel:not(.hidden) {
    animation: slide-down 250ms ease both;
  }

  /* ===== 时间线卡片 ===== */
  .moments-list {
    display: grid;
    gap: 16px;
    padding-left: 20px;
    border-left: 2px solid var(--panel-border);
    margin-left: 4px;
  }

  .moment-card {
    position: relative;
    margin-left: 20px;
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(14px);
    transition: transform 220ms ease, box-shadow 220ms ease;
    animation: card-in 400ms ease both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateX(-12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .moment-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .moment-card::before {
    content: '';
    position: absolute;
    left: -25px;
    top: 22px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
  }

  .card-glow {
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }

  .glow-游戏 { background: linear-gradient(to bottom, #ff8fb3, #a88cff); }
  .glow-音乐 { background: linear-gradient(to bottom, #ffcf7a, #ff8fb3); }
  .glow-生活 { background: linear-gradient(to bottom, #a88cff, #ffcf7a); }

  .card-content {
    padding: 20px 22px 20px 26px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cat-pill {
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .pill-游戏 { background: rgba(255, 143, 179, 0.15); color: #ff6d9e; }
  .pill-音乐 { background: rgba(255, 207, 122, 0.15); color: #e6a820; }
  .pill-生活 { background: rgba(168, 140, 255, 0.15); color: #9b7be6; }

  .card-date {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .card-text {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .card-images {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 6px;
  }

  .card-images img {
    width: 110px;
    height: 110px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--panel-border);
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .card-images img:hover {
    transform: scale(1.04);
    box-shadow: var(--shadow-soft);
  }

  .card-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 180ms ease;
  }

  .card-link:hover {
    color: var(--accent-hover);
  }

  .moment-card.hidden {
    display: none !important;
  }

  /* ===== 图片灯箱 ===== */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    cursor: zoom-out;
  }

  .lightbox-overlay img {
    max-width: 90vw;
    max-height: 90vh;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
</style>

<script>
  // 分类筛选
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pill[data-category]');
  const cards = document.querySelectorAll<HTMLElement>('.moment-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const selected = tab.dataset.category ?? 'all';
      cards.forEach((card) => {
        card.classList.toggle('hidden', selected !== 'all' && card.dataset.category !== selected);
      });
    });
  });

  // 发布面板开关
  const toggleBtn = document.getElementById('publish-toggle');
  const publishBox = document.getElementById('publish-box');
  const closeBtn = document.getElementById('close-btn');
  const toggleIcon = document.getElementById('toggle-icon');

  toggleBtn?.addEventListener('click', () => {
    publishBox?.classList.toggle('hidden');
    const isOpen = !publishBox?.classList.contains('hidden');
    if (toggleIcon) toggleIcon.textContent = isOpen ? '🔼' : '✏️';
    if (isOpen) publishBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  closeBtn?.addEventListener('click', () => {
    publishBox?.classList.add('hidden');
    if (toggleIcon) toggleIcon.textContent = '✏️';
  });

  // 图片上传
  const imageInput = document.getElementById('image-input') as HTMLInputElement | null;
  const uploadPlaceholder = document.getElementById('upload-placeholder');
  const imagePreviews = document.getElementById('image-previews');
  const uploadArea = document.getElementById('image-upload-area');
  const form = document.getElementById('publish-form') as HTMLFormElement | null;
  const msg = document.getElementById('form-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const uploadedImages: string[] = [];

  uploadPlaceholder?.addEventListener('click', () => imageInput?.click());
  uploadArea?.addEventListener('dragover', (e) => { e.preventDefault(); uploadPlaceholder?.classList.add('drag-over'); });
  uploadArea?.addEventListener('dragleave', () => { uploadPlaceholder?.classList.remove('drag-over'); });
  uploadArea?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadPlaceholder?.classList.remove('drag-over');
    const files = (e as DragEvent).dataTransfer?.files;
    if (files) handleFiles(Array.from(files));
  });
  imageInput?.addEventListener('change', () => {
    if (imageInput.files) handleFiles(Array.from(imageInput.files));
    imageInput.value = '';
  });

  async function handleFiles(files: File[]) {
    const tokenInput = form?.querySelector<HTMLInputElement>('input[name="githubToken"]');
    const token = tokenInput?.value;
    if (!token) { alert('请先填写 GitHub Token'); return; }

    for (const file of files) {
      if (!file.type.startsWith('image/')) continue;
      const previewId = `preview-${Date.now()}-${Math.random().toString(36).slice(2)}`;

      const reader = new FileReader();
      reader.onload = (e) => {
        const div = document.createElement('div');
        div.className = 'preview-item';
        div.id = previewId;
        div.innerHTML = `<img src="${e.target?.result}" alt="" /><div class="upload-progress">上传中...</div><button type="button" class="remove-img">✕</button>`;
        imagePreviews?.appendChild(div);
        div.querySelector('.remove-img')?.addEventListener('click', () => {
          const idx = uploadedImages.indexOf(previewId);
          if (idx > -1) uploadedImages.splice(idx, 1);
          div.remove();
        });
      };
      reader.readAsDataURL(file);

      try {
        const fd = new FormData();
        fd.append('file', file);
        fd.append('githubToken', token);
        const res = await fetch('/api/moments', { method: 'PUT', body: fd });
        const result = await res.json();
        const previewEl = document.getElementById(previewId);
        if (result.success) {
          uploadedImages.push(result.url);
          const p = previewEl?.querySelector<HTMLElement>('.upload-progress');
          if (p) { p.textContent = '✅'; setTimeout(() => p.remove(), 1000); }
        } else {
          const p = previewEl?.querySelector<HTMLElement>('.upload-progress');
          if (p) { p.textContent = '❌'; p.style.color = '#d94040'; }
        }
      } catch {
        const previewEl = document.getElementById(previewId);
        const p = previewEl?.querySelector<HTMLElement>('.upload-progress');
        if (p) { p.textContent = '❌'; p.style.color = '#d94040'; }
      }
    }
  }

  if (form && msg && submitBtn) {
    const dateInput = form.querySelector<HTMLInputElement>('input[name="date"]');
    if (dateInput) dateInput.value = new Date().toISOString().slice(0, 10);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const data = {
        date: fd.get('date'),
        category: fd.get('category'),
        text: fd.get('text'),
        link: fd.get('link') || undefined,
        images: uploadedImages.length > 0 ? [...uploadedImages] : undefined,
        githubToken: fd.get('githubToken'),
      };
      submitBtn.disabled = true;
      submitBtn.textContent = '发布中...';
      msg.textContent = '';
      msg.className = '';

      try {
        const res = await fetch('/api/moments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (result.success) {
          msg.textContent = '✅ 发布成功！页面将自动刷新...';
          msg.className = 'success';
          setTimeout(() => location.reload(), 1500);
        } else {
          msg.textContent = '❌ ' + (result.error ?? '发布失败');
          msg.className = 'error';
        }
      } catch {
        msg.textContent = '❌ 网络错误，请检查 Token 和网络连接';
        msg.className = 'error';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '🚀 发布';
      }
    });
  }

  // 图片灯箱
  document.querySelectorAll('.card-images img').forEach((img) => {
    img.addEventListener('click', () => {
      const overlay = document.createElement('div');
      overlay.className = 'lightbox-overlay';
      overlay.innerHTML = `<img src="${(img as HTMLImageElement).src}" alt="" />`;
      overlay.addEventListener('click', () => overlay.remove());
      document.body.appendChild(overlay);
    });
  });
</script>
