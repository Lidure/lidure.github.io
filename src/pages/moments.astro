---
import BaseLayout from '../layouts/BaseLayout.astro';
import { moments, categoryMeta, categoryOrder } from '../data/moments';
import type { MomentCategory } from '../data/moments';

const sortedMoments = [...moments].sort(
  (a, b) => toSortTime(b.date) - toSortTime(a.date)
);

const stats = categoryOrder.map((cat) => ({
  cat,
  count: sortedMoments.filter((m) => m.category === cat).length,
}));
const total = sortedMoments.length;
const rawImageBase = 'https://raw.githubusercontent.com/Lidure/lidure.github.io/main/public/moments/';
const legacyImageBase = 'https://lidure.github.io/moments/';

function toSortTime(value: string) {
  const normalized = value.includes('T') ? value : `${value}T00:00`;
  const time = new Date(normalized).valueOf();
  return Number.isNaN(time) ? 0 : time;
}

function formatMomentDate(value: string) {
  const [datePart, timePart] = value.split('T');
  return timePart ? `${datePart} ${timePart.slice(0, 5)}` : datePart;
}

function momentImageSrc(src: string) {
  if (src.startsWith(rawImageBase)) return `/moments/${src.slice(rawImageBase.length)}`;
  if (src.startsWith(legacyImageBase)) return `/moments/${src.slice(legacyImageBase.length)}`;
  if (src.startsWith('/moments/')) return src;
  return src;
}
---
<BaseLayout title="碎碎念 | 搁浅 的小窝" description="游戏，音乐、生活，随时碎碎念。" showTime={true}>
  <section class="moments-shell">

    <!-- Hero -->
    <div class="moments-hero">
      <div class="hero-bubbles">
        <span class="bubble b1"></span>
        <span class="bubble b2"></span>
        <span class="bubble b3"></span>
      </div>
      <span class="kicker">✨ Moments</span>
      <h1>碎碎念</h1>
      <p>随手记下的碎片，游戏 · 音乐 · 生活。随时更新，想到什么说什么。</p>
      <div class="hero-stats">
        <span class="stat-badge">
          <strong>{total}</strong> 条动态
        </span>
        {stats.map((s) => (
          <span class="stat-badge">
            {categoryMeta[s.cat].icon} <strong>{s.count}</strong>
          </span>
        ))}
      </div>
    </div>

    <!-- 控制栏：筛选 + 发布 -->
    <div class="controls-bar">
      <div class="cat-pills">
        <button class="pill active" data-category="all">全部</button>
        {categoryOrder.map((cat) => (
          <button class="pill" data-category={cat}>
            {categoryMeta[cat].icon}
          </button>
        ))}
      </div>
      <button class="fab" id="publish-toggle" aria-label="发布新动态">
        <span id="toggle-icon">✏️</span>
      </button>
    </div>

    <!-- 发布面板 -->
    <div class="publish-panel hidden" id="publish-box">
      <div class="panel-topbar">
        <span class="panel-title">📝 发布新动态</span>
        <button type="button" class="icon-btn" id="close-btn" aria-label="关闭">✕</button>
      </div>
      <form id="publish-form" class="publish-form">
        <div class="form-row">
          <label class="field">
            <span class="field-label">🕒 时间</span>
            <input type="datetime-local" name="date" required />
          </label>
          <label class="field">
            <span class="field-label">🏷️ 分类</span>
            <select name="category" required>
              <option value="">选择分类</option>
              {categoryOrder.map((cat) => (
                <option value={cat}>{categoryMeta[cat].icon} {cat}</option>
              ))}
            </select>
          </label>
        </div>
        <label class="field full">
          <span class="field-label">✏️ 内容</span>
          <textarea name="text" rows="3" placeholder="想说点什么..." required></textarea>
        </label>
        <label class="field full">
          <span class="field-label">🔗 链接（可选）</span>
          <input type="url" name="link" placeholder="https://..." />
        </label>

        <div class="image-upload-area" id="image-upload-area">
          <input type="file" id="image-input" accept="image/*" multiple hidden />
          <div class="upload-dropzone" id="upload-placeholder">
            <span>📷 点击上传 / 拖入 / Ctrl+V 粘贴图片（最多 9 张）</span>
          </div>
          <div class="image-previews" id="image-previews"></div>
        </div>

        <label class="field full token-field">
          <span class="field-label">🔑 GitHub Token <span id="token-saved-badge" class="token-saved-badge" style="display:none">✓ 已保存</span></span>
          <div class="token-input-wrap">
            <input type="password" name="githubToken" id="token-input" placeholder="首次输入后自动保存，下次不用再填" />
            <button type="button" id="token-clear-btn" class="token-clear-btn" title="清除已保存的 Token" style="display:none">✕</button>
            <a href="https://github.com/settings/tokens/new?scopes=repo&description=Moments%20Blog" target="_blank" rel="noreferrer" class="token-link">
              如何获取？
            </a>
          </div>
        </label>



        <button type="submit" class="submit-btn" id="submit-btn">🚀 发布</button>
        <p class="form-note">Token 需要 repo 权限。首次输入后会自动保存，无需重复填写。</p>
      </form>
      <div id="form-message"></div>
    </div>

    <!-- 时间线 -->
    <div class="moments-list">
      {sortedMoments.map((moment, idx) => (
        <article class="moment-card" data-category={moment.category} style={`--delay: ${idx * 60}ms`}>
          <div class={`card-glow glow-${moment.category}`}></div>
          <div class="card-content">
            <div class="card-meta">
              <span class={`cat-pill pill-${moment.category}`}>
                {categoryMeta[moment.category as MomentCategory].icon}
                {categoryMeta[moment.category as MomentCategory].label}
              </span>
              <time class="card-date" datetime={moment.date}>{formatMomentDate(moment.date)}</time>
            </div>
            <p class="card-text">{moment.text}</p>
            {moment.images && moment.images.length > 0 && (
              <div class="card-images" data-count={moment.images.length}>
                {moment.images.map((img: string) => (
                  <img
                    src={momentImageSrc(img)}
                    data-lightbox-src={momentImageSrc(img)}
                    data-original-src={img}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    role="button"
                    tabindex="0"
                    aria-label="Open image preview"
                  />
                ))}
              </div>
            )}
            {moment.link && (
              <a class="card-link" href={moment.link} target="_blank" rel="noreferrer">
                🔗 {moment.link.replace(/^https?:\/\//, '').split('/')[0]}
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <div class="lightbox-overlay" id="moment-lightbox" aria-hidden="true" hidden>
      <button type="button" class="lightbox-close" id="lightbox-close" aria-label="Close image preview">&times;</button>
      <button type="button" class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Previous image">&#8249;</button>
      <figure class="lightbox-stage" id="lightbox-stage">
        <img class="lightbox-image" id="lightbox-image" src="" alt="" decoding="async" />
        <figcaption class="lightbox-counter" id="lightbox-counter"></figcaption>
      </figure>
      <button type="button" class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Next image">&#8250;</button>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== 页面框架 ===== */
  .moments-shell {
    max-width: 760px;
    margin: 0 auto;
  }

  /* ===== Hero 区域 ===== */
  .moments-hero {
    position: relative;
    padding: 40px 36px 32px;
    margin-bottom: 28px;
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    overflow: hidden;
    text-align: center;
  }

  .hero-bubbles {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .bubble {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(30px);
  }

  .b1 {
    width: 200px; height: 200px;
    background: var(--accent);
    top: -60px; left: -40px;
    animation: bubble-float 8s ease-in-out infinite;
  }

  .b2 {
    width: 160px; height: 160px;
    background: var(--accent-2);
    bottom: -40px; right: 10%;
    animation: bubble-float 10s ease-in-out infinite reverse;
  }

  .b3 {
    width: 120px; height: 120px;
    background: var(--accent-3);
    top: 20px; right: -30px;
    animation: bubble-float 7s ease-in-out infinite 2s;
  }

  @keyframes bubble-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.05); }
  }

  .moments-hero .kicker {
    position: relative;
    z-index: 1;
  }

  .moments-hero h1 {
    position: relative;
    z-index: 1;
    margin: 10px 0 10px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 4.2rem;
    letter-spacing: 0;
  }

  .moments-hero p {
    position: relative;
    z-index: 1;
    color: var(--muted);
    margin: 0 0 20px;
    font-size: 1.02rem;
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .stat-badge {
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--tag-bg);
    border: 1px solid var(--panel-border);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .stat-badge strong {
    color: var(--accent);
    font-weight: 700;
  }

  /* ===== 控制栏 ===== */
  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 24px;
  }

  .cat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    padding: 7px 16px;
    border-radius: 999px;
    border: 1px solid var(--panel-border);
    background: var(--panel);
    color: var(--text-soft);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 180ms ease;
  }

  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pill.active {
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.3);
  }

  .fab {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.35);
    transition: transform 200ms ease, box-shadow 200ms ease;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(var(--accent-rgb), 0.45);
  }

  .fab:active {
    transform: scale(0.95);
  }

  /* ===== 发布面板 ===== */
  .publish-panel {
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
    padding: 24px 26px;
    margin-bottom: 28px;
    backdrop-filter: blur(14px);
  }

  .panel-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .panel-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--muted);
    padding: 4px 10px;
    border-radius: 8px;
    transition: all 180ms ease;
  }

  .icon-btn:hover {
    color: var(--text);
    background: var(--tag-bg);
  }

  .publish-form {
    display: grid;
    gap: 14px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field.full {
    grid-column: 1 / -1;
  }

  .field-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .field input,
  .field select,
  .field textarea {
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.93rem;
    font-family: inherit;
    transition: border-color 180ms ease;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .field textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* 图片上传 */
  .image-upload-area {
    grid-column: 1 / -1;
  }

  .upload-dropzone {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    border: 2px dashed var(--panel-border);
    border-radius: 14px;
    cursor: pointer;
    font-size: 0.88rem;
    color: var(--muted);
    transition: all 180ms ease;
  }

  .upload-dropzone:hover,
  .upload-dropzone.drag-over {
    border-color: var(--accent);
    background: var(--tag-bg);
    color: var(--accent);
  }

  .image-previews {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .preview-item {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--panel-border);
  }

  .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-item .remove-img {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(0,0,0,0.65);
    color: white;
    border: none;
    cursor: pointer;
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-item .upload-progress {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.75rem;
    border-radius: 10px;
  }

  .preview-item .upload-progress.hidden {
    display: none;
  }

  .preview-item.uploaded .upload-progress {
    background: rgba(40, 140, 80, 0.72);
  }

  .preview-item.failed .upload-progress {
    background: rgba(160, 30, 30, 0.72);
  }

  /* Token */
  .token-field {
    grid-column: 1 / -1;
  }



  .token-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .token-input-wrap input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    background: var(--bg);
    color: var(--text);
    font-size: 0.93rem;
    font-family: inherit;
    transition: border-color 180ms ease;
  }

  .token-input-wrap input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .token-link {
    font-size: 0.8rem;
    color: var(--accent);
    white-space: nowrap;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .token-link:hover {
    color: var(--accent-hover);
  }

  .token-saved-badge {
    font-size: 0.75rem;
    color: #3aaa5a;
    font-weight: 600;
    margin-left: 6px;
    padding: 2px 8px;
    border-radius: 999px;
    background: rgba(80, 200, 120, 0.12);
  }

  [data-theme="light"] .token-saved-badge {
    color: #6ed88a;
    background: rgba(80, 200, 120, 0.16);
  }

  .token-clear-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--panel-border);
    background: var(--bg-soft);
    color: var(--muted);
    cursor: pointer;
    font-size: 0.78rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 180ms ease;
  }

  .token-clear-btn:hover {
    color: #d94040;
    border-color: rgba(217, 64, 64, 0.3);
    background: rgba(217, 64, 64, 0.08);
  }

  .submit-btn {
    grid-column: 1 / -1;
    padding: 13px;
    border-radius: 14px;
    border: none;
    background: linear-gradient(135deg, var(--accent), var(--accent-3));
    color: white;
    font-size: 0.97rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.3);
    transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(var(--accent-rgb), 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-note {
    grid-column: 1 / -1;
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
    text-align: center;
  }

  #form-message {
    grid-column: 1 / -1;
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 0.88rem;
    text-align: center;
    margin-top: -4px;
  }

  #form-message.success {
    background: rgba(80, 200, 120, 0.15);
    color: #3aaa5a;
  }

  #form-message.error {
    background: rgba(255, 80, 80, 0.12);
    color: #d94040;
  }

  /* 隐藏/展开动画 */
  .publish-panel.hidden {
    display: none;
  }

  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .publish-panel:not(.hidden) {
    animation: slide-down 250ms ease both;
  }

  /* ===== 时间线卡片 ===== */
  .moments-list {
    display: grid;
    gap: 16px;
    padding-left: 20px;
    border-left: 2px solid var(--panel-border);
    margin-left: 4px;
  }

  .moment-card {
    position: relative;
    margin-left: 20px;
    background: var(--panel-gradient);
    border: 1px solid var(--panel-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(14px);
    transition: transform 220ms ease, box-shadow 220ms ease;
    animation: card-in 400ms ease both;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateX(-12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .moment-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
  }

  .moment-card::before {
    content: '';
    position: absolute;
    left: -25px;
    top: 22px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
  }

  .card-glow {
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
  }

  .glow-游戏 { background: linear-gradient(to bottom, #FF6B9D, #7C8CF8); }
  .glow-音乐 { background: linear-gradient(to bottom, #FFB347, #FF6B9D); }
  .glow-生活 { background: linear-gradient(to bottom, #7C8CF8, #FFB347); }

  .card-content {
    padding: 20px 22px 20px 26px;
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cat-pill {
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .pill-游戏 { background: rgba(255, 107, 157, 0.12); color: #E0456E; }
  .pill-音乐 { background: rgba(255, 179, 71, 0.12); color: #CC8820; }
  .pill-生活 { background: rgba(124, 140, 248, 0.12); color: #5566CC; }

  [data-theme="light"] .pill-游戏 { background: rgba(255, 107, 157, 0.18); color: #FF9EBE; }
  [data-theme="light"] .pill-音乐 { background: rgba(255, 179, 71, 0.18); color: #FFCC77; }
  [data-theme="light"] .pill-生活 { background: rgba(124, 140, 248, 0.18); color: #A0AEFF; }

  .card-date {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .card-text {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .card-images {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
    gap: 8px;
    max-width: 430px;
    margin: 0 0 10px;
  }

  .card-images[data-count="1"] {
    grid-template-columns: minmax(0, 420px);
  }

  .card-images[data-count="2"] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 430px;
  }

  .card-images img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 10px;
    border: 1px solid var(--panel-border);
    background: var(--bg-soft);
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .card-images img:hover {
    transform: translateY(-2px);
    border-color: var(--hover-border);
    box-shadow: var(--shadow-soft);
  }

  .card-link {
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 180ms ease;
  }

  .card-link:hover {
    color: var(--accent-hover);
  }

  .moment-card.hidden {
    display: none !important;
  }

  /* ===== 图片灯箱 ===== */
  :global(body.lightbox-open) {
    overflow: hidden;
  }

  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    grid-template-columns: minmax(48px, 1fr) minmax(0, auto) minmax(48px, 1fr);
    align-items: center;
    justify-items: center;
    gap: 18px;
    padding: 28px;
    background: rgba(8, 8, 12, 0.88);
    backdrop-filter: blur(10px);
  }

  .lightbox-overlay[hidden],
  .lightbox-nav[hidden] {
    display: none;
  }

  .lightbox-stage {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    max-width: min(92vw, 1080px);
    max-height: 90vh;
    margin: 0;
  }

  .lightbox-image {
    display: block;
    max-width: min(92vw, 1080px);
    max-height: calc(90vh - 38px);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.52);
    background: rgba(255, 255, 255, 0.04);
  }

  .lightbox-counter {
    min-height: 20px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .lightbox-close,
  .lightbox-nav {
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 180ms ease, transform 180ms ease, border-color 180ms ease;
  }

  .lightbox-close:hover,
  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.24);
    border-color: rgba(255, 255, 255, 0.34);
  }

  .lightbox-close:active,
  .lightbox-nav:active {
    transform: scale(0.96);
  }

  .lightbox-close {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    font-size: 1.55rem;
    line-height: 1;
  }

  .lightbox-nav {
    width: 46px;
    height: 64px;
    border-radius: 999px;
    font-size: 2.2rem;
    line-height: 1;
  }

  .lightbox-prev {
    grid-column: 1;
    justify-self: end;
  }

  .lightbox-next {
    grid-column: 3;
    justify-self: start;
  }

  @media (max-width: 640px) {
    .moments-hero {
      padding: 32px 20px 26px;
    }

    .moments-hero h1 {
      font-size: 3rem;
      line-height: 1.08;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .controls-bar {
      align-items: flex-start;
    }

    .card-images,
    .card-images[data-count="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: none;
    }

    .card-images[data-count="1"] {
      grid-template-columns: 1fr;
    }

    .lightbox-overlay {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 54px 12px 74px;
    }

    .lightbox-stage {
      grid-column: 1;
      max-width: 96vw;
      max-height: calc(100vh - 132px);
    }

    .lightbox-image {
      max-width: 96vw;
      max-height: calc(100vh - 154px);
      border-radius: 8px;
    }

    .lightbox-close {
      top: 12px;
      right: 12px;
      width: 40px;
      height: 40px;
    }

    .lightbox-nav {
      position: fixed;
      bottom: 16px;
      width: 44px;
      height: 44px;
      font-size: 1.8rem;
    }

    .lightbox-prev {
      left: calc(50% - 54px);
    }

    .lightbox-next {
      right: calc(50% - 54px);
    }
  }

  @media (max-width: 480px) {
    .moments-shell {
      padding: 0 2px;
    }

    .moments-hero {
      padding: 24px 16px 20px;
    }

    .moments-hero h1 {
      font-size: 2.3rem;
    }

    .moments-hero p {
      font-size: 0.88rem;
    }

    .hero-stats {
      gap: 8px;
    }

    .stat-badge {
      font-size: 0.78rem;
      padding: 4px 11px;
    }

    .controls-bar {
      flex-wrap: wrap;
      gap: 8px;
    }

    .controls-bar .pill {
      font-size: 0.78rem;
      padding: 6px 12px;
    }

    .moments-list {
      padding-left: 12px;
      margin-left: 2px;
    }

    .moment-card {
      margin-left: 14px;
      border-radius: 14px;
    }

    .moment-card::before {
      left: -19px;
      width: 8px;
      height: 8px;
    }

    .card-content {
      padding: 14px 16px 14px 18px;
    }

    .card-date {
      font-size: 0.75rem;
    }

    .card-text {
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .cat-pill {
      font-size: 0.68rem;
      padding: 3px 9px;
    }

    .card-images,
    .card-images[data-count="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: none;
    }

    .card-images[data-count="1"] {
      grid-template-columns: 1fr;
    }

    .publish-panel {
      padding: 16px 14px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .token-input-wrap {
      flex-wrap: wrap;
    }

    .token-input-wrap input {
      font-size: 0.82rem;
    }

    .upload-dropzone {
      font-size: 0.8rem;
      padding: 14px;
    }

    .icon-btn {
      min-width: 44px;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

<script>
  import { uploadToR2 } from '../lib/r2-upload';

  // 分类筛选
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pill[data-category]');
  const cards = document.querySelectorAll<HTMLElement>('.moment-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const selected = tab.dataset.category ?? 'all';
      cards.forEach((card) => {
        card.classList.toggle('hidden', selected !== 'all' && card.dataset.category !== selected);
      });
    });
  });

  // 发布面板开关
  const toggleBtn = document.getElementById('publish-toggle');
  const publishBox = document.getElementById('publish-box');
  const closeBtn = document.getElementById('close-btn');
  const toggleIcon = document.getElementById('toggle-icon');

  toggleBtn?.addEventListener('click', () => {
    publishBox?.classList.toggle('hidden');
    const isOpen = !publishBox?.classList.contains('hidden');
    if (toggleIcon) toggleIcon.textContent = isOpen ? '🔼' : '✏️';
    if (isOpen) publishBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  closeBtn?.addEventListener('click', () => {
    publishBox?.classList.add('hidden');
    if (toggleIcon) toggleIcon.textContent = '✏️';
  });

  // 图片上传
  const imageInput = document.getElementById('image-input') as HTMLInputElement | null;
  const uploadPlaceholder = document.getElementById('upload-placeholder');
  const imagePreviews = document.getElementById('image-previews');
  const uploadArea = document.getElementById('image-upload-area');
  const form = document.getElementById('publish-form') as HTMLFormElement | null;
  const msg = document.getElementById('form-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const selectedImages: Array<{ id: string; file: File; previewUrl: string; remoteUrl?: string }> = [];
  const githubOwner = 'Lidure';
  const githubRepo = 'lidure.github.io';
  const githubBranch = 'main';
  const momentsPath = 'src/data/moments.json';
  const maxImages = 9;
  const maxImageBytes = 8 * 1024 * 1024;

  type GitHubContentPayload = {
    sha?: string;
    content?: string;
    message?: string;
  };

  type MomentPayload = {
    date: string;
    category: string;
    text: string;
    link?: string;
    images?: string[];
  };

  function localDateTimeValue(date = new Date()) {
    const local = new Date(date.getTime() - date.getTimezoneOffset() * 60_000);
    return local.toISOString().slice(0, 16);
  }

  function githubHeaders(token: string, withJson = false) {
    const headers: Record<string, string> = {
      Authorization: `Bearer ${token}`,
      Accept: 'application/vnd.github+json',
      'X-GitHub-Api-Version': '2022-11-28',
    };

    if (withJson) headers['Content-Type'] = 'application/json';

    return headers;
  }

  async function readGitHubResponse(res: Response): Promise<GitHubContentPayload> {
    const text = await res.text();
    let result: GitHubContentPayload = {};

    if (text) {
      try {
        result = JSON.parse(text);
      } catch {
        result = { message: text.slice(0, 500) };
      }
    }

    if (!res.ok) {
      throw new Error(result.message ?? `GitHub API HTTP ${res.status}`);
    }

    return result;
  }

  function arrayBufferToBase64(buffer: ArrayBuffer) {
    const bytes = new Uint8Array(buffer);
    const chunkSize = 0x8000;
    let binary = '';

    for (let i = 0; i < bytes.length; i += chunkSize) {
      const chunk = bytes.subarray(i, i + chunkSize);
      binary += String.fromCharCode(...chunk);
    }

    return btoa(binary);
  }

  function stringToBase64(value: string) {
    const bytes = new TextEncoder().encode(value);
    const buffer = bytes.buffer.slice(bytes.byteOffset, bytes.byteOffset + bytes.byteLength);
    return arrayBufferToBase64(buffer);
  }

  function base64ToString(value: string) {
    const binary = atob(value.replace(/\s/g, ''));
    const bytes = new Uint8Array(binary.length);

    for (let i = 0; i < binary.length; i += 1) {
      bytes[i] = binary.charCodeAt(i);
    }

    return new TextDecoder().decode(bytes);
  }

  async function fetchCurrentMoments(token: string) {
    const res = await fetch(
      `https://api.github.com/repos/${githubOwner}/${githubRepo}/contents/${momentsPath}?ref=${githubBranch}`,
      { headers: githubHeaders(token) }
    );

    if (res.status === 404) return { moments: [] as MomentPayload[], sha: undefined };

    const result = await readGitHubResponse(res);
    if (!result.content || !result.sha) {
      throw new Error('GitHub 返回的 moments.json 内容不完整');
    }

    const parsed = JSON.parse(base64ToString(result.content));
    return {
      moments: Array.isArray(parsed) ? parsed as MomentPayload[] : [],
      sha: result.sha,
    };
  }

  async function putGitHubFile(token: string, path: string, content: string, message: string, sha?: string) {
    const res = await fetch(
      `https://api.github.com/repos/${githubOwner}/${githubRepo}/contents/${path}`,
      {
        method: 'PUT',
        headers: githubHeaders(token, true),
        body: JSON.stringify({
          message,
          content,
          ...(sha && { sha }),
          branch: githubBranch,
        }),
      }
    );

    return readGitHubResponse(res);
  }

  async function publishMoment(token: string, moment: MomentPayload) {
    const current = await fetchCurrentMoments(token);
    const momentsJson = JSON.stringify([moment, ...current.moments], null, 2) + '\n';

    await putGitHubFile(
      token,
      momentsPath,
      stringToBase64(momentsJson),
      `Add moment: ${moment.text.slice(0, 30)}${moment.text.length > 30 ? '...' : ''}`,
      current.sha
    );
  }



  function setMessage(text: string, type: 'success' | 'error' | '') {
    if (!msg) return;
    msg.textContent = text;
    msg.className = type;
  }

  function setPreviewStatus(id: string, text: string, state: 'idle' | 'uploading' | 'uploaded' | 'failed') {
    const item = document.getElementById(`preview-${id}`);
    const progress = item?.querySelector<HTMLElement>('.upload-progress');
    if (!item || !progress) return;

    item.classList.toggle('uploaded', state === 'uploaded');
    item.classList.toggle('failed', state === 'failed');
    progress.classList.toggle('hidden', state === 'idle');
    progress.textContent = text;
  }

  function renderPreviews() {
    if (!imagePreviews) return;
    imagePreviews.innerHTML = '';

    selectedImages.forEach((item) => {
      const div = document.createElement('div');
      div.className = 'preview-item';
      div.id = `preview-${item.id}`;

      const img = document.createElement('img');
      img.src = item.previewUrl;
      img.alt = item.file.name;

      const progress = document.createElement('div');
      progress.className = 'upload-progress hidden';

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'remove-img';
      removeBtn.textContent = '✕';
      removeBtn.addEventListener('click', () => {
        const index = selectedImages.findIndex((image) => image.id === item.id);
        if (index > -1) {
          URL.revokeObjectURL(selectedImages[index].previewUrl);
          selectedImages.splice(index, 1);
          renderPreviews();
        }
      });

      div.append(img, progress, removeBtn);
      imagePreviews.appendChild(div);

      if (item.remoteUrl) setPreviewStatus(item.id, '已上传', 'uploaded');
    });
  }

  async function uploadSelectedImages() {
    const urls: string[] = [];

    for (const item of selectedImages) {
      if (item.remoteUrl) {
        urls.push(item.remoteUrl);
        continue;
      }

      setPreviewStatus(item.id, '上传中...', 'uploading');

      if (item.file.size > maxImageBytes) {
        setPreviewStatus(item.id, '过大', 'failed');
        throw new Error('图片过大，请控制在 8 MB 以内');
      }

      try {
        const url = await uploadToR2(item.file);
        item.remoteUrl = url;
        urls.push(url);
        setPreviewStatus(item.id, '已上传', 'uploaded');
      } catch (err) {
        setPreviewStatus(item.id, '失败', 'failed');
        throw err;
      }
    }

    return urls;
  }

  uploadPlaceholder?.addEventListener('click', () => imageInput?.click());
  uploadArea?.addEventListener('dragover', (e) => { e.preventDefault(); uploadPlaceholder?.classList.add('drag-over'); });
  uploadArea?.addEventListener('dragleave', () => { uploadPlaceholder?.classList.remove('drag-over'); });
  uploadArea?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadPlaceholder?.classList.remove('drag-over');
    const files = (e as DragEvent).dataTransfer?.files;
    if (files) handleFiles(Array.from(files));
  });
  imageInput?.addEventListener('change', () => {
    if (imageInput.files) handleFiles(Array.from(imageInput.files));
    imageInput.value = '';
  });

  // 剪贴板粘贴图片
  document.addEventListener('paste', (e) => {
    // 只在发布面板打开时拦截
    if (publishBox?.classList.contains('hidden')) return;
    const items = e.clipboardData?.items;
    if (!items) return;
    const files: File[] = [];
    for (let i = 0; i < items.length; i++) {
      if (items[i].type.startsWith('image/')) {
        const file = items[i].getAsFile();
        if (file) files.push(file);
      }
    }
    if (files.length > 0) {
      e.preventDefault();
      handleFiles(files);
      setMessage(`📷 已粘贴 ${files.length} 张图片`, 'success');
    }
  });

  async function handleFiles(files: File[]) {
    for (const file of files) {
      if (!file.type.startsWith('image/')) continue;

      if (selectedImages.length >= maxImages) {
        setMessage(`最多选择 ${maxImages} 张图片`, 'error');
        break;
      }

      selectedImages.push({
        id: `${Date.now()}-${Math.random().toString(36).slice(2)}`,
        file,
        previewUrl: URL.createObjectURL(file),
      });
    }

    renderPreviews();
  }

  if (form && msg && submitBtn) {
    const dateInput = form.querySelector<HTMLInputElement>('input[name="date"]');
    if (dateInput) dateInput.value = localDateTimeValue();

    // Token 自动保存/填充
    const TOKEN_KEY = 'blog_gh_token';
    const tokenInput = document.getElementById('token-input') as HTMLInputElement | null;
    const savedBadge = document.getElementById('token-saved-badge');
    const clearBtn = document.getElementById('token-clear-btn');

    function refreshTokenUI() {
      const saved = localStorage.getItem(TOKEN_KEY);
      if (saved && tokenInput && !tokenInput.value) {
        tokenInput.value = saved;
      }
      const hasToken = !!(tokenInput?.value || localStorage.getItem(TOKEN_KEY));
      if (savedBadge) savedBadge.style.display = hasToken ? 'inline' : 'none';
      if (clearBtn) clearBtn.style.display = hasToken ? 'inline-flex' : 'none';
    }

    refreshTokenUI();

    clearBtn?.addEventListener('click', () => {
      localStorage.removeItem(TOKEN_KEY);
      if (tokenInput) tokenInput.value = '';
      refreshTokenUI();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      let githubToken = String(fd.get('githubToken') ?? '').trim();

      // 如果输入框为空，尝试从 localStorage 读取
      if (!githubToken) {
        githubToken = localStorage.getItem(TOKEN_KEY) || '';
      }

      submitBtn.disabled = true;
      submitBtn.textContent = selectedImages.length > 0 ? '上传图片...' : '发布中...';
      setMessage('', '');

      try {
        const link = String(fd.get('link') ?? '').trim();
        const baseMoment: MomentPayload = {
          date: String(fd.get('date') ?? '').trim(),
          category: String(fd.get('category') ?? '').trim(),
          text: String(fd.get('text') ?? '').trim(),
          ...(link && { link }),
        };

        if (!githubToken) throw new Error('请填写 GitHub Token（首次使用需要输入一次，之后自动保存）');
        if (!baseMoment.date || !baseMoment.category || !baseMoment.text) throw new Error('请填写时间、分类和内容');

        const imageUrls = selectedImages.length > 0 ? await uploadSelectedImages() : [];
        const moment: MomentPayload = {
          ...baseMoment,
          ...(imageUrls.length > 0 && { images: imageUrls }),
        };

        submitBtn.textContent = '发布中...';
        await publishMoment(githubToken, moment);

        // 发布成功后保存 token
        try { localStorage.setItem(TOKEN_KEY, githubToken); } catch(e) {}
        refreshTokenUI();

        setMessage('✅ 已提交到 GitHub。等待 GitHub Pages 构建完成后刷新页面查看。', 'success');
      } catch (err) {
        const detail = err instanceof Error ? err.message : String(err);
        setMessage('❌ 发布失败: ' + detail.slice(0, 160), 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '🚀 发布';
      }
    });
  }

  // 图片灯箱
  const lightbox = document.getElementById('moment-lightbox') as HTMLElement | null;
  const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement | null;
  const lightboxCounter = document.getElementById('lightbox-counter');
  const lightboxStage = document.getElementById('lightbox-stage');
  const lightboxClose = document.getElementById('lightbox-close') as HTMLButtonElement | null;
  const lightboxPrev = document.getElementById('lightbox-prev') as HTMLButtonElement | null;
  const lightboxNext = document.getElementById('lightbox-next') as HTMLButtonElement | null;
  let lightboxImages: HTMLImageElement[] = [];
  let lightboxIndex = 0;
  let returnFocusTarget: HTMLElement | null = null;

  function setLightboxImage(index: number) {
    if (!lightboxImage || !lightboxCounter || !lightboxPrev || !lightboxNext || lightboxImages.length === 0) return;

    lightboxIndex = (index + lightboxImages.length) % lightboxImages.length;
    const image = lightboxImages[lightboxIndex];
    lightboxImage.src = image.dataset.lightboxSrc || image.currentSrc || image.src;
    lightboxImage.alt = image.alt || '';

    const hasMultipleImages = lightboxImages.length > 1;
    lightboxCounter.textContent = hasMultipleImages ? `${lightboxIndex + 1} / ${lightboxImages.length}` : '';
    lightboxPrev.hidden = !hasMultipleImages;
    lightboxNext.hidden = !hasMultipleImages;
  }

  function openLightbox(target: HTMLImageElement) {
    if (!lightbox || !lightboxImage) return;

    const gallery = target.closest<HTMLElement>('.card-images');
    lightboxImages = gallery ? Array.from(gallery.querySelectorAll<HTMLImageElement>('img')) : [target];
    returnFocusTarget = target;
    setLightboxImage(Math.max(0, lightboxImages.indexOf(target)));

    lightbox.hidden = false;
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.classList.add('lightbox-open');
    lightboxClose?.focus({ preventScroll: true });
  }

  function closeLightbox() {
    if (!lightbox || lightbox.hidden) return;

    lightbox.hidden = true;
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('lightbox-open');
    lightboxImage?.removeAttribute('src');
    returnFocusTarget?.focus({ preventScroll: true });
    returnFocusTarget = null;
  }

  function moveLightbox(delta: number) {
    if (lightbox?.hidden !== false || lightboxImages.length < 2) return;
    setLightboxImage(lightboxIndex + delta);
  }

  document.querySelectorAll<HTMLImageElement>('.card-images img').forEach((img) => {
    img.addEventListener('click', () => openLightbox(img));
    img.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      openLightbox(img);
    });
  });

  lightbox?.addEventListener('click', closeLightbox);
  lightboxStage?.addEventListener('click', (event) => event.stopPropagation());
  lightboxClose?.addEventListener('click', (event) => {
    event.stopPropagation();
    closeLightbox();
  });
  lightboxPrev?.addEventListener('click', (event) => {
    event.stopPropagation();
    moveLightbox(-1);
  });
  lightboxNext?.addEventListener('click', (event) => {
    event.stopPropagation();
    moveLightbox(1);
  });
  document.addEventListener('keydown', (event) => {
    if (lightbox?.hidden !== false) return;
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') moveLightbox(-1);
    if (event.key === 'ArrowRight') moveLightbox(1);
  });
</script>
