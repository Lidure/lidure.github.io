---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="文章 | Lidure Blog" description="按时间整理的博客文章。">
  <section class="archive-shell">
    <span class="kicker">Archive</span>
    <h1>文章归档</h1>
    <p>按时间倒序查看全部文章。所有内容都来自 Markdown 文件，适合长期维护。</p>

    <div class="archive-list">
      {posts.map((post) => (
        <article class="card">
          <div class="meta">
            <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
            {post.data.updatedDate && <span>更新于 {post.data.updatedDate.toLocaleDateString('zh-CN')}</span>}
          </div>
          <h3><a href={`/posts/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="tag-list">
            {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
