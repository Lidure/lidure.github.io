---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGitHubProjects } from '../../lib/github-projects';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const projects = await getGitHubProjects();
---
<BaseLayout title="归档 | 搁浅 的小窝" description="按时间整理的博客文章，并同步展示我的 GitHub 项目。">
  <section class="archive-shell">
    <span class="kicker">Archive</span>
    <h1>文章时间线</h1>
    <p>按时间倒序排列的全部文章，下方同步展示 GitHub 项目。</p>

    <div class="timeline">
      {posts.map((post) => (
        <article class="timeline-item">
          <div class="timeline-date">{post.data.pubDate.toLocaleDateString('zh-CN')}
            {post.data.updatedDate && <span style="margin-left: 8px; color: var(--muted); font-weight:400;">更新于 {post.data.updatedDate.toLocaleDateString('zh-CN')}</span>}
          </div>
          <h3><a href={`/posts/${post.slug}`}>{post.data.title}</a></h3>
          <p>{post.data.description}</p>
          <div class="tag-list" style="margin-top: 10px;">
            {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
        </article>
      ))}
    </div>

    <section class="archive-subsection">
      <div class="sekai-divider">✦ SEKAI ✦</div>
      <div class="section-title">
        <h2>GitHub 项目</h2>
      </div>

      {projects.length > 0 ? (
        <div class="project-grid">
          {projects.map((project) => (
            <article class="card project-card">
              <div class="project-topline">
                <span class="project-pill">{project.language}</span>
                <span class="project-stars">★ {project.stars}</span>
              </div>
              <h3><a href={project.htmlUrl} target="_blank" rel="noreferrer">{project.name}</a></h3>
              <p>{project.description}</p>
              <div class="project-footer">
                <span>更新于 {new Date(project.pushedAt).toLocaleDateString('zh-CN')}</span>
                {project.homepage && <a href={project.homepage} target="_blank" rel="noreferrer">官网</a>}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="card project-empty">
          <p>暂时没有拉到公开项目，可能是 GitHub API 请求失败或者当前账号没有公开仓库。</p>
        </div>
      )}
    </section>
  </section>
</BaseLayout>
