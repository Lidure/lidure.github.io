---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.slice(0, 3);

const quickLinks = [
  {
    label: '仓库主页',
    href: 'https://github.com/Lidure/lidure.github.io',
    description: '查看站点源码与部署流程。',
  },
  {
    label: '文章归档',
    href: '/posts',
    description: '按照时间顺序浏览全部文章。',
  },
  {
    label: '精选文章',
    href: featuredPost ? `/posts/${featuredPost.slug}` : '/posts',
    description: '直接进入当前置顶内容。',
  },
  {
    label: 'QQ 好友',
    href: 'https://qm.qq.com/q/ujOhar9jQQ',
    description: '有事可以直接加我 QQ 联系。',
  },
];
---
<BaseLayout title="搁浅 的小窝" description="一个带有粉彩风的 GitHub Pages 个人博客，使用 Astro、Markdown 和自动部署。">
  <section class="hero-grid">
    <section class="hero">
      <span class="floating-shape floating-shape-a" aria-hidden="true"></span>
      <span class="floating-shape floating-shape-b" aria-hidden="true"></span>
      <span class="floating-shape floating-shape-c" aria-hidden="true"></span>
      <span class="kicker">Sweet Blog Corner</span>
      <h1>把喜欢的东西，认真地收进小站里。</h1>
      <p>
        这是一个基于 Astro 的个人博客，做成了偏可爱少女风的粉彩小站，适合记录日常、灵感、项目和长期积累。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/posts">去看文章</a>
        {featuredPost && <a class="button" href={`/posts/${featuredPost.slug}`}>打开置顶</a>}
      </div>
    </section>

    <aside class="profile-card card">
      <img class="avatar" src="/p0.jpg" alt="搁浅 的头像" width="112" height="112" />
      <div>
        <span class="kicker">About Me</span>
        <h2>搁浅</h2>
        <p class="intro">
          一个偏实用主义但喜欢可爱元素的小站。这里会记录项目笔记、工具整理、写作碎片和长期可复用的经验。
        </p>
      </div>
      <div class="mini-stats">
        <div>
          <strong>{posts.length}</strong>
          <span>篇文章</span>
        </div>
        <div>
          <strong>Astro</strong>
          <span>技术栈</span>
        </div>
        <div>
          <strong>Pages</strong>
          <span>部署</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="link-grid">
    {quickLinks.map((link) => (
      <a
        class="card link-card"
        href={link.href}
        target={link.href.startsWith('http') ? '_blank' : undefined}
        rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
      >
        <span class="link-label">{link.label}</span>
        <p>{link.description}</p>
      </a>
    ))}
  </section>

  <section class="section-title">
    <h2>最新文章</h2>
    <a class="button" href="/posts">查看全部</a>
  </section>

  <section class="posts-grid">
    {latestPosts.map((post) => (
      <article class="card animated-card" style={`animation-delay: ${posts.indexOf(post) * 90}ms`}>
        <div class="meta">
          <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
          <span>{Math.ceil(post.body.length / 800)} 分钟阅读</span>
        </div>
        <h3><a href={`/posts/${post.slug}`}>{post.data.title}</a></h3>
        <p>{post.data.description}</p>
        <div class="tag-list">
          {post.data.tags.map((tag) => <span class="tag">#{tag}</span>)}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
